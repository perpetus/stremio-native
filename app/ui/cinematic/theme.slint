export global CinematicTheme {
    in property <color> canvas: #141414;
    in property <color> raised: #181818;
    in property <color> hover: #232323;
    in property <color> primary: #ffffff;
    in property <color> secondary: #e5e5e5;
    in property <color> muted: #b3b3b3;
    in property <color> accent: #7b5bf5;
    in property <color> accent-hover: #9275f7;
    in property <color> success: #46d369;
    in property <color> danger: #ff6b6b;
    in property <color> divider: #262626;
    in property <color> scrim: #000000b8;
    in property <color> focus-outer: #ffffff;
    in property <color> focus-inner: #7b5bf5;
    in property <length> page-gutter: 36px;
    in property <length> navigation-height: 64px;
    in property <length> card-radius: 4px;
    in property <length> control-radius: 4px;
    in property <length> modal-radius: 8px;
    in property <duration> motion-press: 120ms;
    in property <duration> motion-hover: 180ms;
    in property <duration> motion-expand: 240ms;
}
