import { CinematicTheme } from "../theme.slint";
import { FocusSurface } from "focus_surface.slint";

component StreamAction inherits FocusSurface {
    in property <string> label: "";
    width: 58px;
    height: 34px;
    accessible-name: root.label;
    Text {
        x: 6px;
        width: parent.width - 12px;
        height: parent.height;
        text: root.label;
        color: CinematicTheme.secondary;
        font-size: 11px;
        font-weight: 650;
        horizontal-alignment: center;
        vertical-alignment: center;
        overflow: elide;
    }
}

export component StreamRow inherits FocusSurface {
    in property <string> name: "";
    in property <string> description: "";
    in property <string> provider: "";
    callback play;
    callback copy-link;
    callback copy-magnet;
    callback download;

    height: 76px;
    accessible-name: root.name + ". " + root.description;
    clicked => { root.play(); }

    VerticalLayout {
        x: 16px;
        y: 10px;
        width: max(80px, parent.width - self.x - 214px);
        height: parent.height - 20px;
        alignment: center;
        spacing: 4px;
        Text { text: root.name; color: CinematicTheme.primary; font-size: 15px; font-weight: 700; overflow: elide; }
        Text { text: root.description; color: CinematicTheme.muted; font-size: 12px; overflow: elide; }
        if (root.provider != "") : Text { text: root.provider; color: CinematicTheme.secondary; font-size: 11px; overflow: elide; }
    }

    HorizontalLayout {
        x: parent.width - 204px;
        y: (parent.height - 34px) / 2;
        width: 194px;
        height: 34px;
        spacing: 6px;
        alignment: end;
        StreamAction { label: "Link"; clicked => { root.copy-link(); } }
        StreamAction { label: "Magnet"; clicked => { root.copy-magnet(); } }
        StreamAction { label: "Save"; clicked => { root.download(); } }
    }
}
