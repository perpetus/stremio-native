import { AppPreviewShell } from "preview_shell.slint";
import { LibraryPage, LibraryRow } from "../pages/library.slint";
import { MediaCardItem } from "../components/media_card.slint";
import { Theme } from "../theme.slint";

export component LibraryPreview inherits Window {
    in-out property <string> preview-state: "loaded";
    in-out property <bool> parity-size: false;
    width: root.parity-size ? 2048px : 1280px;
    height: root.parity-size ? 1096px : 720px;
    background: Theme.main-gradient;
    default-font-family: "Plus Jakarta Sans";

    private property <[MediaCardItem]> preview-cards: [
        { id: "dune", media-type: "movie", video-id: "", title: "Dune", poster-url: "", poster: @image-url("../assets/images/background_1.svg"), description: "", show-checkmark: true, show-progress: true, progress-value: 0.35 },
        { id: "alien", media-type: "movie", video-id: "", title: "Alien", poster-url: "", poster: @image-url("../assets/images/background_2.svg"), description: "", show-checkmark: false, show-progress: false, progress-value: 0 },
        { id: "arrival", media-type: "movie", video-id: "", title: "Arrival", poster-url: "", poster: @image-url("../assets/images/intro-background.png"), description: "", show-checkmark: true, show-progress: false, progress-value: 0 },
        { id: "blade-runner", media-type: "movie", video-id: "", title: "Blade Runner", poster-url: "", poster: @image-url("../assets/images/background_1.svg"), description: "", show-checkmark: false, show-progress: true, progress-value: 0.72 },
        { id: "moon", media-type: "movie", video-id: "", title: "Moon", poster-url: "", poster: @image-url("../assets/images/background_2.svg"), description: "", show-checkmark: false, show-progress: false, progress-value: 0 },
        { id: "solaris", media-type: "movie", video-id: "", title: "Solaris", poster-url: "", poster: @image-url("../assets/images/intro-background.png"), description: "", show-checkmark: false, show-progress: false, progress-value: 0 }
    ];
    private property <[LibraryRow]> preview-rows: [
        { cols: root.preview-cards },
        { cols: root.preview-cards }
    ];

    AppPreviewShell {
        width: parent.width;
        height: parent.height;
        active-tab: 2;

        LibraryPage {
            width: parent.width;
            height: parent.height;
            loading: root.preview-state == "loading";
            rows: root.preview-state == "loaded" ? root.preview-rows : [];
            column-count: 6;
            active-type: "All";
            active-sort: "Last Watched";
        }
    }
}
