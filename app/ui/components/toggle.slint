import { Theme } from "../theme.slint";
import { ButtonSurface } from "button.slint";

// Behavior and geometry match stremio-web/Toggle. Consumers may override the
// semantic colors without changing its interaction contract.
export component ToggleSwitch inherits ButtonSurface {
    in property <length> unit: Theme.root-font-size;
    in-out property <bool> checked: false;
    in property <brush> active-color: Theme.secondary-accent;
    in property <brush> inactive-color: Theme.overlay-color;
    in property <brush> thumb-color: Theme.primary-foreground;
    callback toggled;

    width: 3.2 * root.unit;
    height: 1.7 * root.unit;
    border-radius: root.height / 2;
    background: root.checked ? root.active-color : root.inactive-color;
    accessible-name: root.checked ? "On" : "Off";
    accessible-role: checkbox;
    accessible-checkable: true;
    accessible-checked: root.checked;

    clicked => {
        root.checked = !root.checked;
        root.toggled();
    }

    animate background { duration: Theme.motion-fast; easing: ease-in-out; }

    Rectangle {
        width: 1.2 * root.unit;
        height: 1.2 * root.unit;
        x: root.checked ? 1.75 * root.unit : 0.25 * root.unit;
        y: 0.25 * root.unit;
        border-radius: self.width / 2;
        background: root.thumb-color;

        animate x { duration: Theme.motion-fast; easing: ease-in-out; }
    }
}
