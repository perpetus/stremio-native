import { Theme, IconData } from "../theme.slint";
import { ButtonSurface } from "button.slint";

export component NavTabButton inherits Rectangle {
    in property <string> label;
    in property <image> icon-source;
    in property <image> active-icon-source;
    in property <image> logo-source;
    in property <bool> has-logo: false;
    in property <bool> selected: false;
    in property <length> unit: Theme.root-font-size;
    callback clicked;
    callback double-clicked;

    property <length> item-size: max(3.5 * root.unit, 4.8 * root.unit);
    // This component is explicitly positioned by Sidebar, so it needs concrete
    // geometry. A Rectangle with only layout constraints fills its parent when
    // it is used outside a layout, which turns the hover state into a sidebar-
    // sized overlay.
    width: root.item-size;
    height: root.item-size;
    border-radius: Theme.border-radius;
    background: button.has-hover ? Theme.overlay-color : transparent;

    animate background { duration: Theme.motion-fast; }

    button := ButtonSurface {
        width: parent.width;
        height: parent.height;
        border-radius: parent.border-radius;
        accessible-name: root.label;
        focus-on-tab-navigation: false;
        clicked => { root.clicked(); }
        double-clicked => { root.double-clicked(); }
    }

    // A full-width slot avoids accumulating offsets from the rail, button,
    // and SVG geometry. Every icon shares the exact rail centre line.
    Rectangle {
        x: 0px;
        y: 0.45 * root.unit;
        width: parent.width;
        height: 2.4 * root.unit;
        background: transparent;

        Image {
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            width: 2.2 * root.unit;
            height: 2.2 * root.unit;
            source: root.has-logo
                ? root.logo-source
                : (root.selected ? root.active-icon-source : root.icon-source);
            colorize: root.has-logo
                ? transparent
                : (root.selected ? Theme.primary-accent : Theme.primary-foreground);
            opacity: root.has-logo ? 1 : (root.selected ? 1 : 0.35);
            image-fit: contain;
        }
    }

    Text {
        z: 10;
        x: 0.5 * root.unit;
        y: 3.05 * root.unit;
        width: parent.width - root.unit;
        height: 1.5 * root.unit;
        text: root.label;
        color: root.selected ? Theme.primary-accent : Theme.primary-foreground;
        opacity: root.selected ? 1 : (button.has-hover ? 0.6 : 0);
        font-size: 0.8 * root.unit;
        font-weight: 500;
        letter-spacing: 0.01 * root.unit;
        horizontal-alignment: center;
        vertical-alignment: center;
        overflow: elide;
    }
}

// Compatibility shell for the native tab index model. Item rendering itself is
// reusable and mirrors official VerticalNavBar/NavTabButton.
export component Sidebar inherits Rectangle {
    in property <int> active-tab;
    in property <length> unit: Theme.root-font-size;
    in property <string> server-status: "Offline";
    in property <string> username: "";
    in property <string> avatar-letter: "U";

    in property <IconData> board-icon;
    in property <IconData> discover-icon;
    in property <IconData> library-icon;
    in property <IconData> calendar-icon;
    in property <IconData> addons-icon;
    in property <IconData> settings-icon;
    in property <IconData> logout-icon;

    callback change-tab(int);
    callback tab-double-clicked(int);
    callback logout;

    // Keep the navigation rail on the same canonical width used by the
    // horizontal navbar. The preview unit intentionally changes by viewport,
    // while this token remains the single source of truth for rail alignment.
    width: Theme.vertical-nav-bar-size;
    background: transparent;

    NavTabButton {
            x: (parent.width - self.width) / 2;
            y: 1 * root.unit;
            unit: root.unit;
            label: @tr("Board");
            icon-source: @image-url("../assets/images/icons/home-outline.svg");
            active-icon-source: @image-url("../assets/images/icons/home.svg");
            selected: root.active-tab == 0;
            clicked => { root.change-tab(0); }
            double-clicked => { root.tab-double-clicked(0); }
        }
    NavTabButton {
            x: (parent.width - self.width) / 2;
            y: 6.8 * root.unit;
            unit: root.unit;
            label: @tr("Discover" => "Discover");
            icon-source: @image-url("../assets/images/icons/discover-outline.svg");
            active-icon-source: @image-url("../assets/images/icons/discover.svg");
            selected: root.active-tab == 1;
            clicked => { root.change-tab(1); }
            double-clicked => { root.tab-double-clicked(1); }
        }
    NavTabButton {
            x: (parent.width - self.width) / 2;
            y: 12.6 * root.unit;
            unit: root.unit;
            label: @tr("Library" => "Library");
            icon-source: @image-url("../assets/images/icons/library-outline.svg");
            active-icon-source: @image-url("../assets/images/icons/library.svg");
            selected: root.active-tab == 2;
            clicked => { root.change-tab(2); }
            double-clicked => { root.tab-double-clicked(2); }
        }
    NavTabButton {
            x: (parent.width - self.width) / 2;
            y: 18.4 * root.unit;
            unit: root.unit;
            label: @tr("Calendar");
            icon-source: @image-url("../assets/images/icons/calendar-outline.svg");
            active-icon-source: @image-url("../assets/images/icons/calendar.svg");
            selected: root.active-tab == 5;
            clicked => { root.change-tab(5); }
            double-clicked => { root.tab-double-clicked(5); }
        }
    NavTabButton {
            x: (parent.width - self.width) / 2;
            y: 24.2 * root.unit;
            unit: root.unit;
            label: @tr("ADDONS" => "Addons");
            icon-source: @image-url("../assets/images/icons/addons-outline.svg");
            active-icon-source: @image-url("../assets/images/icons/addons.svg");
            selected: root.active-tab == 3;
            clicked => { root.change-tab(3); }
            double-clicked => { root.tab-double-clicked(3); }
        }
    NavTabButton {
            x: (parent.width - self.width) / 2;
            y: 30 * root.unit;
            unit: root.unit;
            label: @tr("SETTINGS" => "Settings");
            icon-source: @image-url("../assets/images/icons/settings-outline.svg");
            active-icon-source: @image-url("../assets/images/icons/settings.svg");
            selected: root.active-tab == 4;
            clicked => { root.change-tab(4); }
            double-clicked => { root.tab-double-clicked(4); }
    }
}
