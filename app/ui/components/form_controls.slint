import { ScrollView } from "std-widgets.slint";
import { Theme, IconData } from "../theme.slint";

export component SelectField inherits Rectangle {
    in property <length> unit: 16px;
    in property <string> value;
    in property <string> placeholder: "Select";
    in property <[string]> options: [];
    in property <bool> open: false;
    in property <length> field-width: 15 * root.unit;

    callback toggle;
    callback selected(string);

    width: root.field-width;
    height: 2.75 * root.unit;
    border-radius: 0.75 * root.unit;
    background: Theme.overlay;
    z: root.open ? 80 : 1;

    button-area := TouchArea {
        mouse-cursor: pointer;
        clicked => { root.toggle(); }
    }

    HorizontalLayout {
        padding-left: root.unit;
        padding-right: root.unit;
        spacing: 0.75 * root.unit;

        Text {
            horizontal-stretch: 1;
            text: root.value == "" ? root.placeholder : root.value;
            color: Theme.text-primary;
            opacity: root.value == "" ? 0.5 : 0.8;
            font-size: root.unit;
            font-weight: 500;
            vertical-alignment: center;
            overflow: elide;
        }

        Text {
            width: root.unit;
            text: root.open ? "▴" : "▾";
            color: Theme.text-primary;
            opacity: 0.5;
            font-size: 0.8 * root.unit;
            horizontal-alignment: center;
            vertical-alignment: center;
        }
    }

    if (root.open) : Rectangle {
        x: 0px;
        y: root.height + 0.5 * root.unit;
        width: root.width;
        height: (root.options.length > 6 ? 6 : root.options.length) * 3 * root.unit + root.unit;
        border-radius: 0.75 * root.unit;
        background: Theme.modal-background;
        border-width: Theme.focus-outline-size;
        border-color: Theme.overlay;
        clip: true;
        z: 100;

        ScrollView {
            VerticalLayout {
                padding: 0.5 * root.unit;
                spacing: 0px;

                for option in root.options : Rectangle {
                    height: 3 * root.unit;
                    border-radius: 0.5 * root.unit;
                    background: option-area.has-hover || option == root.value ? Theme.overlay : transparent;

                    Text {
                        x: root.unit;
                        width: parent.width - 2 * root.unit;
                        height: parent.height;
                        text: option;
                        color: Theme.text-primary;
                        opacity: option == root.value ? 1 : 0.7;
                        font-size: root.unit;
                        font-weight: option == root.value ? 600 : 400;
                        vertical-alignment: center;
                        overflow: elide;
                    }

                    option-area := TouchArea {
                        mouse-cursor: pointer;
                        clicked => { root.selected(option); }
                    }
                }
            }
        }
    }
}

export component PillButton inherits Rectangle {
    in property <length> unit: 16px;
    in property <string> label;
    in property <IconData> icon;
    in property <bool> show-icon: false;
    in property <bool> primary: false;
    in property <bool> outlined: false;
    in property <bool> enabled: true;
    in property <brush> accent-color: Theme.accent;
    callback clicked;

    height: 3.5 * root.unit;
    border-radius: root.height / 2;
    border-width: root.outlined || action.has-hover ? Theme.focus-outline-size : 0px;
    border-color: root.primary ? root.accent-color : Theme.text-primary;
    background: action.has-hover
        ? (root.primary ? transparent : Theme.overlay)
        : (root.primary ? root.accent-color : transparent);
    opacity: root.enabled ? (root.outlined && !action.has-hover ? 0.45 : 1) : 0.3;

    action := TouchArea {
        enabled: root.enabled;
        mouse-cursor: pointer;
        clicked => { root.clicked(); }
    }

    HorizontalLayout {
        alignment: center;
        spacing: 0.75 * root.unit;
        padding-left: 1.25 * root.unit;
        padding-right: 1.25 * root.unit;

        if (root.show-icon) : Text {
            width: 1.5 * root.unit;
            text: root.icon.glyph;
            font-family: root.icon.font-family;
            color: Theme.text-primary;
            font-size: 1.35 * root.unit;
            horizontal-alignment: center;
            vertical-alignment: center;
        }

        Text {
            text: root.label;
            color: Theme.text-primary;
            font-size: 1.05 * root.unit;
            font-weight: 700;
            horizontal-alignment: center;
            vertical-alignment: center;
            overflow: elide;
        }
    }
}

export component NativeTextField inherits Rectangle {
    in property <length> unit: 16px;
    in-out property <string> text;
    in property <string> placeholder-text;
    callback accepted;
    callback edited;

    height: 3.5 * root.unit;
    border-radius: 0.75 * root.unit;
    border-width: editor.has-focus ? Theme.focus-outline-size : 0px;
    border-color: Theme.text-primary;
    background: Theme.overlay;

    if (root.text == "") : Text {
        x: root.unit;
        width: parent.width - 2 * root.unit;
        height: parent.height;
        text: root.placeholder-text;
        color: Theme.text-primary;
        opacity: 0.4;
        font-size: root.unit;
        vertical-alignment: center;
        overflow: elide;
    }

    editor := TextInput {
        x: root.unit;
        width: parent.width - 2 * root.unit;
        height: parent.height;
        text <=> root.text;
        color: Theme.text-primary;
        font-size: root.unit;
        single-line: true;
        vertical-alignment: center;
        edited => { root.edited(); }
        accepted => { root.accepted(); }
    }
}

export component ToggleSwitch inherits Rectangle {
    in property <length> unit: 16px;
    in-out property <bool> checked: false;
    callback toggled;

    width: 3.25 * root.unit;
    height: 1.8 * root.unit;
    border-radius: root.height / 2;
    background: root.checked ? Theme.accent : Theme.overlay;

    Rectangle {
        width: 1.35 * root.unit;
        height: self.width;
        x: root.checked ? parent.width - self.width - 0.225 * root.unit : 0.225 * root.unit;
        y: (parent.height - self.height) / 2;
        border-radius: self.width / 2;
        background: Theme.text-primary;
    }

    TouchArea {
        mouse-cursor: pointer;
        clicked => {
            root.checked = !root.checked;
            root.toggled();
        }
    }
}
