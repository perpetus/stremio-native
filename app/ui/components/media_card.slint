import { Theme } from "../theme.slint";

export struct MediaCardItem {
    id: string,
    media-type: string,
    video-id: string,
    title: string,
    poster-url: string,
    poster: image,
    description: string,
    show-checkmark: bool,
    show-progress: bool,
    progress-value: float,
}

export component MediaCard inherits Rectangle {
    in property <MediaCardItem> item;
    in property <length> unit: 16px;
    in property <bool> enable-hover-scale: true;
    in property <bool> show-close-button: false;
    in property <bool> enable-lazy-loading: false;
    in property <bool> is-visible: true;

    callback clicked;
    callback remove-clicked;
    callback poster-requested(string);

    init => {
        if (root.item.poster.width == 0 && root.item.poster-url != "") {
            root.poster-requested(root.item.poster-url);
        }
    }
    changed item => {
        if (root.item.poster.width == 0 && root.item.poster-url != "") {
            root.poster-requested(root.item.poster-url);
        }
    }

    property <length> poster-width: root.width - 2 * root.unit;
    property <length> poster-height: root.poster-width * 1.464;

    background: transparent;
    height: root.poster-height + 6 * root.unit;

    card-area := TouchArea { clicked => { root.clicked(); } }

    poster-container := Rectangle {
        x: root.unit;
        y: root.unit;
        width: root.poster-width;
        height: root.poster-height;
        background: Theme.overlay;
        border-radius: 0.75 * root.unit;
        border-width: card-area.has-hover ? 0.2 * root.unit : 0px;
        border-color: Theme.text-primary;
        clip: true;

        animate border-width { duration: 100ms; }

        if (root.item.poster.width == 0 || (root.enable-lazy-loading && !root.is-visible)) : Rectangle {
            width: parent.width;
            height: parent.height;
            background: Theme.overlay;
            border-radius: parent.border-radius;

            Text {
                text: root.item.description == "series" ? "▣" : "▤";
                color: Theme.text-primary;
                opacity: 0.2;
                font-size: 5 * root.unit;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
        }

        if (root.item.poster.width > 0 && (!root.enable-lazy-loading || root.is-visible)) : Image {
            source: root.item.poster;
            width: card-area.has-hover && root.enable-hover-scale ? 1.05 * parent.width : parent.width;
            height: card-area.has-hover && root.enable-hover-scale ? 1.05 * parent.height : parent.height;
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            image-fit: cover;
            opacity: 0.9;
            animate width, height, x, y { duration: 100ms; easing: ease-out; }
        }

        if (root.item.show-checkmark) : Rectangle {
            x: 0.5 * root.unit;
            y: 0.5 * root.unit;
            width: 1.5 * root.unit;
            height: 1.5 * root.unit;
            background: Theme.accent;
            border-radius: self.width / 2;
            z: 2;
            Text {
                text: "✓";
                color: Theme.text-primary;
                font-size: 0.75 * root.unit;
                font-weight: 700;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
        }

        if (root.show-close-button) : Rectangle {
            x: 0.5 * root.unit;
            y: 0.5 * root.unit;
            width: 1.5 * root.unit;
            height: 1.5 * root.unit;
            border-radius: self.width / 2;
            background: #0c0b1199;
            opacity: card-area.has-hover ? 1 : 0;
            z: 3;
            Text {
                text: "×";
                color: Theme.text-primary;
                font-size: root.unit;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
            TouchArea { clicked => { root.remove-clicked(); } }
        }

        if (root.item.show-progress) : Rectangle {
            x: root.unit;
            y: parent.height - 1.45 * root.unit;
            width: parent.width - 2 * root.unit;
            height: 0.45 * root.unit;
            border-radius: self.height;
            background: #ffffff4d;
            z: 2;
            Rectangle {
                width: parent.width * root.item.progress-value;
                height: parent.height;
                border-radius: parent.border-radius;
                background: Theme.text-primary;
            }
        }
    }

    Text {
        x: root.unit;
        y: root.poster-height + root.unit;
        width: root.poster-width;
        height: 4 * root.unit;
        text: root.item.title;
        color: Theme.text-primary;
        font-size: root.unit;
        font-weight: 600;
        horizontal-alignment: center;
        vertical-alignment: center;
        wrap: word-wrap;
        overflow: elide;
    }
}
