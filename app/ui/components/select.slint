import { ScrollView } from "std-widgets.slint";
import { Theme } from "../theme.slint";
import { ButtonSurface } from "button.slint";

// Shared popup select. Its label and option geometry follow the official
// Multiselect, while the string model preserves the native page API.
export component SelectField inherits Rectangle {
    in property <length> unit: Theme.root-font-size;
    in-out property <string> value;
    in property <string> placeholder: "Select";
    in property <[string]> options: [];
    in-out property <bool> open: false;
    in property <bool> enabled: true;
    in property <length> field-width: 15 * root.unit;
    in property <brush> surface-color: Theme.overlay-color;
    callback toggle;
    callback opened;
    callback closed;
    callback selected(string);

    width: root.field-width;
    height: 2.75 * root.unit;
    border-radius: root.height / 2;
    background: root.surface-color;
    z: root.open ? 10000 : 0;

    label-button := ButtonSurface {
        width: parent.width;
        height: parent.height;
        border-radius: parent.border-radius;
        enabled: root.enabled;
        accessible-name: root.value == "" ? root.placeholder : root.value;
        clicked => {
            root.toggle();
            if (root.open) {
                root.opened();
            } else {
                root.closed();
            }
        }

        HorizontalLayout {
            padding-left: 1.5 * root.unit;
            padding-right: 1.5 * root.unit;
            spacing: root.unit;

            Text {
                horizontal-stretch: 1;
                text: root.value == "" ? root.placeholder : root.value;
                color: Theme.primary-foreground;
                opacity: root.value == "" ? 0.6 : 1;
                font-size: root.unit;
                font-weight: 500;
                vertical-alignment: center;
                overflow: elide;
            }

            // A wrapper that stretches on the cross axis keeps the caret
            // centered. Giving the image a fixed height directly in a
            // HorizontalLayout otherwise places it at the layout's top edge.
            Rectangle {
                width: 1.5 * root.unit;
                background: transparent;

                Image {
                    x: (parent.width - self.width) / 2;
                    y: (parent.height - self.height) / 2;
                    width: root.unit;
                    height: root.unit;
                    source: root.open
                        ? @image-url("../assets/images/icons/caret-up.svg")
                        : @image-url("../assets/images/icons/caret-down.svg");
                    colorize: Theme.primary-foreground;
                    opacity: 0.4;
                    image-fit: contain;
                }
            }
        }
    }

    if (root.open) : menu := Rectangle {
        x: 0px;
        y: root.height;
        width: root.width;
        height: root.options.length == 0
            ? 4 * root.unit
            : min(root.options.length, 7) * 3 * root.unit;
        border-radius: Theme.border-radius;
        background: Theme.modal-color;
        drop-shadow-blur: Theme.outer-glow-blur;
        drop-shadow-color: Theme.outer-glow-color;
        clip: true;
        z: 10001;

        if (root.options.length == 0) : Text {
            width: parent.width;
            height: parent.height;
            text: "No options";
            color: Theme.surface-light-90;
            font-size: 1.2 * root.unit;
            font-weight: 500;
            horizontal-alignment: center;
            vertical-alignment: center;
        }

        if (root.options.length > 0) : ScrollView {
            width: parent.width;
            height: parent.height;

            VerticalLayout {
                width: menu.width;
                spacing: 0px;

                for option in root.options : option-button := ButtonSurface {
                    horizontal-stretch: 1;
                    height: 3 * root.unit;
                    accessible-name: option;
                    background: self.has-hover || self.has-focus
                        ? Theme.overlay-color
                        : transparent;
                    clicked => { root.selected(option); }

                    HorizontalLayout {
                        padding: root.unit;
                        spacing: root.unit;

                        Text {
                            horizontal-stretch: 1;
                            text: option;
                            color: Theme.primary-foreground;
                            font-size: root.unit;
                            vertical-alignment: center;
                            overflow: elide;
                        }

                        if (option == root.value) : Rectangle {
                            width: 0.5 * root.unit;
                            height: 0.5 * root.unit;
                            border-radius: self.width / 2;
                            background: Theme.secondary-accent;
                        }
                    }
                }
            }
        }
    }
}

export component SeasonSelectField inherits Rectangle {
    in property <length> unit: Theme.root-font-size;
    in-out property <int> value;
    in property <[int]> options: [];
    in-out property <bool> open: false;
    in property <bool> enabled: true;
    in property <length> field-width: 15 * root.unit;
    in property <brush> surface-color: Theme.overlay-color;
    callback toggle;
    callback opened;
    callback closed;
    callback selected(int);

    width: root.field-width;
    height: 2.75 * root.unit;
