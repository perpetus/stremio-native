                        ? Theme.overlay-color
                        : transparent;
                    clicked => { root.selected(option); }

                    HorizontalLayout {
                        padding: root.unit;
                        spacing: root.unit;

                        Text {
                            horizontal-stretch: 1;
                            text: option > 0 ? "Season " + option : "Special";
                            color: Theme.primary-foreground;
                            font-size: root.unit;
                            vertical-alignment: center;
                            overflow: elide;
                        }

                        if (option == root.value) : Rectangle {
                            width: 0.5 * root.unit;
                            height: 0.5 * root.unit;
                            border-radius: self.width / 2;
                            background: Theme.secondary-accent;
                        }
                    }
                }
            }
        }
    }
}
