import { AuthPage } from "pages/auth.slint";
import { BoardPage, BoardSection } from "pages/board.slint";
import { DiscoverPage, DiscoverRow } from "pages/discover.slint";
import { LibraryPage, LibraryRow } from "pages/library.slint";
import { AddonsPage, AddonItem } from "pages/addons.slint";
import { DetailsPage, StreamLink, EpisodeItem } from "pages/details.slint";
import { SettingsPage } from "pages/settings.slint";
import { PlayerPage } from "pages/player.slint";
import { CalendarPage, CalendarRow, CalendarCell, CalendarMediaItem } from "pages/calendar.slint";
import { SearchPage } from "pages/search.slint";
import { AppDebugMenu, DebugPageOption, DebugStateOption } from "components/app_debug_menu.slint";

import { Fonts } from "imported_fonts.slint";
import "./assets/fonts/PlusJakartaSans.ttf";

export { Theme, IconData, MediaCardItem, StreamLink, EpisodeItem, BoardSection, DiscoverRow, LibraryRow, AddonItem, CalendarRow, CalendarCell, CalendarMediaItem, SearchSuggestion }

export component MainWindow inherits Window {
    title: "Stremio";
    preferred-width: 1280px;
    preferred-height: 720px;
    min-width: 1000px;
    min-height: 600px;
    background: Theme.background;
    default-font-family: "Plus Jakarta Sans";
    forward-focus: app-shortcuts;
    property <length> ui-unit: root.width >= 2800px ? 18px :
        (root.width >= 2200px ? 16px : (root.width >= 1600px ? 15px : 14px));
    in-out property <bool> profile-menu-open: false;

    // Disabled by default. `slint-viewer --load-data` can enable this harness
    // without replacing MainWindow, so every state uses the production shell,
    // routing bounds, overlays, and page components.
    in-out property <bool> debug-preview-enabled: false;
    in-out property <bool> debug-menu-open: false;
    in-out property <int> debug-preview-page: 0;
    in-out property <string> debug-preview-state: "loaded";

    private property <[DebugPageOption]> debug-pages: [
        { label: "Auth", page: -1 },
        { label: "Board", page: 0 },
        { label: "Discover", page: 1 },
        { label: "Library", page: 2 },
        { label: "Addons", page: 3 },
        { label: "Settings", page: 4 },
        { label: "Calendar", page: 5 },
        { label: "Search", page: 6 },
        { label: "Details", page: 7 },
        { label: "Player", page: 8 }
    ];
    private property <[DebugStateOption]> debug-auth-states: [
        { label: "Login", value: "login" },
        { label: "Register", value: "register" },
        { label: "Loading", value: "auth-loading" },
        { label: "Invalid credentials", value: "auth-error" }
    ];
    private property <[DebugStateOption]> debug-board-states: [
        { label: "Loaded", value: "loaded" },
        { label: "Loading", value: "loading" },
        { label: "Empty", value: "empty" },
        { label: "Continue watching only", value: "continue-only" },
        { label: "Catalogs only", value: "catalogs-only" },
        { label: "Profile menu", value: "profile-menu" }
    ];
    private property <[DebugStateOption]> debug-discover-states: [
        { label: "Catalog", value: "catalog" },
        { label: "Loading", value: "loading" },
        { label: "Empty", value: "empty" },
        { label: "Movie selected", value: "movie-selected" },
        { label: "Series selected", value: "series-selected" },
        { label: "Type dropdown", value: "type-dropdown" },
        { label: "Catalog dropdown", value: "catalog-dropdown" },
        { label: "Genre dropdown", value: "genre-dropdown" }
    ];
    private property <[DebugStateOption]> debug-library-states: [
        { label: "Loaded", value: "loaded" },
        { label: "Loading", value: "loading" },
        { label: "Empty", value: "empty" },
        { label: "Type dropdown", value: "type-dropdown" },
        { label: "Sort dropdown", value: "sort-dropdown" }
    ];
    private property <[DebugStateOption]> debug-addons-states: [
        { label: "Loaded", value: "loaded" },
        { label: "Loading", value: "loading" },
        { label: "Empty", value: "empty" },
        { label: "Addon details", value: "addon-details" },
        { label: "Details loading", value: "addon-details-loading" },
        { label: "Details error", value: "addon-details-error" },
        { label: "Filter dropdown", value: "filter-dropdown" },
        { label: "Type dropdown", value: "type-dropdown" },
        { label: "Add addon dialog", value: "add-addon" }
    ];
    private property <[DebugStateOption]> debug-settings-states: [
        { label: "General", value: "general" },
        { label: "Interface", value: "interface" },
        { label: "Player", value: "player-settings" },
        { label: "Streaming", value: "streaming" },
        { label: "Shortcuts", value: "shortcuts" },
        { label: "Diagnostics", value: "diagnostics" },
        { label: "Exporting", value: "exporting" }
    ];
    private property <[DebugStateOption]> debug-calendar-states: [
        { label: "Month loaded", value: "loaded" },
        { label: "Loading", value: "loading" },
        { label: "Signed out", value: "signed-out" },
        { label: "Empty month", value: "empty" }
    ];
    private property <[DebugStateOption]> debug-search-states: [
        { label: "Results", value: "results" },
        { label: "Loading", value: "loading" },
        { label: "No results", value: "empty" },
        { label: "No query", value: "idle" }
    ];
    private property <[DebugStateOption]> debug-details-states: [
        { label: "Loading title", value: "details-loading" },
        { label: "Movie streams", value: "movie-streams" },
        { label: "Movie no streams", value: "movie-no-streams" },
        { label: "Movie filter open", value: "movie-filter" },
        { label: "Series episodes", value: "series-episodes" },
        { label: "Season dropdown", value: "series-season-menu" },
        { label: "Selected episode streams", value: "series-streams" },
        { label: "Streams still loading", value: "series-stream-loading" },
        { label: "Episode no streams", value: "series-no-streams" }
    ];
    private property <[DebugStateOption]> debug-player-states: [
        { label: "Loading", value: "player-loading" },
        { label: "Buffering", value: "buffering" },
        { label: "Paused controls", value: "paused" },
        { label: "Playing controls", value: "playing" },
        { label: "Skip intro", value: "skip-intro" },
        { label: "Subtitle menu", value: "subtitles" },
        { label: "Audio menu", value: "audio" },
        { label: "Speed menu", value: "speed" },
        { label: "Playback info", value: "stats" },
        { label: "More options", value: "options" },
        { label: "Context menu", value: "context-menu" },
        { label: "Episode drawer", value: "episodes" },
        { label: "Playback error", value: "player-error" },
        { label: "Controls hidden", value: "controls-hidden" }
    ];
    private property <[DebugStateOption]> debug-state-options:
        root.debug-preview-page == -1 ? root.debug-auth-states :
        (root.debug-preview-page == 0 ? root.debug-board-states :
        (root.debug-preview-page == 1 ? root.debug-discover-states :
        (root.debug-preview-page == 2 ? root.debug-library-states :
        (root.debug-preview-page == 3 ? root.debug-addons-states :
        (root.debug-preview-page == 4 ? root.debug-settings-states :
        (root.debug-preview-page == 5 ? root.debug-calendar-states :
        (root.debug-preview-page == 6 ? root.debug-search-states :
        (root.debug-preview-page == 7 ? root.debug-details-states : root.debug-player-states))))))));

    private property <int> effective-active-tab: root.debug-preview-enabled
        ? (root.debug-preview-page >= 0 && root.debug-preview-page <= 6 ? root.debug-preview-page : 0)
        : root.active-tab;
    private property <bool> effective-show-details: root.debug-preview-enabled
        ? root.debug-preview-page == 7
        : root.show-details;
    private property <bool> effective-show-player: root.debug-preview-enabled
        ? root.debug-preview-page == 8
        : root.show-player;
    private property <bool> show-auth-page: root.debug-preview-enabled
        ? root.debug-preview-page == -1
        : root.username == "";
    private property <bool> show-main-shell: root.debug-preview-enabled
        ? root.debug-preview-page >= 0 && root.debug-preview-page <= 6
        : root.username != "";

    // Bindings / API exposed to Rust code
    in property <int> active-tab: 0; // 0: Board, 1: Discover, 2: Library, 3: Addons, 4: Settings, 5: Calendar, 6: Search
    in-out property <string> username: "";
    in-out property <string> avatar-letter: "U";
    in-out property <image> avatar-image;
    in-out property <bool> has-avatar-image: false;
    in property <image> default-avatar-icon: @image-url("assets/images/default_avatar.png");
    in property <image> anonymous-icon: @image-url("assets/images/anonymous.png");
    in-out property <bool> loading: false;
    in-out property <string> error-message: "";

    // Stats (Footer stats)
    in-out property <string> server-status: "Offline";
    in-out property <string> server-url: "";

    // Data lists
    in-out property <[MediaCardItem]> board-continue-watching: [];
    in-out property <[BoardSection]> board-sections: [];
    in-out property <[BoardSection]> search-sections: [];
    in-out property <[SearchSuggestion]> search-suggestions: [];
    in-out property <string> search-query: "";
    in-out property <bool> search-loading: false;
    in-out property <int> search-catalog-count: 0;
    
    in-out property <[DiscoverRow]> discover-rows: [];
    in-out property <int> discover-column-count: 6;
    in-out property <[LibraryRow]> library-rows: [];
    in-out property <int> library-column-count: 6;
    in-out property <string> library-active-type: "All";
    in-out property <string> library-active-sort: "Last Watched";
    in-out property <[AddonItem]> addons-list: [];
    in-out property <string> addons-search-query: "";
    in property <bool> addon-details-open: false;
    in-out property <AddonItem> addon-details-addon;
    in-out property <bool> addon-details-loading: false;
    in-out property <string> addon-details-error: "";
    in-out property <bool> addon-details-configurable: false;
    in-out property <bool> addon-details-configuration-required: false;
    in-out property <[StreamLink]> stream-links: [];
    in-out property <[string]> detail-stream-providers: ["All"];
    in-out property <int> detail-stream-loading-count: 0;
    in-out property <int> calendar-selected-year: 0;
    in-out property <string> calendar-selected-month: "";
    in-out property <string> calendar-previous-month: "";
    in-out property <string> calendar-next-month: "";
    in-out property <[CalendarRow]> calendar-rows: [];
    in-out property <bool> calendar-loading: false;

    // Filters lists & values for Discover
    in property <[string]> discover-types: [];
    in-out property <string> discover-active-type: "";
    in property <[string]> discover-catalogs: [];
    in-out property <string> discover-active-catalog: "";
    in property <[string]> discover-genres: [];
    in-out property <string> discover-active-genre: "";
    in-out property <length> discover-scroll-y: 0px;

    // Discover preview drawer parameters
    in-out property <bool> discover-has-preview: false;
    in-out property <string> discover-preview-title: "";
    in-out property <string> discover-preview-description: "";
    in-out property <string> discover-preview-rating: "";
    in-out property <string> discover-preview-year: "";
    in-out property <string> discover-preview-runtime: "";
    in-out property <[string]> discover-preview-genres: [];
    in-out property <[string]> discover-preview-cast: [];
    in-out property <[string]> discover-preview-directors: [];
    in-out property <bool> discover-preview-is-in-library: false;
    in-out property <bool> discover-preview-is-watched: false;
    in-out property <bool> discover-preview-has-trailer: false;
    in-out property <image> discover-preview-poster;
    in-out property <string> discover-preview-poster-url: "";

    // Detailed view parameters
    in-out property <string> detail-title: "";
    in-out property <string> detail-description: "";
    in-out property <image> detail-poster;
    in-out property <string> detail-poster-url: "";
    in-out property <string> detail-year: "";
    in-out property <string> detail-runtime: "";
    in-out property <string> detail-rating: "";
    in-out property <[string]> detail-genres: [];
    in-out property <[string]> detail-cast: [];
    in-out property <[string]> detail-directors: [];
    in-out property <bool> detail-is-watched: false;
    in-out property <bool> detail-has-trailer: false;
    in-out property <string> detail-trailer-selection-id: "";
    in property <bool> show-details: false;
    in-out property <bool> details-loading: false;
    
    // Details Series View bindings
    in-out property <bool> detail-is-series: false;
    in-out property <[int]> detail-seasons: [];
    in-out property <int> detail-active-season: 1;
    in-out property <[string]> detail-episode-names: [];
    in-out property <int> detail-active-episode-idx: 0;
    in-out property <bool> detail-is-in-library: false;
    in-out property <image> detail-background;
    in-out property <string> detail-background-url: "";
    in-out property <[EpisodeItem]> detail-episodes: [];
    in-out property <bool> detail-in-stream-view: false;
    in-out property <string> detail-episode-search-query: "";

    callback details-episode-search-changed(string);
    callback details-toggle-episode-watched(string);
    callback details-copy-stream-link(string);
    callback details-copy-magnet-link(string);
    callback details-copy-download-link(string);
    callback details-toggle-season-watched(int);

    // Player Page parameters
    in property <bool> show-player: false;
    in-out property <string> player-title: "";
    in-out property <string> player-stream-name: "";
    in-out property <image> player-poster-image;
    in-out property <image> player-video-frame;
    in-out property <bool> player-has-video-frame: false;
    in-out property <bool> player-loading: false;
    in-out property <bool> player-buffering: false;
    in-out property <float> player-buffering-percent: 0.0;
    in-out property <bool> player-paused: true;
    in-out property <float> player-volume: 1.0;
    in-out property <bool> player-muted: false;
    in-out property <float> player-progress: 0.0;
    in-out property <string> player-elapsed-time-str: "00:00";
    in-out property <string> player-total-time-str: "00:00";
    in-out property <[string]> player-subtitles-tracks: [];
    in-out property <[string]> player-subtitle-track-languages: [];
    in-out property <[string]> player-subtitle-track-origins: [];
    in-out property <[string]> player-subtitle-languages: [];
    in-out property <[int]> player-subtitle-language-track-indices: [];
    in-out property <[string]> player-audio-tracks: [];
    in-out property <[string]> player-audio-track-languages: [];
    in-out property <[string]> player-audio-track-labels: [];
    in-out property <int> player-active-subtitle-idx: -1;
    in-out property <int> player-active-audio-idx: 0;
    in-out property <float> player-subtitle-delay-seconds: 0.0;
    in-out property <float> player-subtitle-size-percent: 100.0;
    in-out property <float> player-subtitle-offset-percent: 100.0;
    in-out property <bool> player-is-series: false;
    in-out property <[string]> player-episode-names: [];
    in-out property <int> player-active-episode-idx: 0;
    in-out property <float> player-playback-speed: 1.0;
    in-out property <int> player-video-scale-mode: 0;
    in-out property <string> player-error: "";
    in-out property <string> player-video-format: "";
    in-out property <string> player-audio-format: "";
    in-out property <string> player-file-format: "";
    in-out property <string> player-hwdec: "";
    in-out property <float> player-buffered-percent: 0.0;
    in-out property <string> player-download-speed: "";
    in-out property <string> player-upload-speed: "";
    in-out property <int> player-peer-count: 0;
    in-out property <float> player-stream-progress: 0.0;
    in-out property <float> player-seek-step-seconds: 10.0;
    in-out property <float> player-short-seek-step-seconds: 3.0;
    in-out property <bool> player-show-skip-button: false;
    in-out property <string> player-skip-button-label: "Skip Intro";
    in-out property <bool> player-controls-visible: true;
    in-out property <bool> player-show-subtitles-menu: false;
    in-out property <bool> player-show-audio-menu: false;
    in-out property <bool> player-show-speed-menu: false;
    in-out property <bool> player-show-stats-menu: false;
    in-out property <bool> player-show-options-menu: false;
    in-out property <bool> player-show-playlist-drawer: false;
    in-out property <bool> player-show-context-menu: false;
    private property <int> player-last-subtitle-idx: 0;
    private property <bool> player-menu-open: player-show-subtitles-menu
        || player-show-audio-menu
        || player-show-speed-menu
        || player-show-stats-menu
        || player-show-options-menu
        || player-show-playlist-drawer
        || player-show-context-menu;
    private property <int> settings-active-category: 0;

    // Player Icons
    in property <IconData> icon-play;
    in property <IconData> icon-pause;
    in property <IconData> icon-next;
    in property <IconData> icon-volume-high;
    in property <IconData> icon-volume-low;
    in property <IconData> icon-volume-mute;
    in property <IconData> icon-fullscreen;
    in property <IconData> icon-subtitles;
    in property <IconData> icon-audio;
    in property <IconData> icon-speed;
    in property <IconData> icon-stats;
    in property <IconData> icon-options;
    in property <IconData> icon-menu;
    in property <IconData> icon-back;

    // Settings Page values
    in-out property <string> torrent-cache-size: "2.0 GB";
    in-out property <string> settings-interface-language: "English";
    in-out property <string> settings-subtitles-language: "English";
    in-out property <string> settings-torrent-profile: "Default";
    in-out property <bool> settings-hardware-acceleration: true;
    in-out property <bool> settings-binge-watching: true;
    in-out property <bool> settings-discord-rpc-enabled: false;
    in-out property <string> settings-tidb-api-key: "";
    in-out property <bool> settings-tidb-show-intro: true;
    in-out property <bool> settings-tidb-show-recap: true;
    in-out property <bool> settings-tidb-show-credits: true;
    in-out property <bool> settings-tidb-show-preview: true;
    in-out property <bool> settings-hide-spoilers: false;
    in-out property <bool> settings-gamepad-support: false;
    in-out property <bool> settings-play-in-background: true;
    in-out property <bool> settings-subtitles-auto-select: true;
    in-out property <string> settings-subtitles-font: "Roboto";
    in-out property <string> settings-subtitles-size: "100";
    in-out property <bool> settings-subtitles-bold: false;
    in-out property <string> settings-subtitles-offset: "5";
    in-out property <string> settings-seek-duration: "10";
    in-out property <bool> settings-pause-on-minimize: false;
    in-out property <bool> settings-quit-on-close: true;
    in-out property <bool> settings-export-loading: false;
    in-out property <string> settings-export-status: "";
    in-out property <bool> settings-streaming-seeding: false;
    in-out property <bool> settings-streaming-dht: true;
    in-out property <bool> settings-streaming-pex: true;
    in-out property <bool> settings-streaming-lsd: true;
    in-out property <string> settings-streaming-remote-url: "";
    in-out property <string> settings-streaming-logs-text: "No logs loaded. Click Refresh.";
    in property <IconData> refresh-icon;
    in property <IconData> folder-icon;

    callback settings-change-seeding-enabled(bool);
    callback settings-change-dht-enabled(bool);
    callback settings-change-pex-enabled(bool);
    callback settings-change-lsd-enabled(bool);
    callback settings-refresh-logs();
    callback settings-open-logs-folder();
    callback settings-export-data();
    callback settings-change-binge-watching(bool);
    callback settings-change-discord-rpc-enabled(bool);
    callback settings-change-tidb-api-key(string);
    callback settings-change-tidb-show-intro(bool);
    callback settings-change-tidb-show-recap(bool);
    callback settings-change-tidb-show-credits(bool);
    callback settings-change-tidb-show-preview(bool);
    callback settings-change-hide-spoilers(bool);
    callback settings-change-gamepad-support(bool);
    callback settings-change-play-in-background(bool);
    callback settings-change-subtitles-auto-select(bool);
    callback settings-change-subtitles-font(string);
    callback settings-change-subtitles-size(string);
    callback settings-change-subtitles-bold(bool);
    callback settings-change-subtitles-offset(string);
    callback settings-change-seek-duration(string);
    callback settings-change-pause-on-minimize(bool);
    callback settings-change-quit-on-close(bool);
    in-out property <length> library-scroll-y: 0px;

    // Icons from Rust Iconflow
    in property <IconData> board-icon;
    in property <IconData> discover-icon;
    in property <IconData> library-icon;
    in property <IconData> calendar-icon;
    in property <IconData> addons-icon;
    in property <IconData> settings-icon;
    in property <IconData> logout-icon;
    in property <IconData> mail-icon;
    in property <IconData> lock-icon;
    in property <IconData> search-icon;
    in property <IconData> facebook-icon;
    in property <IconData> apple-icon;
    in property <IconData> icon-link;
    in property <IconData> icon-magnet;
    in property <IconData> icon-download;
    in property <IconData> icon-eye;
    in property <IconData> icon-eye-off;
    in property <IconData> icon-clapperboard;
    in-out property <bool> is-fullscreen: false;

    // Callbacks
    callback toggle-fullscreen();
    callback open-external-url(string);
    callback submit-login(string, string);
    callback submit-register(string, string, bool, bool, bool);
    callback facebook-login();
    callback apple-login();
    callback cancel-auth();
    callback request-password-reset(string);
    callback guest-login();
    callback logout();
    
    // Board page callback
    callback board-item-selected(string, string, string);
    callback remove-continue-watching(string);
    callback board-see-all-continue-watching();
    callback board-see-all-clicked(string, string, string);

    // Global search callbacks
    callback global-search-edited(string);
    callback global-search-submitted(string);
    callback global-search-suggestion-selected(string, string);
    callback search-item-selected(string, string, string);
    callback request-poster(string);

    // Discover page callbacks
    callback discover-type-changed(string);
    callback discover-catalog-changed(string);
    callback discover-genre-changed(string);
    callback discover-search-changed(string);
    callback discover-item-selected(string);
    callback play-preview();
    callback toggle-library-preview();
    
    // Library page callbacks
    callback library-type-changed(string);
    callback library-sort-changed(string);
    callback library-search-changed(string);
    callback library-item-selected(string, string);

    // Addons page callbacks
    callback install-addon(string);
    callback uninstall-addon(string);
    callback open-addon-details(string);
    callback close-addon-details();
    callback configure-addon(string);
    callback share-addon(string);
    callback addons-search-changed(string);

    // Details callbacks
    callback details-toggle-library();
    callback details-toggle-watched();
    callback details-season-changed(int);
    callback details-episode-changed(int);
    callback play-stream(string);
    
    // Settings callbacks
    callback apply-cache-settings(float);
    callback settings-change-interface-language(string);
    callback settings-change-subtitles-language(string);
    callback settings-change-torrent-profile(string);
    callback settings-change-hardware-acceleration(bool);
    callback settings-clear-search-history();
    callback shutdown-server();
    callback tab-changed(int);
    callback navigation-back();
    callback navigation-forward();
    callback calendar-previous();
    callback calendar-next();
    callback calendar-item-selected(string, string);

    // Player Callbacks
    callback player-toggle-pause();
    callback player-seek(float);
    callback player-seek-relative(float);
    callback player-change-volume(float);
    callback player-toggle-mute();
    callback player-change-subtitle(int);
    callback player-change-audio(int);
    callback player-skip-segment();
    callback player-change-subtitle-delay(float);
    callback player-change-subtitle-size(float);
    callback player-change-subtitle-offset(float);
    callback player-change-speed(float);
    callback player-change-video-scale(int);
    callback player-copy-stream-link();
    callback player-download-video();
    callback player-play-episode(int);
    callback player-toggle-fullscreen();
    callback player-close();
    callback player-activity();

    function close-player-menus() {
        root.player-show-subtitles-menu = false;
        root.player-show-audio-menu = false;
        root.player-show-speed-menu = false;
        root.player-show-stats-menu = false;
        root.player-show-options-menu = false;
        root.player-show-playlist-drawer = false;
        root.player-show-context-menu = false;
    }

    function toggle-player-menu(menu: string) {
        let was-open = (menu == "subtitles" && root.player-show-subtitles-menu)
            || (menu == "audio" && root.player-show-audio-menu)
            || (menu == "speed" && root.player-show-speed-menu)
            || (menu == "stats" && root.player-show-stats-menu)
            || (menu == "info" && root.player-show-playlist-drawer);
        root.close-player-menus();
        if (!was-open) {
            root.player-show-subtitles-menu = menu == "subtitles";
            root.player-show-audio-menu = menu == "audio";
            root.player-show-speed-menu = menu == "speed";
            root.player-show-stats-menu = menu == "stats";
            root.player-show-playlist-drawer = menu == "info";
        }
        root.player-controls-visible = true;
        root.player-activity();
    }

    function adjust-player-subtitle-size(direction: int) {
        let current = root.player-subtitle-size-percent;
        let next = direction > 0
            ? (current < 75 ? 75 : (current < 100 ? 100 : (current < 125 ? 125
                : (current < 150 ? 150 : (current < 175 ? 175 : (current < 200 ? 200 : 250))))))
            : (current > 200 ? 200 : (current > 175 ? 175 : (current > 150 ? 150
                : (current > 125 ? 125 : (current > 100 ? 100 : 75)))));
        root.player-subtitle-size-percent = next;
        root.player-change-subtitle-size(next);
        root.player-activity();
    }

    changed effective-show-player => {
        if (root.effective-show-player) {
            app-shortcuts.focus();
        }
    }

    app-shortcuts := FocusScope {
        property <bool> space-held: false;
        property <bool> space-long-press: false;
        property <float> space-restore-speed: 1.0;

        key-pressed(event) => {
            if (root.effective-show-player && !root.player-menu-open
                && event.text == Key.Space && !event.repeat) {
                self.space-held = true;
                self.space-long-press = false;
                self.space-restore-speed = root.player-playback-speed;
                space-hold-timer.start();
                root.player-controls-visible = true;
                root.player-activity();
                return accept;
            }
            reject
        }

        key-released(event) => {
            if (event.text == Key.Space && self.space-held) {
                space-hold-timer.stop();
                self.space-held = false;
                if (self.space-long-press) {
                    root.player-playback-speed = self.space-restore-speed;
                    root.player-change-speed(self.space-restore-speed);
                } else {
                    root.player-toggle-pause();
                }
                return accept;
            }
            reject
        }

        space-hold-timer := Timer {
            interval: 400ms;
            triggered => {
                self.stop();
                if (app-shortcuts.space-held && root.effective-show-player
                    && !root.player-menu-open) {
                    app-shortcuts.space-long-press = true;
                    root.player-playback-speed = 2.0;
                    root.player-change-speed(2.0);
                }
            }
        }

        KeyBinding { keys: @keys("1"); enabled: !root.effective-show-player; activated => { root.tab-changed(0); } }
        KeyBinding { keys: @keys("2"); enabled: !root.effective-show-player; activated => { root.tab-changed(1); } }
        KeyBinding { keys: @keys("3"); enabled: !root.effective-show-player; activated => { root.tab-changed(2); } }
        KeyBinding { keys: @keys("4"); enabled: !root.effective-show-player; activated => { root.tab-changed(5); } }
        KeyBinding { keys: @keys("5"); enabled: !root.effective-show-player; activated => { root.tab-changed(3); } }
        KeyBinding { keys: @keys("6"); enabled: !root.effective-show-player; activated => { root.tab-changed(4); } }
        KeyBinding { keys: @keys("0"); enabled: !root.effective-show-player; activated => { root.tab-changed(6); } }
        KeyBinding { keys: @keys(Backspace); enabled: !root.effective-show-player; activated => { root.navigation-back(); } }
        KeyBinding { keys: @keys(Control + Backspace); enabled: !root.effective-show-player; activated => { root.navigation-forward(); } }
        KeyBinding {
            keys: @keys(Control + "/");
            enabled: !root.effective-show-player;
            activated => {
                root.settings-active-category = 4;
                root.tab-changed(4);
            }
        }
        KeyBinding { keys: @keys(F); activated => { root.toggle-fullscreen(); } }

        KeyBinding {
            keys: @keys(K);
            enabled: root.effective-show-player && !root.player-menu-open;
            activated => { root.player-toggle-pause(); root.player-activity(); }
        }
        KeyBinding {
            keys: @keys(LeftArrow);
            enabled: root.effective-show-player && !root.player-menu-open;
            activated => { root.player-seek-relative(-root.player-seek-step-seconds); root.player-activity(); }
        }
        KeyBinding {
            keys: @keys(Shift + LeftArrow);
            enabled: root.effective-show-player && !root.player-menu-open;
            activated => { root.player-seek-relative(-root.player-short-seek-step-seconds); root.player-activity(); }
        }
        KeyBinding {
            keys: @keys(RightArrow);
            enabled: root.effective-show-player && !root.player-menu-open;
            activated => { root.player-seek-relative(root.player-seek-step-seconds); root.player-activity(); }
        }
        KeyBinding {
            keys: @keys(Shift + RightArrow);
            enabled: root.effective-show-player && !root.player-menu-open;
            activated => { root.player-seek-relative(root.player-short-seek-step-seconds); root.player-activity(); }
        }
        KeyBinding {
            keys: @keys(UpArrow);
            enabled: root.effective-show-player && !root.player-menu-open;
            activated => {
                root.player-volume = min(1.0, root.player-volume + 0.05);
                root.player-change-volume(root.player-volume);
                root.player-activity();
            }
        }
        KeyBinding {
            keys: @keys(DownArrow);
            enabled: root.effective-show-player && !root.player-menu-open;
            activated => {
                root.player-volume = max(0.0, root.player-volume - 0.05);
                root.player-change-volume(root.player-volume);
                root.player-activity();
            }
        }
        KeyBinding { keys: @keys(M); enabled: root.effective-show-player && !root.player-menu-open; activated => { root.player-toggle-mute(); root.player-activity(); } }
        KeyBinding { keys: @keys("-"); enabled: root.effective-show-player && !root.player-menu-open; activated => { root.adjust-player-subtitle-size(-1); } }
        KeyBinding { keys: @keys("="); enabled: root.effective-show-player && !root.player-menu-open; activated => { root.adjust-player-subtitle-size(1); } }
        KeyBinding {
            keys: @keys(G);
            enabled: root.effective-show-player && !root.player-menu-open;
            activated => {
                root.player-subtitle-delay-seconds -= 0.25;
                root.player-change-subtitle-delay(root.player-subtitle-delay-seconds);
                root.player-activity();
            }
        }
        KeyBinding {
            keys: @keys(H);
            enabled: root.effective-show-player && !root.player-menu-open;
            activated => {
                root.player-subtitle-delay-seconds += 0.25;
                root.player-change-subtitle-delay(root.player-subtitle-delay-seconds);
                root.player-activity();
            }
        }
        KeyBinding {
            keys: @keys("[");
            enabled: root.effective-show-player && !root.player-menu-open;
            activated => {
                root.player-playback-speed = max(0.25, root.player-playback-speed - 0.25);
                root.player-change-speed(root.player-playback-speed);
                root.player-activity();
            }
        }
        KeyBinding {
            keys: @keys("]");
            enabled: root.effective-show-player && !root.player-menu-open;
            activated => {
                root.player-playback-speed = min(2.0, root.player-playback-speed + 0.25);
                root.player-change-speed(root.player-playback-speed);
                root.player-activity();
            }
        }
        KeyBinding {
            keys: @keys(C);
            enabled: root.effective-show-player && !root.player-menu-open;
            activated => {
                if (root.player-active-subtitle-idx >= 0) {
                    root.player-last-subtitle-idx = root.player-active-subtitle-idx;
                    root.player-change-subtitle(-1);
                } else if (root.player-subtitles-tracks.length > 0) {
                    root.player-change-subtitle(root.player-last-subtitle-idx);
                }
                root.player-activity();
            }
        }
        KeyBinding { keys: @keys(S); enabled: root.effective-show-player; activated => { if (root.player-subtitles-tracks.length > 0) { root.toggle-player-menu("subtitles"); } } }
        KeyBinding { keys: @keys(A); enabled: root.effective-show-player; activated => { if (root.player-audio-tracks.length > 0) { root.toggle-player-menu("audio"); } } }
        KeyBinding { keys: @keys(I); enabled: root.effective-show-player && root.player-is-series; activated => { root.toggle-player-menu("info"); } }
        KeyBinding { keys: @keys(R); enabled: root.effective-show-player; activated => { root.toggle-player-menu("speed"); } }
        KeyBinding { keys: @keys(D); enabled: root.effective-show-player; activated => { root.toggle-player-menu("stats"); } }
        KeyBinding {
            keys: @keys(Shift + N);
            enabled: root.effective-show-player && root.player-is-series;
            activated => { root.close-player-menus(); root.player-play-episode(root.player-active-episode-idx + 1); }
        }
        KeyBinding {
            keys: @keys(Escape);
            enabled: root.effective-show-player;
            activated => {
                if (root.player-menu-open) {
                    root.close-player-menus();
                    root.player-activity();
                } else {
                    root.player-close();
                }
            }
        }
    }

    // Visual layout routing
    Rectangle {
        x: 0px;
        y: 0px;
        width: 100%;
        height: 100%;

        app-shell := Rectangle {
            x: 0px;
            y: 0px;
            width: 100%;
            height: 100%;
            visible: !root.effective-show-player;
            background: root.show-auth-page ? Theme.background : Theme.main-gradient;

            Rectangle {
                width: 100%;
                height: 100%;

        if (root.show-auth-page) : AuthPage {
            width: 100%;
            height: 100%;
            unit: root.ui-unit;
            error-message: root.debug-preview-enabled && root.debug-preview-page == -1
                ? (root.debug-preview-state == "auth-error" ? "The email or password is incorrect." : "")
                : error-message;
            loading: root.debug-preview-enabled && root.debug-preview-page == -1
                ? root.debug-preview-state == "auth-loading"
                : loading;
            register-mode: root.debug-preview-enabled && root.debug-preview-page == -1
                && root.debug-preview-state == "register";
            mail-icon: mail-icon;
            lock-icon: lock-icon;
            facebook-icon: facebook-icon;
            apple-icon: apple-icon;
            submit-login(email, pass) => { submit-login(email, pass); }
            submit-register(email, pass, tos, priv, mkt) => { submit-register(email, pass, tos, priv, mkt); }
            facebook-login => { facebook-login(); }
            apple-login => { apple-login(); }
            cancel-auth => { cancel-auth(); }
            request-password-reset(email) => { request-password-reset(email); }
            guest-login => { guest-login(); }
        }

        if (root.show-main-shell) : VerticalLayout {
            width: 100%;
            height: 100%;
            visible: !root.effective-show-details;
            spacing: 0;
            padding: 0;

            // Official horizontal navigation bar.
            Rectangle {
                height: 5.5 * root.ui-unit;
                visible: !root.effective-show-details;
                background: transparent;
                z: 100;

                HorizontalLayout {
                    padding-right: root.ui-unit;
                    alignment: space-between;

                    // Left Block: Logo symbol
                    Rectangle {
                        width: 6 * root.ui-unit;
                        height: 5.5 * root.ui-unit;
                        
                        Image {
                            source: @image-url("assets/images/stremio-logo.svg");
                            width: 2.5 * root.ui-unit;
                            height: 2.5 * root.ui-unit;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                            opacity: 0.9;
                        }
                    }

                    // Center Search pill (starts next to logo, left-ish aligned)
                    VerticalLayout {
                        alignment: center;
                        
                        search-input := SearchBox {
                            width: 30 * root.ui-unit;
                            height: 3.25 * root.ui-unit;
                            unit: root.ui-unit;
                            text <=> root.search-query;
                            suggestions: root.search-suggestions;
                            edited(value) => {
                                global-search-edited(value);
                                if (root.effective-active-tab == 1) {
                                    discover-search-changed(value);
                                } else if (root.effective-active-tab == 2) {
                                    library-search-changed(value);
                                }
                            }
                            accepted(value) => {
                                if (value != "") {
                                    global-search-submitted(value);
                                }
                            }
                            cleared => { global-search-edited(""); }
                            suggestion-selected(id, media-type, title) => {
                                root.search-query = title;
                                root.global-search-suggestion-selected(id, media-type);
                            }
                        }
                    }

                    HorizontalLayout {
                        spacing: 0.5 * root.ui-unit;
                        alignment: center;
                        padding-top: 0.5 * root.ui-unit;

                        Rectangle {
                            width: 3.5 * root.ui-unit;
                            height: 3.5 * root.ui-unit;
                            border-radius: 0.75 * root.ui-unit;
                            background: top-fullscreen.has-hover ? Theme.overlay : transparent;
                            top-fullscreen := TouchArea {
                                clicked => { root.player-toggle-fullscreen(); }
                            }
                             Image {
                                source: @image-url("assets/images/icons/maximize.svg");
                                width: 2 * root.ui-unit;
                                height: 2 * root.ui-unit;
                                x: (parent.width - self.width) / 2;
                                y: (parent.height - self.height) / 2;
                                opacity: 0.6;
                                image-fit: contain;
                            }
                        }

                        Rectangle {
                            width: 5.5 * root.ui-unit;
                            height: 3.5 * root.ui-unit;
                            border-radius: 0.75 * root.ui-unit;
                            background: profile-area.has-hover ? Theme.overlay : transparent;

                            profile-area := TouchArea {
                                clicked => { root.profile-menu-open = !root.profile-menu-open; }
                            }

                            Rectangle {
                                x: 0.55 * root.ui-unit;
                                y: 0.55 * root.ui-unit;
                                width: 2.4 * root.ui-unit;
                                height: 2.4 * root.ui-unit;
                                background: Theme.accent;
                                border-radius: self.width / 2;
                                border-width: 0.15 * root.ui-unit;
                                border-color: Theme.accent;
                                clip: true;
                            
                                if (username == "" || username == "Guest") : Image {
                                    source: anonymous-icon;
                                    width: parent.width;
                                    height: parent.height;
                                    image-fit: cover;
                                }
                            
                                if (username != "" && username != "Guest" && has-avatar-image) : Image {
                                    source: avatar-image;
                                    width: parent.width;
                                    height: parent.height;
                                    image-fit: cover;
                                }
                            
                                if (username != "" && username != "Guest" && !has-avatar-image) : Image {
                                    source: default-avatar-icon;
                                    width: parent.width;
                                    height: parent.height;
                                    image-fit: cover;
                                }
                            }

                            Image {
                                x: parent.width - self.width - 0.55 * root.ui-unit;
                                y: (parent.height - self.height) / 2;
                                width: root.ui-unit;
                                height: root.ui-unit;
                                source: @image-url("assets/images/icons/caret-down.svg");
                                colorize: Theme.text-primary;
                                opacity: 0.6;
                                image-fit: contain;
                            }
                        }
                    }
                }

                if (root.profile-menu-open) : Rectangle {
                    x: 0px;
                    y: 0px;
                    width: root.width;
                    height: root.height;
                    background: transparent;
                    z: 190;

                    TouchArea {
                        clicked => { root.profile-menu-open = false; }
                    }
                }

                if (root.profile-menu-open) : Rectangle {
                    x: parent.width - 23 * root.ui-unit;
                    y: 6.5 * root.ui-unit;
                    width: 22 * root.ui-unit;
                    height: layout.preferred-height;
                    border-radius: 0.75 * root.ui-unit;
                    background: Theme.modal-background;
                    clip: true;
                    z: 200;

                    layout := VerticalLayout {
                        spacing: 0px;

                        HorizontalLayout {
                            height: 7 * root.ui-unit;
                            padding-left: root.ui-unit;
                            padding-right: root.ui-unit;
                            spacing: root.ui-unit;
                            alignment: start;

                            Rectangle {
                                width: 4 * root.ui-unit;
                                height: 4 * root.ui-unit;
                                border-radius: self.width / 2;
                                background: Theme.text-primary;
                                clip: true;
                                y: (parent.height - self.height) / 2;

                                if (username == "" || username == "Guest") : Image {
                                    source: anonymous-icon;
                                    width: parent.width;
                                    height: parent.height;
                                    image-fit: cover;
                                }
                                if (username != "" && username != "Guest" && has-avatar-image) : Image {
                                    source: avatar-image;
                                    width: parent.width;
                                    height: parent.height;
                                    image-fit: cover;
                                }
                                if (username != "" && username != "Guest" && !has-avatar-image) : Image {
                                    source: default-avatar-icon;
                                    width: parent.width;
                                    height: parent.height;
                                    image-fit: cover;
                                }
                            }

                            VerticalLayout {
                                alignment: center;
                                spacing: 0.5 * root.ui-unit;
                                Text {
                                    text: username == "" || username == "Guest" ? "Anonymous user" : username;
                                    color: Theme.text-primary;
                                    font-size: root.ui-unit;
                                    overflow: elide;
                                }
                                Text {
                                    text: username == "" || username == "Guest" ? "Log in / Sign up" : "Log out";
                                    color: Theme.accent;
                                    font-size: 0.9 * root.ui-unit;
                                    font-weight: 600;
                                    TouchArea {
                                        mouse-cursor: pointer;
                                        clicked => {
                                            root.profile-menu-open = false;
                                            if (username == "" || username == "Guest") {
                                                username = "";
                                            } else {
                                                root.logout();
                                            }
                                        }
                                    }
                                }
                            }
                        }

                        Rectangle { height: 1px; background: Theme.overlay; }

                        MenuButton {
                            unit: root.ui-unit;
                            label: root.is-fullscreen ? "Exit Fullscreen" : "Enter Fullscreen";
                            show-icon: true;
                            icon-source: root.is-fullscreen ? @image-url("assets/images/icons/minimize.svg") : @image-url("assets/images/icons/maximize.svg");
                            clicked => {
                                root.profile-menu-open = false;
                                root.toggle-fullscreen();
                            }
                        }

                        Rectangle { height: 1px; background: Theme.overlay; }

                        MenuButton {
                            unit: root.ui-unit;
                            label: "Settings";
                            show-icon: true;
                            icon-source: @image-url("assets/images/icons/settings.svg");
                            clicked => {
                                root.profile-menu-open = false;
                                root.tab-changed(4);
                            }
                        }
                        MenuButton {
                            unit: root.ui-unit;
                            label: "Addons";
                            show-icon: true;
                            icon-source: @image-url("assets/images/icons/addons.svg");
                            clicked => {
                                root.profile-menu-open = false;
                                root.tab-changed(3);
                            }
                        }
                        MenuButton {
                            unit: root.ui-unit;
                            label: "Play URL or magnet link";
                            show-icon: true;
                            icon-source: @image-url("assets/images/icons/magnet-link.svg");
                            clicked => {
                                root.profile-menu-open = false;
                                search-input.focus-input();
                            }
                        }
                        MenuButton {
                            unit: root.ui-unit;
                            label: "Help & Feedback";
                            show-icon: true;
                            icon-source: @image-url("assets/images/icons/help.svg");
                            clicked => {
                                root.profile-menu-open = false;
                                root.open-external-url("https://stremio.zendesk.com/");
                            }
                        }

                        Rectangle { height: 1px; background: Theme.overlay; }

                        MenuButton {
                            unit: root.ui-unit;
                            label: "Terms of Service";
                            show-icon: false;
                            clicked => {
                                root.profile-menu-open = false;
                                root.open-external-url("https://www.stremio.com/tos");
                            }
                        }
                        MenuButton {
                            unit: root.ui-unit;
                            label: "Privacy Policy";
                            show-icon: false;
                            clicked => {
                                root.profile-menu-open = false;
                                root.open-external-url("https://www.stremio.com/privacy");
                            }
                        }
                        if (username != "" && username != "Guest") : MenuButton {
                            unit: root.ui-unit;
                            label: "User Panel";
                            show-icon: false;
                            clicked => {
                                root.profile-menu-open = false;
                                root.open-external-url("https://www.stremio.com/acc-settings");
                            }
                        }
                    }
                }
            }

            // Lower Content Area (Sidebar on left, main content page on right)
            HorizontalLayout {
                spacing: 0;
                padding: 0;
                vertical-stretch: 1;

                Sidebar {
                    unit: root.ui-unit;
                    visible: !root.effective-show-details;
                    active-tab: root.effective-active-tab;
                    server-status: server-status;
                    username: username;
                    avatar-letter: avatar-letter;
                    
                    board-icon: board-icon;
                    discover-icon: discover-icon;
                    library-icon: library-icon;
                    calendar-icon: calendar-icon;
                    addons-icon: addons-icon;
                    settings-icon: settings-icon;
                    logout-icon: logout-icon;

                    change-tab(tab) => {
                        root.tab-changed(tab);
                    }
                    logout => { logout(); }
                }

                // Inner content area
                Rectangle {
                    min-width: 0px;
                    horizontal-stretch: 1;
                    vertical-stretch: 1;
                    background: transparent;
                    clip: true;
                    
                    if (root.effective-active-tab == 0) : BoardPage {
                        width: parent.width;
                        height: parent.height;
                        unit: root.ui-unit;
                        continue-watching: root.debug-preview-enabled && root.debug-preview-page == 0
                            && (root.debug-preview-state == "empty"
                                || root.debug-preview-state == "loading"
                                || root.debug-preview-state == "catalogs-only")
                            ? [] : board-continue-watching;
                        sections: root.debug-preview-enabled && root.debug-preview-page == 0
                            && (root.debug-preview-state == "empty"
                                || root.debug-preview-state == "loading"
                                || root.debug-preview-state == "continue-only")
                            ? [] : board-sections;
                        loading: root.debug-preview-enabled && root.debug-preview-page == 0
                            ? root.debug-preview-state == "loading"
                            : loading;
                        item-selected(id, media-type, video-id) => {
                            board-item-selected(id, media-type, video-id);
                        }
                        remove-continue-watching(id) => { remove-continue-watching(id); }
                        see-all-continue-watching() => { board-see-all-continue-watching(); }
                        see-all-clicked(t, id, base) => { board-see-all-clicked(t, id, base); }
