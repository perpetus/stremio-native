            active-subtitle-idx: player-active-subtitle-idx;
            active-audio-idx: player-active-audio-idx;
            subtitle-delay-seconds: player-subtitle-delay-seconds;
            subtitle-size-percent: player-subtitle-size-percent;
            subtitle-offset-percent: player-subtitle-offset-percent;
            is-series: root.debug-preview-enabled && root.debug-preview-page == 8
                ? true : player-is-series;
            episode-names: player-episode-names;
            active-episode-idx: player-active-episode-idx;
            playback-speed: player-playback-speed;
            video-scale-mode: player-video-scale-mode;
            error-message: root.debug-preview-enabled && root.debug-preview-page == 8
                ? (root.debug-preview-state == "player-error"
                    ? "The stream stopped unexpectedly. Select another stream and try again."
                    : "")
                : player-error;
            video-format: player-video-format;
            audio-format: player-audio-format;
            file-format: player-file-format;
            hardware-decoder: player-hwdec;
            buffered-percent: player-buffered-percent;
            download-speed: player-download-speed;
            upload-speed: player-upload-speed;
            peer-count: player-peer-count;
            stream-progress: player-stream-progress;
            seek-step-seconds: player-seek-step-seconds;
            show-skip-button: root.debug-preview-enabled && root.debug-preview-page == 8
                ? root.debug-preview-state == "skip-intro"
                : player-show-skip-button;
            skip-button-label: player-skip-button-label;
            controls-visible <=> root.player-controls-visible;
            show-subtitles-menu <=> root.player-show-subtitles-menu;
            show-audio-menu <=> root.player-show-audio-menu;
            show-speed-menu <=> root.player-show-speed-menu;
            show-stats-menu <=> root.player-show-stats-menu;
            show-options-menu <=> root.player-show-options-menu;
            show-context-menu <=> root.player-show-context-menu;
            show-playlist-drawer <=> root.player-show-playlist-drawer;
            
            icon-play: icon-play;
            icon-pause: icon-pause;
            icon-next: icon-next;
            icon-volume-high: icon-volume-high;
            icon-volume-low: icon-volume-low;
            icon-volume-mute: icon-volume-mute;
            icon-fullscreen: icon-fullscreen;
            icon-subtitles: icon-subtitles;
            icon-audio: icon-audio;
            icon-speed: icon-speed;
            icon-stats: icon-stats;
            icon-options: icon-options;
            icon-menu: icon-menu;
            icon-back: icon-back;
            
            toggle-pause => { player-toggle-pause(); }
            seek(val) => { player-seek(val); }
            seek-relative(seconds) => { player-seek-relative(seconds); }
            change-volume(val) => { player-change-volume(val); }
            toggle-mute => { player-toggle-mute(); }
            change-subtitle(idx) => { player-change-subtitle(idx); }
            change-audio(idx) => { player-change-audio(idx); }
            change-subtitle-delay(value) => { player-change-subtitle-delay(value); }
            change-subtitle-size(value) => { player-change-subtitle-size(value); }
            change-subtitle-offset(value) => { player-change-subtitle-offset(value); }
            change-speed(val) => { player-change-speed(val); }
            change-video-scale(mode) => { player-change-video-scale(mode); }
            skip-segment => { player-skip-segment(); }
            copy-stream-link => { player-copy-stream-link(); }
            download-video => { player-download-video(); }
            play-episode(idx) => { player-play-episode(idx); }
            toggle-fullscreen => { player-toggle-fullscreen(); }
            close => { player-close(); }
            activity => { player-activity(); }
        }

        if (root.debug-preview-enabled) : AppDebugMenu {
            x: root.ui-unit;
            y: parent.height - self.height - root.ui-unit;
            unit: root.ui-unit;
            pages: root.debug-pages;
            states: root.debug-state-options;
            selected-page: root.debug-preview-page;
            selected-state: root.debug-preview-state;
            open <=> root.debug-menu-open;
            page-selected(page) => {
                root.profile-menu-open = false;
                root.debug-preview-page = page;
                root.debug-preview-state = page == -1 ? "login"
                    : (page == 0 ? "loaded"
                    : (page == 1 ? "catalog"
                    : (page == 2 ? "loaded"
                    : (page == 3 ? "loaded"
                    : (page == 4 ? "general"
                    : (page == 5 ? "loaded"
                    : (page == 6 ? "results"
                    : (page == 7 ? "series-episodes" : "paused"))))))));
            }
            state-selected(state) => {
                root.profile-menu-open = root.debug-preview-page == 0 && state == "profile-menu";
                root.debug-preview-state = state;
                if (root.debug-preview-page == 8) {
                    root.player-controls-visible = state != "controls-hidden";
                    root.player-show-subtitles-menu = state == "subtitles";
                    root.player-show-audio-menu = state == "audio";
                    root.player-show-speed-menu = state == "speed";
                    root.player-show-stats-menu = state == "stats";
                    root.player-show-options-menu = state == "options";
                    root.player-show-context-menu = state == "context-menu";
                    root.player-show-playlist-drawer = state == "episodes";
                }
            }
        }
    }
}
