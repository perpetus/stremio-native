        if (root.effective-show-details) : DetailsPage {
            x: 0px;
            y: 0px;
            width: 100%;
            height: 100%;
            z: 500;
            unit: root.ui-unit;
            item-title: root.debug-preview-enabled && root.debug-preview-page == 7
                && (root.debug-preview-state == "movie-streams"
                    || root.debug-preview-state == "movie-no-streams"
                    || root.debug-preview-state == "movie-filter")
                ? "Dune: Part Two" : detail-title;
            description: root.debug-preview-enabled && root.debug-preview-page == 7
                && (root.debug-preview-state == "movie-streams"
                    || root.debug-preview-state == "movie-no-streams"
                    || root.debug-preview-state == "movie-filter")
                ? "Paul Atreides unites with Chani and the Fremen while seeking revenge against the conspirators who destroyed his family."
                : detail-description;
            poster: root.debug-preview-enabled && root.debug-preview-page == 7
                && (root.debug-preview-state == "movie-streams"
                    || root.debug-preview-state == "movie-no-streams"
                    || root.debug-preview-state == "movie-filter")
                ? @image-url("assets/images/background_1.svg") : detail-poster;
            background-image: root.debug-preview-enabled && root.debug-preview-page == 7
                && (root.debug-preview-state == "movie-streams"
                    || root.debug-preview-state == "movie-no-streams"
                    || root.debug-preview-state == "movie-filter")
                ? @image-url("assets/images/background_1.svg") : detail-background;
            release-year: root.debug-preview-enabled && root.debug-preview-page == 7
                && (root.debug-preview-state == "movie-streams"
                    || root.debug-preview-state == "movie-no-streams"
                    || root.debug-preview-state == "movie-filter") ? "2024" : detail-year;
            runtime: root.debug-preview-enabled && root.debug-preview-page == 7
                && (root.debug-preview-state == "movie-streams"
                    || root.debug-preview-state == "movie-no-streams"
                    || root.debug-preview-state == "movie-filter") ? "166 min" : detail-runtime;
            rating: root.debug-preview-enabled && root.debug-preview-page == 7
                && (root.debug-preview-state == "movie-streams"
                    || root.debug-preview-state == "movie-no-streams"
                    || root.debug-preview-state == "movie-filter") ? "8.5" : detail-rating;
            genres: root.debug-preview-enabled && root.debug-preview-page == 7
                && (root.debug-preview-state == "movie-streams"
                    || root.debug-preview-state == "movie-no-streams"
                    || root.debug-preview-state == "movie-filter")
                ? ["Science Fiction", "Adventure", "Drama"] : detail-genres;
            cast: root.debug-preview-enabled && root.debug-preview-page == 7
                && (root.debug-preview-state == "movie-streams"
                    || root.debug-preview-state == "movie-no-streams"
                    || root.debug-preview-state == "movie-filter")
                ? ["Timothée Chalamet", "Zendaya", "Rebecca Ferguson"] : detail-cast;
            directors: root.debug-preview-enabled && root.debug-preview-page == 7
                && (root.debug-preview-state == "movie-streams"
                    || root.debug-preview-state == "movie-no-streams"
                    || root.debug-preview-state == "movie-filter")
                ? ["Denis Villeneuve"] : detail-directors;
            streams: root.debug-preview-enabled && root.debug-preview-page == 7
                && (root.debug-preview-state == "movie-no-streams"
                    || root.debug-preview-state == "series-no-streams"
                    || root.debug-preview-state == "details-loading")
                ? [] : stream-links;
            stream-providers: detail-stream-providers;
            stream-loading-count: root.debug-preview-enabled && root.debug-preview-page == 7
                ? (root.debug-preview-state == "series-stream-loading" ? 2 : 0)
                : detail-stream-loading-count;
            stream-filter-open: root.debug-preview-enabled && root.debug-preview-page == 7
                && root.debug-preview-state == "movie-filter";
            loading: root.debug-preview-enabled && root.debug-preview-page == 7
                ? root.debug-preview-state == "details-loading"
                : details-loading;
            username: root.username;
            avatar-image: root.avatar-image;
            has-avatar-image: root.has-avatar-image;
            default-avatar-icon: root.default-avatar-icon;
            anonymous-icon: root.anonymous-icon;

            is-in-library: detail-is-in-library;
            is-watched: detail-is-watched;
            has-trailer: detail-has-trailer;
            trailer-selection-id: detail-trailer-selection-id;
            toggle-library => { details-toggle-library(); }
            toggle-watched => { details-toggle-watched(); }
            play-trailer(selection-id) => { play-stream(selection-id); }

            is-series: root.debug-preview-enabled && root.debug-preview-page == 7
                ? (root.debug-preview-state == "series-episodes"
                    || root.debug-preview-state == "series-season-menu"
                    || root.debug-preview-state == "series-streams"
                    || root.debug-preview-state == "series-stream-loading"
                    || root.debug-preview-state == "series-no-streams")
                : detail-is-series;
            available-seasons: detail-seasons;
            active-season: detail-active-season;
            season-menu-open: root.debug-preview-enabled && root.debug-preview-page == 7
                && root.debug-preview-state == "series-season-menu";
            episode-names: detail-episode-names;
            active-episode-idx: detail-active-episode-idx;
            episodes: detail-episodes;
            in-stream-view: root.debug-preview-enabled && root.debug-preview-page == 7
                ? (root.debug-preview-state == "series-streams"
                    || root.debug-preview-state == "series-stream-loading"
                    || root.debug-preview-state == "series-no-streams")
                : detail-in-stream-view;
            episode-search-query: detail-episode-search-query;

            icon-play: root.icon-play;
            icon-link: root.icon-link;
            icon-magnet: root.icon-magnet;
            icon-download: root.icon-download;
            icon-eye: root.icon-eye;
            icon-eye-off: root.icon-eye-off;
            icon-clapperboard: root.icon-clapperboard;

            season-changed(s) => { details-season-changed(s); }
            episode-changed(idx) => {
                if (root.debug-preview-enabled && root.debug-preview-page == 7) {
                    root.detail-active-episode-idx = idx;
                    root.debug-preview-state = "series-streams";
                } else {
                    details-episode-changed(idx);
                }
            }
            toggle-episode-watched(id) => { details-toggle-episode-watched(id); }
            episode-search-changed(q) => {
                detail-episode-search-query = q;
                details-episode-search-changed(q);
            }
            copy-stream-link(id) => { details-copy-stream-link(id); }
            copy-magnet-link(id) => { details-copy-magnet-link(id); }
            copy-download-link(id) => { details-copy-download-link(id); }
            toggle-season-watched(s) => { details-toggle-season-watched(s); }
            play-stream(selection-id) => { play-stream(selection-id); }
            toggle-fullscreen => { root.player-toggle-fullscreen(); }
            close => {
                if (root.debug-preview-enabled && root.debug-preview-page == 7
                    && (root.debug-preview-state == "series-streams"
                        || root.debug-preview-state == "series-stream-loading"
                        || root.debug-preview-state == "series-no-streams")) {
                    root.debug-preview-state = "series-episodes";
                } else if (detail-in-stream-view) {
                    detail-in-stream-view = false;
                } else {
                    root.navigation-back();
                }
            }
        }
        }
        }

        if (root.effective-show-player) : PlayerPage {
