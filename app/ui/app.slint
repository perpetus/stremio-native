import { Theme, IconData } from "theme.slint";
import { Sidebar } from "components/sidebar.slint";
import { MediaCardItem } from "components/media_card.slint";
import { AuthPage } from "pages/auth.slint";
import { BoardPage, BoardSection } from "pages/board.slint";
import { DiscoverPage, DiscoverRow } from "pages/discover.slint";
import { LibraryPage, LibraryRow } from "pages/library.slint";
import { AddonsPage, AddonItem } from "pages/addons.slint";
import { DetailsPage, StreamLink, EpisodeItem } from "pages/details.slint";
import { SettingsPage } from "pages/settings.slint";
import { PlayerPage } from "pages/player.slint";
import { CalendarPage, CalendarRow, CalendarCell, CalendarMediaItem } from "pages/calendar.slint";
import { SearchPage, SearchSuggestion } from "pages/search.slint";

import { Fonts } from "imported_fonts.slint";
import "./assets/fonts/PlusJakartaSans.ttf";
import { LineEdit } from "std-widgets.slint";

export { Theme, IconData, MediaCardItem, StreamLink, EpisodeItem, BoardSection, DiscoverRow, LibraryRow, AddonItem, CalendarRow, CalendarCell, CalendarMediaItem, SearchSuggestion }

component NavMenuItem inherits Rectangle {
    in property <length> unit: 16px;
    in property <string> label;
    in property <image> icon;
    in property <bool> show-icon: true;
    callback clicked;

    height: 4 * root.unit;
    background: area.has-hover ? Theme.overlay : transparent;
    area := TouchArea { clicked => { root.clicked(); } }

    HorizontalLayout {
        padding-left: 1.5 * root.unit;
        padding-right: 1.5 * root.unit;
        spacing: 1.25 * root.unit;
        alignment: start;

        if (root.show-icon) : Image {
            width: 1.5 * root.unit;
            height: 1.5 * root.unit;
            source: root.icon;
            colorize: Theme.text-primary;
            opacity: 0.6;
            image-fit: contain;
            y: (parent.height - self.height) / 2;
        }
        Text {
            text: root.label;
            color: Theme.text-primary;
            font-size: root.unit;
            vertical-alignment: center;
            overflow: elide;
        }
    }
}

export component MainWindow inherits Window {
    title: "Stremio";
    preferred-width: 1280px;
    preferred-height: 720px;
    min-width: 960px;
    min-height: 540px;
    background: Theme.background;
    default-font-family: "Plus Jakarta Sans";
    property <length> ui-unit: root.width > 2800px ? 18px :
        (root.width > 2200px ? 16px : (root.width > 1600px ? 15px : 14px));
    property <bool> profile-menu-open: false;

    // Bindings / API exposed to Rust code
    in-out property <int> active-tab: 0; // 0: Board, 1: Discover, 2: Library, 3: Addons, 4: Settings
    in-out property <string> username: "";
    in-out property <string> avatar-letter: "U";
    in-out property <image> avatar-image;
    in-out property <bool> has-avatar-image: false;
    in property <image> default-avatar-icon: @image-url("assets/images/default_avatar.png");
    in property <image> anonymous-icon: @image-url("assets/images/anonymous.png");
    in-out property <bool> loading: false;
    in-out property <string> error-message: "";

    // Stats (Footer stats)
    in-out property <string> server-status: "Offline";
    in-out property <string> server-url: "";

    // Data lists
    in-out property <[MediaCardItem]> board-continue-watching: [];
    in-out property <[BoardSection]> board-sections: [];
    in-out property <[BoardSection]> search-sections: [];
    in-out property <[SearchSuggestion]> search-suggestions: [];
    in-out property <string> search-query: "";
    in-out property <bool> search-loading: false;
    in-out property <int> search-catalog-count: 0;
    
    in-out property <[DiscoverRow]> discover-rows: [];
    in-out property <int> discover-column-count: 6;
    in-out property <[LibraryRow]> library-rows: [];
    in-out property <int> library-column-count: 6;
    in-out property <string> library-active-type: "All";
    in-out property <string> library-active-sort: "Last Watched";
    in-out property <[AddonItem]> addons-list: [];
    in-out property <string> addons-search-query: "";
    in-out property <bool> addon-details-open: false;
    in-out property <AddonItem> addon-details-addon;
    in-out property <bool> addon-details-loading: false;
    in-out property <string> addon-details-error: "";
    in-out property <bool> addon-details-configurable: false;
    in-out property <bool> addon-details-configuration-required: false;
    in-out property <[StreamLink]> stream-links: [];
    in-out property <[string]> detail-stream-providers: ["All"];
    in-out property <int> detail-stream-loading-count: 0;
    in-out property <int> calendar-selected-year: 0;
    in-out property <string> calendar-selected-month: "";
    in-out property <string> calendar-previous-month: "";
    in-out property <string> calendar-next-month: "";
    in-out property <[CalendarRow]> calendar-rows: [];
    in-out property <bool> calendar-loading: false;

    // Filters lists & values for Discover
    in property <[string]> discover-types: [];
    in-out property <string> discover-active-type: "";
    in property <[string]> discover-catalogs: [];
    in-out property <string> discover-active-catalog: "";
    in property <[string]> discover-genres: [];
    in-out property <string> discover-active-genre: "";
    in-out property <length> discover-scroll-y: 0px;

    // Discover preview drawer parameters
    in-out property <bool> discover-has-preview: false;
    in-out property <string> discover-preview-title: "";
    in-out property <string> discover-preview-description: "";
    in-out property <string> discover-preview-rating: "";
    in-out property <string> discover-preview-year: "";
    in-out property <string> discover-preview-runtime: "";
    in-out property <[string]> discover-preview-genres: [];
    in-out property <[string]> discover-preview-cast: [];
    in-out property <[string]> discover-preview-directors: [];
    in-out property <bool> discover-preview-is-in-library: false;
    in-out property <bool> discover-preview-is-watched: false;
    in-out property <bool> discover-preview-has-trailer: false;
    in-out property <image> discover-preview-poster;

    // Detailed view parameters
    in-out property <string> detail-title: "";
    in-out property <string> detail-description: "";
    in-out property <image> detail-poster;
    in-out property <string> detail-year: "";
    in-out property <string> detail-runtime: "";
    in-out property <string> detail-rating: "";
    in-out property <[string]> detail-genres: [];
    in-out property <[string]> detail-cast: [];
    in-out property <[string]> detail-directors: [];
    in-out property <bool> detail-is-watched: false;
    in-out property <bool> detail-has-trailer: false;
    in-out property <string> detail-trailer-selection-id: "";
    in-out property <bool> show-details: false;
    
    // Details Series View bindings
    in-out property <bool> detail-is-series: false;
    in-out property <[int]> detail-seasons: [];
    in-out property <int> detail-active-season: 1;
    in-out property <[string]> detail-episode-names: [];
    in-out property <int> detail-active-episode-idx: 0;
    in-out property <bool> detail-is-in-library: false;
    in-out property <image> detail-background;
    in-out property <[EpisodeItem]> detail-episodes: [];
    in-out property <bool> detail-in-stream-view: false;
    in-out property <string> detail-episode-search-query: "";

    callback details-episode-search-changed(string);
    callback details-toggle-episode-watched(string);
    callback details-copy-stream-link(string);
    callback details-copy-magnet-link(string);
    callback details-copy-download-link(string);
    callback details-toggle-season-watched(int);

    // Player Page parameters
    in-out property <bool> show-player: false;
    in-out property <string> player-title: "";
    in-out property <string> player-stream-name: "";
    in-out property <image> player-poster-image;
    in-out property <image> player-video-frame;
    in-out property <bool> player-has-video-frame: false;
    in-out property <bool> player-loading: false;
    in-out property <bool> player-buffering: false;
    in-out property <float> player-buffering-percent: 0.0;
    in-out property <bool> player-paused: true;
    in-out property <float> player-volume: 1.0;
    in-out property <bool> player-muted: false;
    in-out property <float> player-progress: 0.0;
    in-out property <string> player-elapsed-time-str: "00:00";
    in-out property <string> player-total-time-str: "00:00";
    in-out property <[string]> player-subtitles-tracks: [];
    in-out property <[string]> player-subtitle-track-languages: [];
    in-out property <[string]> player-subtitle-track-origins: [];
    in-out property <[string]> player-subtitle-languages: [];
    in-out property <[int]> player-subtitle-language-track-indices: [];
    in-out property <[string]> player-audio-tracks: [];
    in-out property <[string]> player-audio-track-languages: [];
    in-out property <[string]> player-audio-track-labels: [];
    in-out property <int> player-active-subtitle-idx: -1;
    in-out property <int> player-active-audio-idx: 0;
    in-out property <float> player-subtitle-delay-seconds: 0.0;
    in-out property <float> player-subtitle-size-percent: 100.0;
    in-out property <float> player-subtitle-offset-percent: 100.0;
    in-out property <bool> player-is-series: false;
    in-out property <[string]> player-episode-names: [];
    in-out property <int> player-active-episode-idx: 0;
    in-out property <float> player-playback-speed: 1.0;
    in-out property <int> player-video-scale-mode: 0;
    in-out property <string> player-error: "";
    in-out property <string> player-video-format: "";
    in-out property <string> player-audio-format: "";
    in-out property <string> player-file-format: "";
    in-out property <string> player-hwdec: "";
    in-out property <float> player-buffered-percent: 0.0;
    in-out property <string> player-download-speed: "";
    in-out property <string> player-upload-speed: "";
    in-out property <int> player-peer-count: 0;
    in-out property <float> player-stream-progress: 0.0;
    in-out property <float> player-seek-step-seconds: 10.0;

    // Player Icons
    in property <IconData> icon-play;
    in property <IconData> icon-pause;
    in property <IconData> icon-next;
    in property <IconData> icon-volume-high;
    in property <IconData> icon-volume-low;
    in property <IconData> icon-volume-mute;
    in property <IconData> icon-fullscreen;
    in property <IconData> icon-subtitles;
    in property <IconData> icon-audio;
    in property <IconData> icon-speed;
    in property <IconData> icon-stats;
    in property <IconData> icon-options;
    in property <IconData> icon-menu;
    in property <IconData> icon-back;

    // Settings Page values
    in-out property <string> torrent-cache-size: "2.0 GB";
    in-out property <string> settings-interface-language: "English";
    in-out property <string> settings-subtitles-language: "English";
    in-out property <string> settings-torrent-profile: "Default";
    in-out property <bool> settings-hardware-acceleration: true;
    in-out property <bool> settings-binge-watching: true;
    in-out property <bool> settings-hide-spoilers: false;
    in-out property <bool> settings-gamepad-support: false;
    in-out property <bool> settings-play-in-background: true;
    in-out property <bool> settings-subtitles-auto-select: true;
    in-out property <string> settings-subtitles-font: "Roboto";
    in-out property <string> settings-subtitles-size: "100";
    in-out property <bool> settings-subtitles-bold: false;
    in-out property <string> settings-subtitles-offset: "5";
    in-out property <string> settings-seek-duration: "10";
    in-out property <bool> settings-pause-on-minimize: false;
    in-out property <bool> settings-quit-on-close: true;
    in-out property <bool> settings-export-loading: false;
    in-out property <string> settings-export-status: "";
    in-out property <bool> settings-streaming-seeding: false;
    in-out property <bool> settings-streaming-dht: true;
    in-out property <bool> settings-streaming-pex: true;
    in-out property <bool> settings-streaming-lsd: true;
    in-out property <string> settings-streaming-remote-url: "";
    in-out property <string> settings-streaming-logs-text: "No logs loaded. Click Refresh.";
    in property <IconData> refresh-icon;
    in property <IconData> folder-icon;

    callback settings-change-seeding-enabled(bool);
    callback settings-change-dht-enabled(bool);
    callback settings-change-pex-enabled(bool);
    callback settings-change-lsd-enabled(bool);
    callback settings-refresh-logs();
    callback settings-open-logs-folder();
    callback settings-export-data();
    callback settings-change-binge-watching(bool);
    callback settings-change-hide-spoilers(bool);
    callback settings-change-gamepad-support(bool);
    callback settings-change-play-in-background(bool);
    callback settings-change-subtitles-auto-select(bool);
    callback settings-change-subtitles-font(string);
    callback settings-change-subtitles-size(string);
    callback settings-change-subtitles-bold(bool);
    callback settings-change-subtitles-offset(string);
    callback settings-change-seek-duration(string);
    callback settings-change-pause-on-minimize(bool);
    callback settings-change-quit-on-close(bool);
    in-out property <length> library-scroll-y: 0px;

    // Icons from Rust Iconflow
    in property <IconData> board-icon;
    in property <IconData> discover-icon;
    in property <IconData> library-icon;
    in property <IconData> calendar-icon;
    in property <IconData> addons-icon;
    in property <IconData> settings-icon;
    in property <IconData> logout-icon;
    in property <IconData> mail-icon;
    in property <IconData> lock-icon;
    in property <IconData> search-icon;
    in property <IconData> facebook-icon;
    in property <IconData> apple-icon;
    in property <IconData> icon-link;
    in property <IconData> icon-magnet;
    in property <IconData> icon-download;
    in property <IconData> icon-eye;
    in property <IconData> icon-eye-off;
    in property <IconData> icon-clapperboard;
    in-out property <bool> is-fullscreen: false;

    // Callbacks
    callback toggle-fullscreen();
    callback open-external-url(string);
    callback submit-login(string, string);
    callback submit-register(string, string, bool, bool, bool);
    callback facebook-login();
    callback apple-login();
    callback cancel-auth();
    callback request-password-reset(string);
    callback guest-login();
    callback logout();
    
    // Board page callback
    callback board-item-selected(string, string, string);
    callback remove-continue-watching(string);
    callback board-see-all-continue-watching();
    callback board-see-all-clicked(string, string, string);

    // Global search callbacks
    callback global-search-edited(string);
    callback global-search-submitted(string);
    callback global-search-suggestion-selected(string, string);
    callback search-item-selected(string, string, string);
    callback request-poster(string);

    // Discover page callbacks
    callback discover-type-changed(string);
    callback discover-catalog-changed(string);
    callback discover-genre-changed(string);
    callback discover-search-changed(string);
    callback discover-item-selected(string);
    callback play-preview();
    callback toggle-library-preview();
    
    // Library page callbacks
    callback library-type-changed(string);
    callback library-sort-changed(string);
    callback library-search-changed(string);
    callback library-item-selected(string);

    // Addons page callbacks
    callback install-addon(string);
    callback uninstall-addon(string);
    callback open-addon-details(string);
    callback close-addon-details();
    callback configure-addon(string);
    callback share-addon(string);
    callback addons-search-changed(string);

    // Details callbacks
    callback details-toggle-library();
    callback details-toggle-watched();
    callback details-season-changed(int);
    callback details-episode-changed(int);
    callback play-stream(string);
    
    // Settings callbacks
    callback apply-cache-settings(float);
    callback settings-change-interface-language(string);
    callback settings-change-subtitles-language(string);
    callback settings-change-torrent-profile(string);
    callback settings-change-hardware-acceleration(bool);
    callback settings-clear-search-history();
    callback shutdown-server();
    callback tab-changed(int);
    callback calendar-previous();
    callback calendar-next();
    callback calendar-item-selected(string);

    // Player Callbacks
    callback player-toggle-pause();
    callback player-seek(float);
    callback player-seek-relative(float);
    callback player-change-volume(float);
    callback player-toggle-mute();
    callback player-change-subtitle(int);
    callback player-change-audio(int);
    callback player-change-subtitle-delay(float);
    callback player-change-subtitle-size(float);
    callback player-change-subtitle-offset(float);
    callback player-change-speed(float);
    callback player-change-video-scale(int);
    callback player-copy-stream-link();
    callback player-download-video();
    callback player-play-episode(int);
    callback player-toggle-fullscreen();
    callback player-close();

    // Visual layout routing
    Rectangle {
        width: 100%;
        height: 100%;

        if (!show-player) : Rectangle {
            width: 100%;
            height: 100%;
            background: username == "" ? Theme.background : Theme.main-gradient;

            HorizontalLayout {
                spacing: 0;
                padding: 0;

        if (username == "") : AuthPage {
            error-message: error-message;
            loading: loading;
            mail-icon: mail-icon;
            lock-icon: lock-icon;
            facebook-icon: facebook-icon;
            apple-icon: apple-icon;
            submit-login(email, pass) => { submit-login(email, pass); }
            submit-register(email, pass, tos, priv, mkt) => { submit-register(email, pass, tos, priv, mkt); }
            facebook-login => { facebook-login(); }
            apple-login => { apple-login(); }
            cancel-auth => { cancel-auth(); }
            request-password-reset(email) => { request-password-reset(email); }
            guest-login => { guest-login(); }
        }

        if (username != "") : VerticalLayout {
            spacing: 0;
            padding: 0;

            // Official horizontal navigation bar.
            if (!root.show-details) : Rectangle {
                height: 5.5 * root.ui-unit;
                background: transparent;
                z: 100;

                HorizontalLayout {
                    padding-right: root.ui-unit;
                    alignment: space-between;

                    // Left Block: Logo symbol
                    Rectangle {
                        width: 6 * root.ui-unit;
                        height: 5.5 * root.ui-unit;
                        
                        Image {
                            source: @image-url("assets/images/stremio-logo.svg");
                            width: 2.5 * root.ui-unit;
                            height: 2.5 * root.ui-unit;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                            opacity: 0.9;
                        }
                    }

                    // Center Search pill (starts next to logo, left-ish aligned)
                    VerticalLayout {
                        alignment: center;
                        
                        search-bar := Rectangle {
                            width: 30 * root.ui-unit;
                            height: 3.25 * root.ui-unit;
                            background: Theme.overlay;
                            border-radius: self.height / 2;

                            if (search-input.text == "") : Text {
                                x: 2 * root.ui-unit;
                                width: parent.width - 6 * root.ui-unit;
                                height: parent.height;
                                text: "Search or paste link";
                                color: Theme.text-primary;
                                opacity: 0.6;
                                font-size: root.ui-unit;
                                font-weight: 500;
                                vertical-alignment: center;
                            }

                            search-input := TextInput {
                                x: 2 * root.ui-unit;
                                width: parent.width - 6 * root.ui-unit;
                                height: parent.height;
                                font-size: root.ui-unit;
                                font-weight: 500;
                                color: Theme.text-primary;
                                vertical-alignment: center;
                                single-line: true;
                                text <=> root.search-query;
                                edited => {
                                    global-search-edited(self.text);
                                    if (active-tab == 1) {
                                        discover-search-changed(self.text);
                                    } else if (active-tab == 2) {
                                        library-search-changed(self.text);
                                    }
                                }
                                accepted => {
                                    if (self.text != "") {
                                        global-search-submitted(self.text);
                                    }
                                }
                            }

                            Image {
                                x: parent.width - 2.975 * root.ui-unit;
                                y: (parent.height - self.height) / 2;
                                width: 1.7 * root.ui-unit;
                                height: 1.7 * root.ui-unit;
                                source: @image-url("assets/images/icons/search.svg");
                                colorize: Theme.text-primary;
                                opacity: 0.6;
                                image-fit: contain;
                            }

                            if (search-input.has-focus && root.search-query != "" && root.search-suggestions.length > 0) : Rectangle {
                                x: 0px;
                                y: parent.height + 0.5 * root.ui-unit;
                                width: parent.width;
                                height: root.search-suggestions.length * 3.75 * root.ui-unit;
                                background: Theme.modal-background;
                                border-radius: root.ui-unit;
                                border-width: 1px;
                                border-color: Theme.card-border;
                                clip: true;
                                z: 300;

                                VerticalLayout {
                                    width: 100%;
                                    height: 100%;
                                    spacing: 0px;

                                    for suggestion in root.search-suggestions : Rectangle {
                                        height: 3.75 * root.ui-unit;
                                        background: suggestion-area.has-hover ? Theme.overlay : transparent;

                                        HorizontalLayout {
                                            padding-left: root.ui-unit;
                                            padding-right: root.ui-unit;
                                            spacing: root.ui-unit;

                                            Rectangle {
                                                width: 2.4 * root.ui-unit;
                                                height: parent.height;
                                                Image {
                                                    x: (parent.width - self.width) / 2;
                                                    y: (parent.height - self.height) / 2;
                                                    width: 2 * root.ui-unit;
                                                    height: 2.8 * root.ui-unit;
                                                    source: suggestion.poster;
                                                    image-fit: cover;
                                                }
                                            }
                                            VerticalLayout {
                                                horizontal-stretch: 1;
                                                alignment: center;
                                                Text {
                                                    text: suggestion.title;
                                                    color: Theme.text-primary;
                                                    font-size: root.ui-unit;
                                                    font-weight: 600;
                                                    overflow: elide;
                                                }
                                                Text {
                                                    text: suggestion.release-info == ""
                                                        ? suggestion.media-type
                                                        : suggestion.media-type + " · " + suggestion.release-info;
                                                    color: Theme.text-secondary;
                                                    font-size: 0.8 * root.ui-unit;
                                                    overflow: elide;
                                                }
                                            }
                                        }

                                        suggestion-area := TouchArea {
                                            clicked => {
                                                root.search-query = suggestion.title;
                                                root.global-search-suggestion-selected(
                                                    suggestion.id,
                                                    suggestion.media-type
                                                );
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }

                    HorizontalLayout {
                        spacing: 0.5 * root.ui-unit;
                        alignment: center;
                        padding-top: 0.5 * root.ui-unit;

                        Rectangle {
                            width: 3.5 * root.ui-unit;
                            height: 3.5 * root.ui-unit;
                            border-radius: 0.75 * root.ui-unit;
                            background: top-fullscreen.has-hover ? Theme.overlay : transparent;
                            top-fullscreen := TouchArea {
                                clicked => { root.player-toggle-fullscreen(); }
                            }
                             Image {
                                source: @image-url("assets/images/icons/maximize.svg");
                                width: 2 * root.ui-unit;
                                height: 2 * root.ui-unit;
                                x: (parent.width - self.width) / 2;
                                y: (parent.height - self.height) / 2;
                                opacity: 0.6;
                                image-fit: contain;
                            }
                        }

                        Rectangle {
                            width: 3.5 * root.ui-unit;
                            height: 3.5 * root.ui-unit;
                            border-radius: 0.75 * root.ui-unit;
                            background: profile-area.has-hover ? Theme.overlay : transparent;

                            profile-area := TouchArea {
                                clicked => { root.profile-menu-open = !root.profile-menu-open; }
                            }

                            Rectangle {
                                x: 0.55 * root.ui-unit;
                                y: 0.55 * root.ui-unit;
                                width: 2.4 * root.ui-unit;
                                height: 2.4 * root.ui-unit;
                                background: Theme.accent;
                                border-radius: self.width / 2;
                                border-width: 0.15 * root.ui-unit;
                                border-color: Theme.accent;
                                clip: true;
                            
                                if (username == "" || username == "Guest") : Image {
                                    source: anonymous-icon;
                                    width: parent.width;
                                    height: parent.height;
                                    image-fit: cover;
                                }
                            
                                if (username != "" && username != "Guest" && has-avatar-image) : Image {
                                    source: avatar-image;
                                    width: parent.width;
                                    height: parent.height;
                                    image-fit: cover;
                                }
                            
                                if (username != "" && username != "Guest" && !has-avatar-image) : Image {
                                    source: default-avatar-icon;
                                    width: parent.width;
                                    height: parent.height;
                                    image-fit: cover;
                                }
                            }
                        }

                        Rectangle {
                            width: 1.5 * root.ui-unit;
                            height: 3.5 * root.ui-unit;
                            background: menu-caret-area.has-hover ? Theme.overlay : transparent;
                            border-radius: 0.75 * root.ui-unit;

                            menu-caret-area := TouchArea {
                                clicked => { root.profile-menu-open = !root.profile-menu-open; }
                            }

                            Image {
                                x: (parent.width - self.width) / 2;
                                y: (parent.height - self.height) / 2;
                                width: root.ui-unit;
                                height: root.ui-unit;
                                source: @image-url("assets/images/icons/caret-down.svg");
                                colorize: Theme.text-primary;
                                opacity: 0.6;
                                image-fit: contain;
                            }
                        }
                    }
                }

                if (root.profile-menu-open) : Rectangle {
                    x: parent.width - 23 * root.ui-unit;
                    y: 6.5 * root.ui-unit;
                    width: 22 * root.ui-unit;
                    height: layout.preferred-height;
                    border-radius: 0.75 * root.ui-unit;
                    background: Theme.modal-background;
                    clip: true;
                    z: 200;

                    layout := VerticalLayout {
                        spacing: 0px;

                        HorizontalLayout {
                            height: 7 * root.ui-unit;
                            padding-left: root.ui-unit;
                            padding-right: root.ui-unit;
                            spacing: root.ui-unit;
                            alignment: start;

                            Rectangle {
                                width: 4 * root.ui-unit;
                                height: 4 * root.ui-unit;
                                border-radius: self.width / 2;
                                background: Theme.text-primary;
                                clip: true;
                                y: (parent.height - self.height) / 2;

                                if (username == "" || username == "Guest") : Image {
                                    source: anonymous-icon;
                                    width: parent.width;
                                    height: parent.height;
                                    image-fit: cover;
                                }
                                if (username != "" && username != "Guest" && has-avatar-image) : Image {
                                    source: avatar-image;
                                    width: parent.width;
                                    height: parent.height;
                                    image-fit: cover;
                                }
                                if (username != "" && username != "Guest" && !has-avatar-image) : Image {
                                    source: default-avatar-icon;
                                    width: parent.width;
                                    height: parent.height;
                                    image-fit: cover;
                                }
                            }

                            VerticalLayout {
                                alignment: center;
                                spacing: 0.5 * root.ui-unit;
                                Text {
                                    text: username == "" || username == "Guest" ? "Anonymous user" : username;
                                    color: Theme.text-primary;
                                    font-size: root.ui-unit;
                                    overflow: elide;
                                }
                                Text {
                                    text: username == "" || username == "Guest" ? "Log in / Sign up" : "Log out";
                                    color: Theme.accent;
                                    font-size: 0.9 * root.ui-unit;
                                    font-weight: 600;
                                    TouchArea {
                                        mouse-cursor: pointer;
                                        clicked => {
                                            root.profile-menu-open = false;
                                            if (username == "" || username == "Guest") {
                                                username = "";
                                            } else {
                                                root.logout();
                                            }
                                        }
                                    }
                                }
                            }
                        }

                        Rectangle { height: 1px; background: Theme.overlay; }

                        NavMenuItem {
                            unit: root.ui-unit;
                            label: root.is-fullscreen ? "Exit Fullscreen" : "Enter Fullscreen";
                            icon: root.is-fullscreen ? @image-url("assets/images/icons/minimize.svg") : @image-url("assets/images/icons/maximize.svg");
                            clicked => {
                                root.profile-menu-open = false;
                                root.toggle-fullscreen();
                            }
                        }

                        Rectangle { height: 1px; background: Theme.overlay; }

                        NavMenuItem {
                            unit: root.ui-unit;
                            label: "Settings";
                            icon: @image-url("assets/images/icons/settings.svg");
                            clicked => {
                                root.profile-menu-open = false;
                                root.active-tab = 4;
                                root.show-details = false;
                                root.tab-changed(4);
                            }
                        }
                        NavMenuItem {
                            unit: root.ui-unit;
                            label: "Addons";
                            icon: @image-url("assets/images/icons/addons.svg");
                            clicked => {
                                root.profile-menu-open = false;
                                root.active-tab = 3;
                                root.show-details = false;
                                root.tab-changed(3);
                            }
                        }
                        NavMenuItem {
                            unit: root.ui-unit;
                            label: "Play URL or magnet link";
                            icon: @image-url("assets/images/icons/magnet-link.svg");
                            clicked => {
                                root.profile-menu-open = false;
                                search-input.focus();
                            }
                        }
                        NavMenuItem {
                            unit: root.ui-unit;
                            label: "Help & Feedback";
                            icon: @image-url("assets/images/icons/help.svg");
                            clicked => {
                                root.profile-menu-open = false;
                                root.open-external-url("https://stremio.zendesk.com/");
                            }
                        }

                        Rectangle { height: 1px; background: Theme.overlay; }

                        NavMenuItem {
                            unit: root.ui-unit;
                            label: "Terms of Service";
                            show-icon: false;
                            clicked => {
                                root.profile-menu-open = false;
                                root.open-external-url("https://www.stremio.com/tos");
                            }
                        }
                        NavMenuItem {
                            unit: root.ui-unit;
                            label: "Privacy Policy";
                            show-icon: false;
                            clicked => {
                                root.profile-menu-open = false;
                                root.open-external-url("https://www.stremio.com/privacy");
                            }
                        }
                        if (username != "" && username != "Guest") : NavMenuItem {
                            unit: root.ui-unit;
                            label: "User Panel";
                            show-icon: false;
                            clicked => {
                                root.profile-menu-open = false;
                                root.open-external-url("https://www.stremio.com/acc-settings");
                            }
                        }
                    }
                }
            }

            // Lower Content Area (Sidebar on left, main content page on right)
            HorizontalLayout {
                spacing: 0;
                padding: 0;
                vertical-stretch: 1;

                if (!root.show-details) : Sidebar {
                    unit: root.ui-unit;
                    active-tab: active-tab;
                    server-status: server-status;
                    username: username;
                    avatar-letter: avatar-letter;
                    
                    board-icon: board-icon;
                    discover-icon: discover-icon;
                    library-icon: library-icon;
                    calendar-icon: calendar-icon;
                    addons-icon: addons-icon;
                    settings-icon: settings-icon;
                    logout-icon: logout-icon;

                    change-tab(tab) => {
                        active-tab = tab;
                        show-details = false;
                        root.tab-changed(tab);
                    }
                    logout => { logout(); }
                }

                // Inner content area
                Rectangle {
                    min-width: 0px;
                    horizontal-stretch: 1;
                    vertical-stretch: 1;
                    background: transparent;
                    clip: true;
                    
                    if (show-details) : DetailsPage {
                        item-title: detail-title;
                        description: detail-description;
                        poster: detail-poster;
                        background-image: detail-background;
                        release-year: detail-year;
                        runtime: detail-runtime;
                        rating: detail-rating;
                        genres: detail-genres;
                        cast: detail-cast;
                        directors: detail-directors;
                        streams: stream-links;
                        stream-providers: detail-stream-providers;
                        stream-loading-count: detail-stream-loading-count;
                        loading: loading;
                        username: root.username;
                        avatar-image: root.avatar-image;
                        has-avatar-image: root.has-avatar-image;
                        default-avatar-icon: root.default-avatar-icon;
                        anonymous-icon: root.anonymous-icon;
                        
                        is-in-library: detail-is-in-library;
                        is-watched: detail-is-watched;
                        has-trailer: detail-has-trailer;
                        trailer-selection-id: detail-trailer-selection-id;
                        toggle-library => { details-toggle-library(); }
                        toggle-watched => { details-toggle-watched(); }
                        play-trailer(selection-id) => { play-stream(selection-id); }

                        is-series: detail-is-series;
                        available-seasons: detail-seasons;
                        active-season: detail-active-season;
                        episode-names: detail-episode-names;
                        active-episode-idx: detail-active-episode-idx;

                        episodes: detail-episodes;
                        in-stream-view: detail-in-stream-view;
                        episode-search-query: detail-episode-search-query;

                        icon-play: root.icon-play;
                        icon-link: root.icon-link;
                        icon-magnet: root.icon-magnet;
                        icon-download: root.icon-download;
                        icon-eye: root.icon-eye;
                        icon-eye-off: root.icon-eye-off;
                        icon-clapperboard: root.icon-clapperboard;

                        season-changed(s) => { details-season-changed(s); }
                        episode-changed(idx) => { details-episode-changed(idx); }
                        toggle-episode-watched(id) => { details-toggle-episode-watched(id); }
                        episode-search-changed(q) => {
                            detail-episode-search-query = q;
                            details-episode-search-changed(q);
                        }

                        copy-stream-link(id) => { details-copy-stream-link(id); }
                        copy-magnet-link(id) => { details-copy-magnet-link(id); }
                        copy-download-link(id) => { details-copy-download-link(id); }
                        toggle-season-watched(s) => { details-toggle-season-watched(s); }

                        play-stream(selection-id) => { play-stream(selection-id); }
                        toggle-fullscreen => { root.player-toggle-fullscreen(); }
                        close => { show-details = false; }
                    }

                    if (!show-details && active-tab == 0) : BoardPage {
                        continue-watching: board-continue-watching;
                        sections: board-sections;
                        loading: loading;
                        item-selected(id, media-type, video-id) => {
                            board-item-selected(id, media-type, video-id);
                        }
                        remove-continue-watching(id) => { remove-continue-watching(id); }
                        see-all-continue-watching() => { board-see-all-continue-watching(); }
                        see-all-clicked(t, id, base) => { board-see-all-clicked(t, id, base); }
                        poster-requested(url) => { request-poster(url); }
                    }

                    if (!show-details && active-tab == 1) : DiscoverPage {
                        rows: discover-rows;
                        column-count: discover-column-count;
                        loading: loading;

                        available-types: discover-types;
                        active-type: discover-active-type;
                        available-catalogs: discover-catalogs;
                        active-catalog: discover-active-catalog;
                        available-genres: discover-genres;
                        active-genre: discover-active-genre;

                        has-preview: discover-has-preview;
                        preview-title: discover-preview-title;
                        preview-description: discover-preview-description;
                        preview-rating: discover-preview-rating;
                        preview-year: discover-preview-year;
                        preview-runtime: discover-preview-runtime;
                        preview-genres: discover-preview-genres;
                        preview-cast: discover-preview-cast;
                        preview-directors: discover-preview-directors;
                        preview-is-in-library: discover-preview-is-in-library;
                        preview-is-watched: discover-preview-is-watched;
                        preview-has-trailer: discover-preview-has-trailer;
                        preview-trailer-selection-id: detail-trailer-selection-id;
                        preview-poster: discover-preview-poster;

                        type-changed(t) => { discover-type-changed(t); }
                        catalog-changed(c) => { discover-catalog-changed(c); }
                        genre-changed(g) => { discover-genre-changed(g); }
                        item-selected(id) => { discover-item-selected(id); }
                        poster-requested(url) => { request-poster(url); }
                        play-preview => { play-preview(); }
                        toggle-library-preview => { toggle-library-preview(); }
                        toggle-watched-preview => { details-toggle-watched(); }
                        play-trailer-preview(selection-id) => { play-stream(selection-id); }
                        scroll-y: discover-scroll-y;
                    }

                    if (!show-details && active-tab == 2) : LibraryPage {
                        rows: library-rows;
                        column-count: library-column-count;
                        loading: loading;
                        active-type: library-active-type;
                        active-sort: library-active-sort;

                        type-changed(t) => { library-type-changed(t); }
                        sort-changed(s) => { library-sort-changed(s); }
                        item-selected(id) => { library-item-selected(id); }
                        poster-requested(url) => { request-poster(url); }
                        scroll-y: library-scroll-y;
                    }

                    if (!show-details && active-tab == 3) : AddonsPage {
                        addons: addons-list;
                        search-query: addons-search-query;
                        loading: loading;
                        details-open: addon-details-open;
                        details-addon: addon-details-addon;
                        details-loading: addon-details-loading;
                        details-error: addon-details-error;
                        details-configurable: addon-details-configurable;
                        details-configuration-required: addon-details-configuration-required;
                        install-addon(url) => { install-addon(url); }
                        uninstall-addon(url) => { uninstall-addon(url); }
                        open-addon-details(url) => { open-addon-details(url); }
                        close-addon-details => { close-addon-details(); }
                        configure-addon(url) => { configure-addon(url); }
                        share-addon(url) => { share-addon(url); }
                        search-changed(query) => { addons-search-changed(query); }
                    }

                    if (!show-details && active-tab == 4) : SettingsPage {
                        torrent-cache-size: torrent-cache-size;
                        server-url: server-url;
                        interface-language: settings-interface-language;
                        subtitles-language: settings-subtitles-language;
                        torrent-profile: settings-torrent-profile;
                        hardware-acceleration: settings-hardware-acceleration;
                        binge-watching: settings-binge-watching;
                        hide-spoilers: settings-hide-spoilers;
                        gamepad-support: settings-gamepad-support;
                        play-in-background: settings-play-in-background;
                        subtitles-auto-select: settings-subtitles-auto-select;
                        subtitles-font: settings-subtitles-font;
                        subtitles-size: settings-subtitles-size;
                        subtitles-bold: settings-subtitles-bold;
                        subtitles-offset: settings-subtitles-offset;
                        seek-duration: settings-seek-duration;
                        pause-on-minimize: settings-pause-on-minimize;
                        quit-on-close: settings-quit-on-close;
                        export-loading: settings-export-loading;
                        export-status: settings-export-status;

                        streaming-seeding: settings-streaming-seeding;
                        streaming-dht: settings-streaming-dht;
                        streaming-pex: settings-streaming-pex;
                        streaming-lsd: settings-streaming-lsd;
                        streaming-remote-url: settings-streaming-remote-url;
                        streaming-logs-text: settings-streaming-logs-text;
                        refresh-icon: refresh-icon;
                        folder-icon: folder-icon;

                        apply-cache-settings(val) => { apply-cache-settings(val); }
                        change-interface-language(lang) => { settings-change-interface-language(lang); }
                        change-subtitles-language(lang) => { settings-change-subtitles-language(lang); }
                        change-torrent-profile(prof) => { settings-change-torrent-profile(prof); }
                        change-hardware-acceleration(val) => { settings-change-hardware-acceleration(val); }
                        clear-search-history => { settings-clear-search-history(); }
                        shutdown-server => { shutdown-server(); }

                        change-seeding-enabled(val) => { settings-change-seeding-enabled(val); }
                        change-dht-enabled(val) => { settings-change-dht-enabled(val); }
                        change-pex-enabled(val) => { settings-change-pex-enabled(val); }
                        change-lsd-enabled(val) => { settings-change-lsd-enabled(val); }
                        refresh-logs => { settings-refresh-logs(); }
                        open-logs-folder => { settings-open-logs-folder(); }
                        export-data => { settings-export-data(); }
                        change-binge-watching(val) => { settings-change-binge-watching(val); }
                        change-hide-spoilers(val) => { settings-change-hide-spoilers(val); }
                        change-gamepad-support(val) => { settings-change-gamepad-support(val); }
                        change-play-in-background(val) => { settings-change-play-in-background(val); }
                        change-subtitles-auto-select(val) => { settings-change-subtitles-auto-select(val); }
                        change-subtitles-font(val) => { settings-change-subtitles-font(val); }
                        change-subtitles-size(val) => { settings-change-subtitles-size(val); }
                        change-subtitles-bold(val) => { settings-change-subtitles-bold(val); }
                        change-subtitles-offset(val) => { settings-change-subtitles-offset(val); }
                        change-seek-duration(val) => { settings-change-seek-duration(val); }
                        change-pause-on-minimize(val) => { settings-change-pause-on-minimize(val); }
                        change-quit-on-close(val) => { settings-change-quit-on-close(val); }
                    }

                    if (!show-details && active-tab == 5) : CalendarPage {
                        authenticated: username != "" && username != "Guest";
                        loading: calendar-loading;
                        selected-year: calendar-selected-year;
                        selected-month: calendar-selected-month;
                        previous-month: calendar-previous-month;
                        next-month: calendar-next-month;
                        rows: calendar-rows;
                        previous => { calendar-previous(); }
                        next => { calendar-next(); }
                        item-selected(id) => { calendar-item-selected(id); }
                    }

                    if (!show-details && active-tab == 6) : SearchPage {
                        query: search-query;
                        sections: search-sections;
                        loading: search-loading;
                        catalog-count: search-catalog-count;
                        item-selected(id, media-type, video-id) => {
                            search-item-selected(id, media-type, video-id);
                        }
                        poster-requested(url) => { request-poster(url); }
                    }
                }
            }
        }
        }
        }

        if (show-player) : PlayerPage {
            width: 100%;
            height: 100%;
            z: 1000;
            
            item-title: player-title;
            stream-name: player-stream-name;
            poster-image: player-poster-image;
            video-frame: player-video-frame;
            has-video-frame: player-has-video-frame;
            loading: player-loading;
            buffering: player-buffering;
            buffering-percent: player-buffering-percent;
            paused: player-paused;
            volume: player-volume;
            muted: player-muted;
            progress: player-progress;
            elapsed-time-str: player-elapsed-time-str;
            total-time-str: player-total-time-str;
            subtitles-tracks: player-subtitles-tracks;
            subtitle-track-languages: player-subtitle-track-languages;
            subtitle-track-origins: player-subtitle-track-origins;
            subtitle-languages: player-subtitle-languages;
            subtitle-language-track-indices: player-subtitle-language-track-indices;
            audio-tracks: player-audio-tracks;
            audio-track-languages: player-audio-track-languages;
            audio-track-labels: player-audio-track-labels;
            active-subtitle-idx: player-active-subtitle-idx;
            active-audio-idx: player-active-audio-idx;
            subtitle-delay-seconds: player-subtitle-delay-seconds;
            subtitle-size-percent: player-subtitle-size-percent;
            subtitle-offset-percent: player-subtitle-offset-percent;
            is-series: player-is-series;
            episode-names: player-episode-names;
            active-episode-idx: player-active-episode-idx;
            playback-speed: player-playback-speed;
            video-scale-mode: player-video-scale-mode;
            error-message: player-error;
            video-format: player-video-format;
            audio-format: player-audio-format;
            file-format: player-file-format;
            hardware-decoder: player-hwdec;
            buffered-percent: player-buffered-percent;
            download-speed: player-download-speed;
            upload-speed: player-upload-speed;
            peer-count: player-peer-count;
            stream-progress: player-stream-progress;
            seek-step-seconds: player-seek-step-seconds;
            
            icon-play: icon-play;
            icon-pause: icon-pause;
            icon-next: icon-next;
            icon-volume-high: icon-volume-high;
            icon-volume-low: icon-volume-low;
            icon-volume-mute: icon-volume-mute;
            icon-fullscreen: icon-fullscreen;
            icon-subtitles: icon-subtitles;
            icon-audio: icon-audio;
            icon-speed: icon-speed;
            icon-stats: icon-stats;
            icon-options: icon-options;
            icon-menu: icon-menu;
            icon-back: icon-back;
            
            toggle-pause => { player-toggle-pause(); }
            seek(val) => { player-seek(val); }
            seek-relative(seconds) => { player-seek-relative(seconds); }
            change-volume(val) => { player-change-volume(val); }
            toggle-mute => { player-toggle-mute(); }
            change-subtitle(idx) => { player-change-subtitle(idx); }
            change-audio(idx) => { player-change-audio(idx); }
            change-subtitle-delay(value) => { player-change-subtitle-delay(value); }
            change-subtitle-size(value) => { player-change-subtitle-size(value); }
            change-subtitle-offset(value) => { player-change-subtitle-offset(value); }
            change-speed(val) => { player-change-speed(val); }
            change-video-scale(mode) => { player-change-video-scale(mode); }
            copy-stream-link => { player-copy-stream-link(); }
            download-video => { player-download-video(); }
            play-episode(idx) => { player-play-episode(idx); }
            toggle-fullscreen => { player-toggle-fullscreen(); }
            close => { player-close(); }
        }
    }
}
