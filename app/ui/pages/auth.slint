import { Theme, IconData } from "../theme.slint";

component CredentialsInput inherits Rectangle {
    in-out property <string> text;
    in property <string> placeholder-text;
    in property <bool> is-password: false;
    in property <length> unit: 16px;

    callback accepted;
    callback edited;

    public function focus-input() {
        editor.focus();
    }

    height: 3.2 * root.unit;
    border-radius: 0.75 * root.unit;
    border-width: editor.has-focus ? Theme.focus-outline-size : 0px;
    border-color: Theme.overlay;
    background: Theme.overlay;

    if (root.text == "") : Text {
        x: root.unit;
        width: parent.width - 2 * root.unit;
        height: parent.height;
        text: root.placeholder-text;
        color: Theme.text-secondary;
        opacity: 0.6;
        font-size: root.unit;
        vertical-alignment: center;
        overflow: elide;
    }

    editor := TextInput {
        x: root.unit;
        width: parent.width - 2 * root.unit;
        height: parent.height;
        text <=> root.text;
        input-type: root.is-password ? InputType.password : InputType.text;
        color: Theme.text-primary;
        font-size: root.unit;
        vertical-alignment: center;
        single-line: true;
        accepted => { root.accepted(); }
        edited => { root.edited(); }
    }
}

component StremioButton inherits Rectangle {
    in property <string> label;
    in property <length> unit: 16px;
    in property <bool> enabled: true;
    in property <bool> outlined: false;
    in property <bool> has-icon: false;
    in property <IconData> icon;
    in property <brush> fill: transparent;
    in property <brush> normal-foreground: Theme.text-primary;
    in property <brush> hover-foreground: Theme.background;
    in property <brush> outline-color: Theme.text-primary;

    callback clicked;

    height: 4 * root.unit;
    // CSS clamps an oversized radius to half the element height. Slint does
    // not, so express the clamped value directly to keep a true capsule.
    border-radius: self.height / 2;
    border-width: root.outlined || button-area.has-hover ? Theme.focus-outline-size : 0px;
    border-color: root.outline-color;
    background: button-area.has-hover ? (root.outlined ? root.outline-color : transparent) : root.fill;
    opacity: root.enabled ? 1 : 0.4;

    animate background, opacity { duration: 100ms; }

    button-area := TouchArea {
        enabled: root.enabled;
        clicked => { root.clicked(); }
    }

    HorizontalLayout {
        alignment: center;
        spacing: root.unit;
        padding-left: root.unit;
        padding-right: root.unit;

        if (root.has-icon) : Text {
            width: 2 * root.unit;
            text: root.icon.glyph;
            font-family: root.icon.font-family;
            font-size: 2 * root.unit;
            color: button-area.has-hover ? root.hover-foreground : root.normal-foreground;
            horizontal-alignment: center;
            vertical-alignment: center;
            animate color { duration: 120ms; }
        }

        Text {
            text: root.label;
            color: button-area.has-hover ? root.hover-foreground : root.normal-foreground;
            font-size: 1.1 * root.unit;
            font-weight: 700;
            horizontal-alignment: center;
            vertical-alignment: center;
            overflow: elide;
            animate color { duration: 120ms; }
        }
    }
}

component StremioCheckbox inherits Rectangle {
    in-out property <bool> checked;
    in property <string> label;
    in property <string> link-label: "";
    in property <length> unit: 16px;

    callback toggled;

    height: 2.5 * root.unit;
    // The official checkbox row intentionally stays on one line. Clamp it to
    // the form column so localized/legal copy can never cover the options.
    clip: true;

    checkbox-area := TouchArea {
        clicked => {
            root.checked = !root.checked;
            root.toggled();
        }
    }

    Rectangle {
        x: 0.3 * root.unit;
        y: (parent.height - self.height) / 2;
        width: 1.5 * root.unit;
        height: 1.5 * root.unit;
        border-radius: 0.3 * root.unit;
        border-width: checkbox-area.has-hover ? Theme.focus-outline-size : 0px;
        border-color: #ffffff33;
        background: root.checked ? Theme.accent : Theme.overlay;

        animate background { duration: 100ms; }

        if (root.checked) : Text {
            text: "✓";
            color: Theme.text-primary;
            font-size: 0.9 * root.unit;
            font-weight: 700;
            horizontal-alignment: center;
            vertical-alignment: center;
        }
    }

    HorizontalLayout {
        x: 2.8 * root.unit;
        width: parent.width - 2.8 * root.unit;
        height: parent.height;
        spacing: 0.35 * root.unit;
        alignment: start;

        Text {
            text: root.label;
            color: Theme.text-primary;
            opacity: 0.6;
            font-size: 0.8 * root.unit;
            vertical-alignment: center;
            overflow: elide;
            wrap: word-wrap;
        }

        if (root.link-label != "") : Text {
            text: root.link-label;
            color: Theme.accent;
            font-size: 0.8 * root.unit;
            vertical-alignment: center;
            overflow: elide;
        }
    }
}

component BrandHeader inherits Rectangle {
    in property <length> unit: 16px;
    in property <bool> left-aligned: false;

    height: 13.9 * root.unit;
    background: transparent;

    Image {
        x: root.left-aligned ? 0px : (parent.width - self.width) / 2;
        y: 0px;
        width: 17.18 * root.unit;
        height: 5 * root.unit;
        source: @image-url("../assets/images/logo.png");
        image-fit: contain;
        opacity: 0.9;
    }

    Text {
        x: 0px;
        y: 8 * root.unit;
        width: parent.width;
        height: 3.6 * root.unit;
        text: "Freedom to Stream";
        color: Theme.text-primary;
        font-size: 3 * root.unit;
        font-weight: 600;
        horizontal-alignment: root.left-aligned ? left : center;
    }

    Text {
        x: 0px;
        y: 12.1 * root.unit;
        width: parent.width;
        height: 1.8 * root.unit;
        text: "All the video content you enjoy in one place";
        color: Theme.text-primary;
        opacity: 0.6;
        font-size: 1.5 * root.unit;
        font-weight: 400;
        horizontal-alignment: root.left-aligned ? left : center;
    }
}

component FormSection inherits VerticalLayout {
    in-out property <string> email;
    in-out property <string> password;
    in-out property <string> confirm-password;
    in-out property <bool> tos-accepted;
    in-out property <bool> privacy-accepted;
    in-out property <bool> marketing-accepted;
    in property <bool> register-mode: false;
    in property <string> error-message;
    in property <bool> loading: false;
    in property <length> unit: 16px;

    callback submit;
    callback forgot-password;
    callback edited;

    spacing: root.unit;
    alignment: start;

    CredentialsInput {
        unit: root.unit;
        text <=> root.email;
        placeholder-text: "E-mail";
        accepted => { password-input.focus-input(); }
        edited => { root.edited(); }
    }

    password-input := CredentialsInput {
        unit: root.unit;
        text <=> root.password;
        placeholder-text: "Password";
        is-password: true;
        accepted => {
            if (!root.register-mode) {
                root.submit();
            }
        }
        edited => { root.edited(); }
    }

    if (root.register-mode) : confirm-input := CredentialsInput {
        unit: root.unit;
        text <=> root.confirm-password;
        placeholder-text: "Confirm password";
        is-password: true;
        accepted => { root.submit(); }
        edited => { root.edited(); }
    }

    if (!root.register-mode) : Rectangle {
        height: 2.2 * root.unit;

        Text {
            x: parent.width - self.width;
            height: parent.height;
            text: "Forgot password?";
            color: Theme.text-primary;
            font-size: root.unit;
            vertical-alignment: center;

            TouchArea {
                mouse-cursor: pointer;
                clicked => { root.forgot-password(); }
            }
        }
    }

    if (root.register-mode) : VerticalLayout {
        spacing: 0px;

        StremioCheckbox {
            unit: root.unit;
            checked <=> root.tos-accepted;
            
            label: "I have read and agree with the Stremio";
            link-label: "Terms and Conditions";
            toggled => { root.edited(); }
        }

        StremioCheckbox {
            unit: root.unit;
            checked <=> root.privacy-accepted;
            label: "I have read and agree with the Stremio";
            link-label: "Privacy Policy";
            toggled => { root.edited(); }
        }

        StremioCheckbox {
            unit: root.unit;
            checked <=> root.marketing-accepted;
            label: "I agree to receive marketing communications from Stremio";
            toggled => { root.edited(); }
        }
    }

    if (root.error-message != "") : Text {
        text: root.error-message;
        color: Theme.warning;
        font-size: root.unit;
        horizontal-alignment: center;
        wrap: word-wrap;
    }

    StremioButton {
        unit: root.unit;
        label: root.register-mode ? "Sign up" : "Log in";
        enabled: !root.loading;
        outlined: true;
        clicked => { root.submit(); }
    }
}

component OptionsSection inherits VerticalLayout {
    in property <bool> register-mode: false;
    in property <bool> loading: false;
    in property <length> unit: 16px;
    in property <IconData> facebook-icon;
    in property <IconData> apple-icon;

    callback toggle-mode;
    callback facebook-login;
    callback apple-login;
    callback guest-login;

    spacing: root.unit;
    alignment: start;

    StremioButton {
        unit: root.unit;
        label: "Continue with Facebook";
        enabled: !root.loading;
        has-icon: true;
        icon: root.facebook-icon;
        fill: Theme.facebook;
        outline-color: Theme.facebook;
        normal-foreground: Theme.text-primary;
        hover-foreground: Theme.facebook;
        clicked => { root.facebook-login(); }
    }

    StremioButton {
        unit: root.unit;
        label: "Continue with Apple";
        enabled: !root.loading;
        has-icon: true;
        icon: root.apple-icon;
        fill: Theme.text-primary;
        outline-color: Theme.text-primary;
        normal-foreground: Theme.background;
        hover-foreground: Theme.text-primary;
        clicked => { root.apple-login(); }
    }

    StremioButton {
        unit: root.unit;
        label: root.register-mode ? "Log in" : "Sign up with email";
        enabled: !root.loading;
        outlined: true;
        clicked => { root.toggle-mode(); }
    }

    if (root.register-mode) : StremioButton {
        unit: root.unit;
        label: "Guest login";
        enabled: !root.loading;
        outlined: true;
        clicked => { root.guest-login(); }
    }
}

export component AuthPage inherits Rectangle {
    in-out property <string> error-message: "";
    in property <bool> loading: false;
    in property <IconData> mail-icon;
    in property <IconData> lock-icon;
    in property <IconData> facebook-icon;
    in property <IconData> apple-icon;

    out property <string> email: email-text;
    out property <string> password: password-text;
    in-out property <bool> tos-accepted: false;
    in-out property <bool> privacy-accepted: false;
    in-out property <bool> marketing-accepted: false;
    in-out property <bool> register-mode: false;

    callback submit-login(string, string);
    callback submit-register(string, string, bool, bool, bool);
    callback facebook-login();
    callback apple-login();
    callback cancel-auth();
    callback request-password-reset(string);
    callback guest-login();

    property <string> email-text: "";
    property <string> password-text: "";
    property <string> confirm-password-text: "";
    property <bool> reset-open: false;
    property <string> reset-email: "";
    property <string> reset-error: "";
    property <bool> is-wide: root.width > 1000px;
    property <length> unit: root.width > 2800px ? 18px :
        (root.width > 2200px ? 16px : (root.width > 1600px ? 15px : 14px));
    property <length> compact-height: root.register-mode ? 74 * root.unit : 60 * root.unit;

    background: Theme.background;

    Image {
        width: parent.width;
        height: parent.height;
        // Pre-rasterized from intro-background.svg so FemtoVG never evaluates
        // the 6rem Gaussian blur during hover, input, or layout frames.
        source: @image-url("../assets/images/intro-background.png");
        image-fit: cover;
    }

    auth-scroll := Flickable {
        width: parent.width;
        height: parent.height;
        viewport-width: root.width;
        viewport-height: root.is-wide ? root.height :
            (root.height > root.compact-height ? root.height : root.compact-height);

        if (root.is-wide) : VerticalLayout {
            width: root.width;
            height: root.height;
            spacing: 0px;
            alignment: center;

            BrandHeader {
                width: root.width;
                unit: root.unit;
            }
            Rectangle { height: 5 * root.unit; }

            Rectangle {
                width: root.width;
                height: wide-content.preferred-height;
                background: transparent;

                wide-content := HorizontalLayout {
                    x: (parent.width - self.width) / 2;
                    width: 48 * root.unit;
                    spacing: 4 * root.unit;
                    alignment: start;

                    FormSection {
                        width: 22 * root.unit;
                        unit: root.unit;
                        email <=> root.email-text;
                        password <=> root.password-text;
                        confirm-password <=> root.confirm-password-text;
                        tos-accepted <=> root.tos-accepted;
                        privacy-accepted <=> root.privacy-accepted;
                        marketing-accepted <=> root.marketing-accepted;
                        register-mode: root.register-mode;
                        error-message: root.error-message;
                        loading: root.loading;
                        edited => { root.error-message = ""; }
                        forgot-password => {
                            root.reset-email = root.email-text;
                            root.reset-error = "";
                            root.reset-open = true;
                        }
                        submit => { root.submit-current-form(); }
                    }

                    OptionsSection {
                        width: 22 * root.unit;
                        unit: root.unit;
                        register-mode: root.register-mode;
                        loading: root.loading;
                        facebook-icon: root.facebook-icon;
                        apple-icon: root.apple-icon;
                        toggle-mode => { root.switch-form(); }
                        facebook-login => { root.facebook-login(); }
                        apple-login => { root.apple-login(); }
                        guest-login => { root.guest-login(); }
                    }
                }
            }
        }

        if (!root.is-wide) : VerticalLayout {
            width: root.width;
            height: auth-scroll.viewport-height;
            padding-top: 3 * root.unit;
            padding-bottom: 3 * root.unit;
            padding-left: 1.5 * root.unit;
            padding-right: 1.5 * root.unit;
            spacing: 0px;
            alignment: start;

            BrandHeader {
                width: root.width - 3 * root.unit;
                unit: root.unit;
                left-aligned: true;
            }
            Rectangle { height: 4 * root.unit; }

            OptionsSection {
                width: root.width <= 640px ? root.width - 3 * root.unit : 0.5 * (root.width - 3 * root.unit);
                unit: root.unit;
                register-mode: root.register-mode;
                loading: root.loading;
                facebook-icon: root.facebook-icon;
                apple-icon: root.apple-icon;
                toggle-mode => { root.switch-form(); }
                facebook-login => { root.facebook-login(); }
                apple-login => { root.apple-login(); }
                guest-login => { root.guest-login(); }
            }
            Rectangle { height: 4 * root.unit; }

            FormSection {
                width: root.width <= 640px ? root.width - 3 * root.unit : 0.5 * (root.width - 3 * root.unit);
                unit: root.unit;
                email <=> root.email-text;
                password <=> root.password-text;
                confirm-password <=> root.confirm-password-text;
                tos-accepted <=> root.tos-accepted;
                privacy-accepted <=> root.privacy-accepted;
                marketing-accepted <=> root.marketing-accepted;
                register-mode: root.register-mode;
                error-message: root.error-message;
                loading: root.loading;
                edited => { root.error-message = ""; }
                forgot-password => {
                    root.reset-email = root.email-text;
                    root.reset-error = "";
                    root.reset-open = true;
                }
                submit => { root.submit-current-form(); }
            }
        }
    }

    if (root.reset-open) : Rectangle {
        background: #00000066;

        TouchArea { clicked => { } }

        dialog := Rectangle {
            width: root.width <= 640px ? 0.9 * root.width : 34 * root.unit;
            height: 19 * root.unit;
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            border-radius: 0.75 * root.unit;
            background: Theme.modal-background;

            VerticalLayout {
                padding-left: 2 * root.unit;
                padding-right: 2 * root.unit;
                spacing: 0px;

                Text {
                    height: 4.5 * root.unit;
                    text: "Password reset";
                    color: Theme.text-primary;
                    font-size: 1.2 * root.unit;
                    font-weight: 500;
                    vertical-alignment: center;
                }

                Rectangle { height: 2 * root.unit; }

                CredentialsInput {
                    unit: root.unit;
                    text <=> root.reset-email;
                    placeholder-text: "E-mail";
                    edited => { root.reset-error = ""; }
                    accepted => { root.send-password-reset(); }
                }

                if (root.reset-error != "") : Text {
                    height: 2 * root.unit;
                    text: root.reset-error;
                    color: Theme.warning;
                    font-size: 1.1 * root.unit;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }

                Rectangle { vertical-stretch: 1; }

                HorizontalLayout {
                    height: 3.5 * root.unit;
                    spacing: root.unit;

                    StremioButton {
                        unit: root.unit;
                        label: "Cancel";
                        outlined: true;
                        clicked => { root.reset-open = false; }
                    }
                    StremioButton {
                        unit: root.unit;
                        label: "Send";
                        fill: Theme.accent;
                        outline-color: Theme.accent;
                        normal-foreground: Theme.text-primary;
                        hover-foreground: Theme.accent;
                        clicked => { root.send-password-reset(); }
                    }
                }

                Rectangle { height: 2 * root.unit; }
            }

            Text {
                x: parent.width - 3.5 * root.unit;
                y: 0.5 * root.unit;
                width: 3 * root.unit;
                height: 3 * root.unit;
                text: "×";
                color: Theme.text-secondary;
                font-size: 2 * root.unit;
                horizontal-alignment: center;
                vertical-alignment: center;
                TouchArea {
                    mouse-cursor: pointer;
                    clicked => { root.reset-open = false; }
                }
            }
        }
    }

    if (root.loading) : Rectangle {
        background: #00000066;

        Rectangle {
            width: 16 * root.unit;
            height: 19 * root.unit;
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            border-radius: 0.75 * root.unit;
            background: Theme.modal-background;

            VerticalLayout {
                padding: 2.5 * root.unit;
                spacing: root.unit;
                alignment: center;

                Image {
                    width: 5 * root.unit;
                    height: 5 * root.unit;
                    source: @image-url("../assets/images/anonymous.png");
                    image-fit: contain;
                    opacity: 0.8;
                }
                Text {
                    text: "Authenticating";
                    color: Theme.text-primary;
                    font-size: 1.5 * root.unit;
                    horizontal-alignment: center;
                }
                Rectangle { height: root.unit; }
                StremioButton {
                    unit: root.unit;
                    label: "Cancel";
                    outlined: true;
                    clicked => { root.cancel-auth(); }
                }
            }
        }
    }

    function switch-form() {
        root.register-mode = !root.register-mode;
        root.email-text = "";
        root.password-text = "";
        root.confirm-password-text = "";
        root.tos-accepted = false;
        root.privacy-accepted = false;
        root.marketing-accepted = false;
        root.error-message = "";
    }

    function submit-current-form() {
        if (root.email-text == "") {
            root.error-message = "Invalid email";
            return;
        }
        if (root.password-text == "") {
            root.error-message = "Invalid password";
            return;
        }
        if (root.register-mode) {
            if (root.confirm-password-text != root.password-text) {
                root.error-message = "Passwords do not match";
                return;
            }
            if (!root.tos-accepted) {
                root.error-message = "You must accept the Terms and Conditions";
                return;
            }
            if (!root.privacy-accepted) {
                root.error-message = "You must accept the Privacy Policy";
                return;
            }
            root.submit-register(
                root.email-text,
                root.password-text,
                root.tos-accepted,
                root.privacy-accepted,
                root.marketing-accepted
            );
        } else {
            root.submit-login(root.email-text, root.password-text);
        }
    }

    function send-password-reset() {
        if (root.reset-email == "") {
            root.reset-error = "Invalid email";
            return;
        }
        root.request-password-reset(root.reset-email);
    }
}
