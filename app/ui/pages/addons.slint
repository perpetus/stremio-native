import { ListView, ScrollView } from "std-widgets.slint";
import { Theme } from "../theme.slint";
import { IconAction, PillButton } from "../components/button.slint";
import { EmptyState, SkeletonBlock } from "../components/feedback.slint";
import { AddonCardPlaceholder } from "../components/loading_placeholders.slint";
import { SelectField } from "../components/select.slint";
import { NativeTextField, SearchBar } from "../components/text_input.slint";

export struct AddonItem {
    id: string,
    name: string,
    version: string,
    description: string,
    logo-url: string,
    logo: image,
    is_installed: bool,
    transport-url: string,
    types-label: string,
    configurable: bool,
    configuration-required: bool,
    supports-movie: bool,
    supports-series: bool,
    supports-anime: bool,
    supports-tv: bool,
}

component AddonCard inherits Rectangle {
    in property <length> unit: 16px;
    in property <AddonItem> addon;
    callback install;
    callback uninstall;
    callback details;
    callback configure;
    callback share;

    property <length> card-padding: 1.5 * root.unit;
    property <length> logo-size: 8 * root.unit;
    property <length> actions-width: 17 * root.unit;

    height: 11 * root.unit;
    border-radius: 0.75 * root.unit;
    border-width: 0.15 * root.unit;
    border-color: card-area.has-hover ? Theme.overlay : transparent;
    background: Theme.overlay;

    card-area := TouchArea {
        mouse-cursor: pointer;
        clicked => { root.details(); }
    }

    Rectangle {
        x: root.card-padding;
        y: root.card-padding;
        width: root.logo-size;
        height: root.logo-size;
        background: transparent;

        if (root.addon.logo.width > 0) : Image {
            x: 0.5 * root.unit;
            y: 0.5 * root.unit;
            width: parent.width - root.unit;
            height: parent.height - root.unit;
            source: root.addon.logo;
            image-fit: contain;
        }

        if (root.addon.logo.width == 0) : Image {
            x: root.unit;
            y: root.unit;
            width: parent.width - 2 * root.unit;
            height: parent.height - 2 * root.unit;
            source: @image-url("../assets/images/icons/addons.svg");
            colorize: Theme.text-primary;
            opacity: 0.35;
            image-fit: contain;
        }
    }

    // The official card reserves a fixed 17rem action column at the far
    // right. Explicit anchors avoid the content-sized Slint layout that used
    // to leave the buttons stranded near the middle of wide windows.
    VerticalLayout {
        x: root.card-padding + root.logo-size + 1.5 * root.unit;
        y: root.card-padding;
        width: max(0px, root.width - self.x - root.actions-width - 3 * root.unit);
        height: root.height - 2 * root.card-padding;
        spacing: 0.5 * root.unit;
        alignment: center;

        HorizontalLayout {
            height: 2.25 * root.unit;
            spacing: 0.5 * root.unit;
            alignment: start;
            Text {
                text: root.addon.name;
                color: Theme.text-primary;
                font-size: 1.6 * root.unit;
                font-weight: 500;
                vertical-alignment: center;
                overflow: elide;
            }
            Text {
                text: root.addon.version;
                color: Theme.text-primary;
                opacity: 0.6;
                font-size: root.unit;
                vertical-alignment: center;
            }
        }

        Text {
            text: root.addon.types-label;
            color: Theme.text-primary;
            opacity: 0.4;
            font-size: root.unit;
        }

        Text {
            text: root.addon.description;
            color: Theme.text-primary;
            opacity: 0.7;
            font-size: root.unit;
            wrap: word-wrap;
            overflow: elide;
        }
    }

    // The web app reserves an exact 17rem action column. Absolute positions
    // here keep the 3.5rem controls and 1.5rem share icon stable at every card
    // width instead of allowing the layout engine to content-size them.
    Rectangle {
        x: root.width - root.card-padding - root.actions-width;
        y: root.card-padding;
        width: root.actions-width;
        height: root.height - 2 * root.card-padding;
        background: transparent;

        Rectangle {
            x: 0px;
            y: 0px;
            width: root.actions-width;
            height: 3.5 * root.unit;
            background: transparent;

            if (root.addon.configurable && !root.addon.configuration-required) : IconAction {
                x: 0px;
                y: 0px;
                width: 3.5 * root.unit;
                height: 3.5 * root.unit;
                unit: root.unit;
                label: "Configure addon";
                icon-size: 1.7 * root.unit;
                icon-source: @image-url("../assets/images/icons/settings.svg");
                surface-color: Theme.success;
                clicked => { root.configure(); }
            }

            PillButton {
                x: root.addon.configurable && !root.addon.configuration-required
                    ? 4.5 * root.unit : 0px;
                y: 0px;
                width: root.addon.configurable && !root.addon.configuration-required
                    ? root.actions-width - 4.5 * root.unit : root.actions-width;
                height: 3.5 * root.unit;
                unit: root.unit;
                label: root.addon.is-installed ? "Uninstall" :
                    (root.addon.configuration-required ? "Configure" : "Install");
                outlined: root.addon.is-installed;
                primary: !root.addon.is-installed;
                accent-color: Theme.success;
                surface-color: transparent;
                hover-color: Theme.overlay;
                outline-color: root.addon.is-installed ? Theme.text-primary : Theme.success;
                hover-outline-color: root.addon.is-installed ? Theme.text-primary : Theme.success;
                idle-opacity: root.addon.is-installed ? 0.35 : 1;
                clicked => {
                    if (root.addon.is-installed) { root.uninstall(); }
                    else if (root.addon.configuration-required) { root.configure(); }
                    else { root.install(); }
                }
            }
        }

        PillButton {
            x: 0px;
            y: 4.5 * root.unit;
            width: root.actions-width;
            height: 3.5 * root.unit;
            unit: root.unit;
            label: "Share addon";
            show-icon: true;
            use-svg-icon: true;
            icon-source: @image-url("../assets/images/icons/share.svg");
            icon-size: 1.5 * root.unit;
            label-font-size: 1.1 * root.unit;
            surface-color: transparent;
            idle-opacity: 0.9;
            clicked => { root.share(); }
        }
    }
}

export component AddonsPage inherits Rectangle {
    width: 1280px;
    height: 720px;
    in property <[AddonItem]> addons: [];
    in property <bool> loading: false;
    callback install-addon(string);
    callback uninstall-addon(string);
    callback open-addon-details(string);
    callback close-addon-details;
    callback configure-addon(string);
    callback share-addon(string);
    callback search-changed(string);

    in-out property <bool> details-open: false;
    in property <AddonItem> details-addon;
    in property <bool> details-loading: false;
    in property <string> details-error: "";
    in property <bool> details-configurable: false;
    in property <bool> details-configuration-required: false;

    in property <length> unit: Theme.root-font-size;
    in-out property <string> active-filter: "Installed";
    in-out property <string> active-type: "All";
    in-out property <bool> filter-open: false;
    in-out property <bool> type-open: false;
    in-out property <bool> add-modal-open: false;
    property <string> manifest-url: "";
    in-out property <string> search-query: "";

    background: transparent;

    VerticalLayout {
        spacing: 0px;

        Rectangle {
            height: 6 * root.unit;
            z: 50;

            HorizontalLayout {
                width: parent.width;
                height: parent.height;
                padding: 1.5 * root.unit;
                spacing: 1.5 * root.unit;

                SelectField {
                    unit: root.unit;
                    field-width: 15 * root.unit;
                    value: root.active-filter;
                    options: ["Installed", "Community"];
                    open: root.filter-open;
                    toggle => {
                        root.filter-open = !root.filter-open;
                        root.type-open = false;
                    }
                    selected(value) => {
                        root.active-filter = value;
                        root.filter-open = false;
                    }
                }

                SelectField {
                    unit: root.unit;
                    field-width: 15 * root.unit;
                    value: root.active-type;
                    options: ["All", "Movie", "Series", "Anime", "TV Channel"];
                    open: root.type-open;
                    toggle => {
                        root.type-open = !root.type-open;
                        root.filter-open = false;
                    }
                    selected(value) => {
                        root.active-type = value;
                        root.type-open = false;
                    }
                }

                Rectangle { horizontal-stretch: 1; }

                PillButton {
                    width: 10.5 * root.unit;
                    height: 3 * root.unit;
                    unit: root.unit;
                    label: "Add addon";
                    show-icon: true;
                    use-svg-icon: true;
                    icon-source: @image-url("../assets/images/icons/add.svg");
                    icon-size: 1.2 * root.unit;
                    label-font-size: root.unit;
                    primary: true;
                    accent-color: Theme.success;
                    hover-color: transparent;
                    hover-outline-color: Theme.success;
                    clicked => { root.add-modal-open = true; }
                }

                SearchBar {
                    width: 18 * root.unit;
                    height: 3 * root.unit;
                    unit: root.unit;
                    title: "Search addons";
                    text <=> root.search-query;
                    edited => { root.search-changed(root.search-query); }
                }
            }
        }

        if (root.loading) : ScrollView {
            vertical-stretch: 1;
            viewport-width: root.width;
            horizontal-scrollbar-policy: ScrollBarPolicy.always-off;

            VerticalLayout {
                width: root.width;
                padding-left: 1.5 * root.unit;
                padding-right: 1.5 * root.unit;
                padding-bottom: 1.5 * root.unit;
                spacing: 1.5 * root.unit;

                for _placeholder in [0, 1, 2, 3] : AddonCardPlaceholder {
                    horizontal-stretch: 1;
                    unit: root.unit;
                }
            }
        }

        if (!root.loading && root.addons.length == 0) : EmptyState {
            vertical-stretch: 1;
            unit: root.unit;
            icon-source: @image-url("../assets/images/icons/addons.svg");
            title: "No addons found";
            message: "Try another filter or install an addon by manifest URL.";
        }

        if (!root.loading && root.addons.length > 0) : ListView {
            vertical-stretch: 1;
            mouse-drag-pan-enabled: true;
            horizontal-scrollbar-policy: ScrollBarPolicy.always-off;

            for item in root.addons : Rectangle {
                private property <bool> matches-filter:
                    ((root.active-filter == "Installed") == item.is-installed)
                        && (root.active-type == "All"
                            || (root.active-type == "Movie" && item.supports-movie)
                            || (root.active-type == "Series" && item.supports-series)
                            || (root.active-type == "Anime" && item.supports-anime)
                            || (root.active-type == "TV Channel" && item.supports-tv));
                width: parent.width;
                height: self.matches-filter ? 12.5 * root.unit : 0px;
                clip: true;
                background: transparent;

                AddonCard {
                    visible: parent.matches-filter;
                    x: 1.5 * root.unit;
                    width: max(0px, parent.width - 3 * root.unit);
                    height: 11 * root.unit;
                    unit: root.unit;
                    addon: item;
                    install => { root.install-addon(item.transport-url); }
                    uninstall => { root.uninstall-addon(item.transport-url); }
                    details => { root.open-addon-details(item.transport-url); }
                    configure => { root.configure-addon(item.transport-url); }
                    share => { root.share-addon(item.transport-url); }
                }
            }
        }
    }

    if (root.add-modal-open) : Rectangle {
        background: #00000066;
        z: 200;
        TouchArea { clicked => { } }

        Rectangle {
            width: root.width < 600px ? 0.9 * root.width : 34 * root.unit;
            height: 17 * root.unit;
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            border-radius: 0.75 * root.unit;
            background: Theme.modal-background;

            VerticalLayout {
                padding: 2 * root.unit;
                spacing: root.unit;
                Text {
                    text: "Add addon";
                    color: Theme.text-primary;
                    font-size: 1.6 * root.unit;
                    font-weight: 500;
                }
                Text {
                    text: "Paste the HTTPS URL of an addon manifest.";
                    color: Theme.text-primary;
                    opacity: 0.6;
                    font-size: root.unit;
                }
                NativeTextField {
                    unit: root.unit;
                    text <=> root.manifest-url;
                    placeholder-text: "https://…/manifest.json";
                    accepted => {
                        if (root.manifest-url != "") {
                            root.install-addon(root.manifest-url);
                            root.add-modal-open = false;
                        }
                    }
                }
                Rectangle { vertical-stretch: 1; }
                HorizontalLayout {
                    height: 3.5 * root.unit;
                    spacing: root.unit;
                    PillButton {
                        horizontal-stretch: 1;
                        unit: root.unit;
                        label: "Cancel";
                        outlined: true;
                        clicked => { root.add-modal-open = false; }
                    }
                    PillButton {
                        horizontal-stretch: 1;
                        unit: root.unit;
                        label: "Install";
                        primary: true;
                        accent-color: Theme.success;
                        enabled: root.manifest-url != "";
                        clicked => {
                            root.install-addon(root.manifest-url);
                            root.add-modal-open = false;
                        }
                    }
                }
            }
        }
    }

    if (root.details-open) : Rectangle {
        background: #00000099;
        z: 220;

        TouchArea { clicked => { root.close-addon-details(); } }

        Rectangle {
            width: root.width < 700px ? 0.92 * root.width : 42 * root.unit;
            height: min(38 * root.unit, root.height - 4 * root.unit);
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            border-radius: root.unit;
            border-width: 1px;
            border-color: Theme.card-border;
            background: Theme.modal-background;
            clip: true;

            TouchArea { clicked => { } }

            VerticalLayout {
                padding: 2 * root.unit;
                spacing: 1.25 * root.unit;

                Text {
                    text: "Community addon";
                    color: Theme.text-primary;
                    opacity: 0.55;
                    font-size: root.unit;
                    font-weight: 600;
                }

                if (root.details-loading) : Rectangle {
                    vertical-stretch: 1;

                    SkeletonBlock {
                        x: 0px;
                        y: root.unit;
                        width: 9 * root.unit;
                        height: 9 * root.unit;
                        radius: self.width / 2;
                    }
                    SkeletonBlock { x: 11 * root.unit; y: 1.5 * root.unit; width: 18 * root.unit; height: 1.8 * root.unit; }
                    SkeletonBlock { x: 11 * root.unit; y: 4 * root.unit; width: 10 * root.unit; height: root.unit; }
                    SkeletonBlock { x: 11 * root.unit; y: 6 * root.unit; width: min(24 * root.unit, parent.width - 11 * root.unit); height: root.unit; }
                    SkeletonBlock { x: 0px; y: 12 * root.unit; width: parent.width; height: 1.2 * root.unit; }
                    SkeletonBlock { x: 0px; y: 14 * root.unit; width: parent.width * 0.8; height: 1.2 * root.unit; }
                }

                if (!root.details-loading && root.details-error != "") : Rectangle {
                    vertical-stretch: 1;
                    Text {
                        text: root.details-error;
                        color: Theme.text-secondary;
                        font-size: root.unit;
                        wrap: word-wrap;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }

                if (!root.details-loading && root.details-error == "") : VerticalLayout {
                    vertical-stretch: 1;
                    spacing: 1.25 * root.unit;

                    HorizontalLayout {
                        height: 9 * root.unit;
                        spacing: 1.5 * root.unit;

                        Rectangle {
                            width: 9 * root.unit;
                            height: 9 * root.unit;
                            border-radius: 0.75 * root.unit;
                            background: Theme.overlay;
                            Image {
                                x: root.unit;
                                y: root.unit;
                                width: parent.width - 2 * root.unit;
                                height: parent.height - 2 * root.unit;
                                source: root.details-addon.logo;
                                image-fit: contain;
                            }
                        }

                        VerticalLayout {
                            horizontal-stretch: 1;
                            alignment: center;
                            spacing: 0.5 * root.unit;
                            Text {
                                text: root.details-addon.name;
                                color: Theme.text-primary;
                                font-size: 1.8 * root.unit;
                                font-weight: 600;
                                overflow: elide;
                            }
                            Text {
                                text: root.details-addon.version;
                                color: Theme.text-secondary;
                                font-size: root.unit;
                            }
                            Text {
                                text: root.details-addon.transport-url;
                                color: Theme.text-secondary;
                                font-size: 0.85 * root.unit;
                                overflow: elide;
                            }
                        }
                    }

                    ScrollView {
                        vertical-stretch: 1;
                        mouse-drag-pan-enabled: true;
                        horizontal-scrollbar-policy: ScrollBarPolicy.always-off;
                        Text {
                            width: parent.width;
                            text: root.details-addon.description;
                            color: Theme.text-primary;
                            opacity: 0.75;
                            font-size: root.unit;
                            wrap: word-wrap;
                        }
                    }
                }

                HorizontalLayout {
                    height: 3.5 * root.unit;
                    spacing: root.unit;

                    Rectangle { horizontal-stretch: 1; }

                    PillButton {
                        width: 9 * root.unit;
                        unit: root.unit;
                        label: "Cancel";
                        outlined: true;
                        clicked => { root.close-addon-details(); }
                    }

                    if (root.details-configurable) : PillButton {
                        width: 12 * root.unit;
                        unit: root.unit;
                        label: "Configure";
                        show-icon: true;
                        use-svg-icon: true;
                        icon-source: @image-url("../assets/images/icons/settings.svg");
                        surface-color: transparent;
                        idle-opacity: 0.35;
                        clicked => { root.configure-addon(root.details-addon.transport-url); }
                    }

                    if (!root.details-loading && root.details-error == "" &&
                        (root.details-addon.is-installed || !root.details-configuration-required)) : PillButton {
                        width: 12 * root.unit;
                        unit: root.unit;
                        label: root.details-addon.is-installed ? "Uninstall" : "Install";
                        show-icon: true;
                        use-svg-icon: true;
                        icon-source: root.details-addon.is-installed
                            ? @image-url("../assets/images/icons/delete.svg")
                            : @image-url("../assets/images/icons/add.svg");
                        primary: !root.details-addon.is-installed;
                        accent-color: Theme.success;
                        surface-color: transparent;
                        idle-opacity: root.details-addon.is-installed ? 0.35 : 1;
                        clicked => {
                            if (root.details-addon.is-installed) {
                                root.uninstall-addon(root.details-addon.transport-url);
                            } else {
                                root.install-addon(root.details-addon.transport-url);
                            }
                            root.close-addon-details();
                        }
                    }
                }
            }
        }
    }
}
