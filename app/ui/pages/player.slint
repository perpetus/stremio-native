import { ListView, ScrollView } from "std-widgets.slint";
import { Theme, IconData } from "../theme.slint";
import { ButtonSurface, ChevronTextButton, IconAction, MenuButton, PillButton } from "../components/button.slint";
import { Video } from "../components/media_rows.slint";
import { SeasonSelectField } from "../components/select.slint";
import { Slider } from "../components/slider.slint";
import { PopupMenuSurface, ContextMenuSurface, ContextMenuOption } from "../components/overlays.slint";
import { EpisodeItem } from "details.slint";

component PlayerIconButton inherits IconAction {
    // Kept for the legacy control tree below. The active player chrome uses
    // the exact SVG assets from stremio-icons through icon-source.
    in property <IconData> icon;
    in property <bool> disabled: false;
    in property <string> tooltip: "";

    width: 64px;
    height: 64px;
    unit: 16px;
    icon-size: 35px;
    border-radius: 12px;
    enabled: !root.disabled;
    label: root.tooltip;
    surface-color: transparent;
    hover-color: #ffffff1f;
    active-color: #ffffff1f;
    foreground-color: #ffffffdf;
    active-foreground-color: Theme.accent;
}

component TrackItem inherits ButtonSurface {
    in property <string> label;
    in property <string> secondary-label: "";
    in property <bool> active;
    in property <length> row-height: secondary-label == "" ? 56px : 64px;
    height: row-height;
    border-radius: 10px;
    background: root.has-hover
        ? (active ? #7b5bf54d : #ffffff12)
        : (active ? #7b5bf538 : transparent);
    accessible-name: root.label;

    animate background { duration: 150ms; }

    VerticalLayout {
        x: 24px;
        y: secondary-label == "" ? 0px : 10px;
        width: parent.width - 64px;
        height: secondary-label == "" ? parent.height : parent.height - 20px;
        spacing: 4px;
        alignment: center;

        Text {
            text: label;
            color: #ffffff;
            font-size: 17px;
            font-weight: active ? 600 : 400;
            vertical-alignment: center;
            overflow: elide;
        }

        if (secondary-label != "") : Text {
            text: secondary-label;
            color: #ffffff80;
            font-size: 14px;
            vertical-alignment: center;
            overflow: elide;
        }
    }

    if (active) : Rectangle {
        x: parent.width - 24px;
        y: (parent.height - 8px) / 2;
        width: 8px;
        height: 8px;
        border-radius: self.height / 2;
        background: Theme.accent;
    }
}

component PlayerMenuOption inherits MenuButton {
    unit: 14px;
    height: 56px;
    border-radius: 10px;
    show-icon: true;
    icon-size: 22px;
    label-font-size: 16px;
    horizontal-padding: 16px;
    hover-color: #ffffff1f;
    opacity: 1;
}

component SubtitleStepper inherits Rectangle {
    in property <string> label;
    in property <string> unit: "";
    in-out property <float> value;
    in property <float> step: 1.0;
    in property <float> minimum: -1000.0;
    in property <float> maximum: 1000.0;
    in property <bool> disabled: false;
    callback changed(float);

    height: 88px;
    background: transparent;
    opacity: disabled ? 0.42 : 1.0;

    VerticalLayout {
        padding-left: 24px;
        padding-right: 24px;
        padding-bottom: 16px;
        spacing: 8px;

        Text {
            height: 22px;
            text: label;
            color: #ffffff80;
            font-size: 14px;
            font-weight: 600;
            vertical-alignment: center;
            overflow: elide;
        }

        HorizontalLayout {
            height: 42px;
            spacing: 8px;
            alignment: center;

            ButtonSurface {
                width: 42px;
                height: 42px;
                border-radius: 8px;
                enabled: !root.disabled;
                accessible-name: @tr("Decrease") + " " + root.label;
                background: self.has-hover ? #ffffff1f : #ffffff0d;
                Text { text: "−"; color: #ffffff; font-size: 24px; horizontal-alignment: center; vertical-alignment: center; }
                clicked => {
                    root.value = max(root.minimum, root.value - root.step);
                    root.changed(root.value);
                }
            }

            Text {
                horizontal-stretch: 1;
                text: round(value * 100.0) / 100.0 + unit;
                color: #ffffff;
                font-size: 16px;
                font-weight: 600;
                horizontal-alignment: center;
                vertical-alignment: center;
            }

            ButtonSurface {
                width: 42px;
                height: 42px;
                border-radius: 8px;
                enabled: !root.disabled;
                accessible-name: @tr("Increase") + " " + root.label;
                background: self.has-hover ? #ffffff1f : #ffffff0d;
                Text { text: "+"; color: #ffffff; font-size: 22px; horizontal-alignment: center; vertical-alignment: center; }
                clicked => {
                    root.value = min(root.maximum, root.value + root.step);
                    root.changed(root.value);
                }
            }
        }
    }
}

export component PlayerPage inherits Rectangle {
    width: 1280px;
    height: 720px;
    in property <string> item-title: "";
    in property <string> stream-name: "";
    in property <string> info-hash: "";
    in property <image> poster-image;
    in property <image> video-frame;
    in property <bool> has-video-frame: false;
    in property <bool> loading: false;
    in property <bool> buffering: false;
    in property <float> buffering-percent: 0.0;
    in property <string> error-message: "";
    in property <string> video-format: "";
    in property <string> audio-format: "";
    in property <string> file-format: "";
    in property <string> hardware-decoder: "";
    in property <float> buffered-percent: 0.0;
    in property <string> download-speed: "";
    in property <string> upload-speed: "";
    in property <int> peer-count: 0;
    in property <float> stream-progress: 0.0;

    // Playback state bindings
    in property <bool> paused: true;
    in-out property <float> volume: 1.0;
    in property <bool> muted: false;
    in-out property <float> progress: 0.0; // 0.0 to 1.0 representation
    in property <string> elapsed-time-str: "00:00";
    in property <string> total-time-str: "00:00";
    in property <float> seek-step-seconds: 10.0;

    // Track data lists
    in property <[string]> subtitles-tracks: [];
    in property <[string]> subtitle-track-languages: [];
    in property <[string]> subtitle-track-origins: [];
    in property <[string]> subtitle-languages: [];
    in property <[int]> subtitle-language-track-indices: [];
    in property <[string]> audio-tracks: [];
    in property <[string]> audio-track-languages: [];
    in property <[string]> audio-track-labels: [];
    in-out property <int> active-subtitle-idx: -1;
    in-out property <int> active-audio-idx: 0;
    in-out property <float> subtitle-delay-seconds: 0.0;
    in-out property <float> subtitle-size-percent: 100.0;
    in-out property <float> subtitle-offset-percent: 100.0;
    
    // Episode playlist
    in property <bool> is-series: false;
    in property <[int]> available-seasons: [];
    in-out property <int> active-season: 1;
    in property <[EpisodeItem]> episodes: [];
    in-out property <string> active-video-id: "";
    in-out property <int> active-episode-idx: 0;
    in property <bool> has-next-episode: false;

    // Speed options
    in-out property <float> playback-speed: 1.0;
    in-out property <int> video-scale-mode: 0;

    in-out property <bool> show-skip-button: false;
    in-out property <string> skip-button-label: @tr("PLAYER_SKIP_INTRO" => "Skip Intro");
    callback skip-segment();

    // Icons
    in property <IconData> icon-play;
    in property <IconData> icon-pause;
    in property <IconData> icon-next;
    in property <IconData> icon-volume-high;
    in property <IconData> icon-volume-low;
    in property <IconData> icon-volume-mute;
    in property <IconData> icon-fullscreen;
    in property <IconData> icon-subtitles;
    in property <IconData> icon-audio;
    in property <IconData> icon-speed;
    in property <IconData> icon-stats;
    in property <IconData> icon-options;
    in property <IconData> icon-menu;
    in property <IconData> icon-back;

    // Callbacks to Rust
    callback toggle-pause();
    callback seek(float);
    callback seek-relative(float);
    callback change-volume(float);
    callback toggle-mute();
    callback change-subtitle(int);
    callback change-audio(int);
    callback change-subtitle-delay(float);
    callback change-subtitle-size(float);
    callback change-subtitle-offset(float);
    callback change-speed(float);
    callback change-video-scale(int);
    callback copy-stream-link();
    callback download-video();
    callback play-episode(int, string);
    callback play-next-episode();
    callback season-changed(int);
    callback season-step(int);
    callback toggle-episode-watched(string);
    callback toggle-fullscreen();
    callback close();
    callback activity();

    // Internal state
    in-out property <bool> show-subtitles-menu: false;
    in-out property <bool> show-audio-menu: false;
    in-out property <bool> show-speed-menu: false;
    in-out property <bool> show-stats-menu: false;
    in-out property <bool> show-options-menu: false;
    in-out property <bool> show-playlist-drawer: false;
    in-out property <bool> season-menu-open: false;
    in-out property <bool> show-context-menu: false;
    in-out property <length> context-menu-x: root.width * 0.52;
    in-out property <length> context-menu-y: root.height * 0.48;
    in-out property <bool> controls-visible: true;
    property <bool> buffer-pulse: false;
    property <length> buffer-logo-size: min(240px, min(root.width / 3, root.height / 3));
    property <float> buffer-visual-progress: stream-progress > 0.0
        ? stream-progress
        : buffering-percent;
    property <string> selected-subtitle-language: active-subtitle-idx >= 0 && active-subtitle-idx < subtitle-track-languages.length
        ? subtitle-track-languages[active-subtitle-idx]
        : "";

    changed show-playlist-drawer => {
        if (!root.show-playlist-drawer) {
            root.season-menu-open = false;
        }
    }

    buffering-pulse-timer := Timer {
        interval: 1s;
        running: !has-video-frame;
        triggered => { buffer-pulse = !buffer-pulse; }
    }

    background: #000000;

    // MPV renders into a same-context RGBA texture. Keeping the frame in the
    // Slint scene lets the renderer composite every control above the video.
    Image {
        source: video-frame;
        width: 100%;
        height: 100%;
        // The render target normally matches the content area, while a resize
        // can briefly expose the previous texture. `contain` prevents that
        // transitional frame from being stretched into a square or a stale
        // window aspect; libmpv still owns the video letterboxing inside it.
        image-fit: contain;
        z: 0;
    }

    // Retain the artwork only until libmpv publishes an actual decoded frame.
    // Cache state may remain active after that point and must not mask video.
    if (!has-video-frame && error-message == "") : Rectangle {
        width: 100%;
        height: 100%;
        background: #000000;
        z: 2;
        Image {
            source: poster-image;
            width: 100%;
            height: 100%;
            image-fit: cover;
            opacity: 0.35;
        }
    }

    if (error-message != "") : Rectangle {
        width: 100%;
        height: 100%;
        background: #09070ed9;
        z: 250;

        VerticalLayout {
            alignment: center;
            spacing: 14px;
            padding-left: 48px;
            padding-right: 48px;

            Text {
                text: @tr("Playback unavailable");
                color: #ffffff;
                font-size: 22px;
                font-weight: 700;
                horizontal-alignment: center;
            }
            Text {
                text: error-message;
                color: #ffffffb8;
                font-size: 14px;
                horizontal-alignment: center;
                wrap: word-wrap;
            }
            PillButton {
                width: 192px;
                unit: 16px;
                label: @tr("Back to streams");
                outlined: true;
                surface-color: transparent;
                clicked => { close(); }
            }
        }
    }

    // Interactive Screen Area (to toggle controls visibility)
    screen-touch := TouchArea {
        width: 100%;
        height: 100%;
        clicked => {
            if (show-context-menu) {
                show-context-menu = false;
                controls-visible = true;
                root.activity();
                return;
            }
            if (!show-subtitles-menu && !show-audio-menu && !show-speed-menu &&
                !show-stats-menu && !show-options-menu && !show-playlist-drawer) {
                toggle-pause();
            }
            show-subtitles-menu = false;
            show-audio-menu = false;
            show-speed-menu = false;
            show-stats-menu = false;
            show-options-menu = false;
            show-playlist-drawer = false;
            season-menu-open = false;
            
            controls-visible = true;
            root.activity();
        }
        pointer-event(event) => {
            if (event.button == PointerEventButton.right && event.kind == PointerEventKind.down) {
                context-menu-x = self.mouse-x;
                context-menu-y = self.mouse-y;
                show-context-menu = true;
                controls-visible = true;
                root.activity();
            } else if (event.kind == PointerEventKind.move) {
                controls-visible = true;
                root.activity();
            }
        }
    }

    // Big play indicator in center if paused
    if (paused && !loading) : Rectangle {
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        width: 96px;
        height: 96px;
        border-radius: self.height / 2;
        background: #0f0d20aa;
        border-width: 1px;
        border-color: #ffffff22;
        z: 40;
        
        Image {
            x: (parent.width - 42px) / 2 + 3px;
            y: (parent.height - 42px) / 2;
            width: 42px;
            height: 42px;
            source: @image-url("../assets/images/icons/play.svg");
            image-fit: contain;
            colorize: #ffffff;
        }

        TouchArea {
            clicked => { toggle-pause(); }
        }
    }

    // Match the web player: buffering is a transparent, pulsing Stremio mark.
    // The foreground fill follows torrent/cache progress while the faded mark
    // remains visible behind it. Video is never covered by an opaque scrim.
    if (!has-video-frame) : Rectangle {
        width: 100%;
        height: 100%;
        background: transparent;
        z: 20;

        buffer-mark := Rectangle {
            width: buffer-pulse ? buffer-logo-size * 1.05 : buffer-logo-size;
            height: buffer-pulse ? buffer-logo-size * 1.05 : buffer-logo-size;
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            background: transparent;
            opacity: buffer-pulse ? 1.0 : 0.4;

            animate width { duration: 1s; easing: ease-in-out; }
            animate height { duration: 1s; easing: ease-in-out; }
            animate opacity { duration: 1s; easing: ease-in-out; }

            Image {
                width: 100%;
                height: 100%;
                source: @image-url("../assets/images/stremio_symbol.png");
                image-fit: contain;
                opacity: 0.2;
            }

            Rectangle {
                width: parent.width * max(0.0, min(100.0, buffer-visual-progress)) / 100.0;
                height: parent.height;
                clip: true;
                background: transparent;

                Image {
                    width: buffer-mark.width;
                    height: buffer-mark.height;
                    source: @image-url("../assets/images/stremio_symbol.png");
                    image-fit: contain;
                }
            }
        }
    }

    // Official Stremio player navigation. These items are positioned
    // explicitly instead of being put in a nested layout so their anchors do
    // not collapse when the video texture changes size.
    if (controls-visible) : Rectangle {
        y: 0px;
        width: 100%;
        height: 128px;
        background: @linear-gradient(180deg, #00000059 0%, #00000000 100%);
        z: 150;

        PlayerIconButton {
            x: 16px;
            y: 16px;
            width: 56px;
            height: 56px;
            icon-size: 32px;
            icon-source: @image-url("../assets/images/icons/chevron-back.svg");
            tooltip: @tr("BACK" => "Back") + " (Escape)";
            clicked => { close(); }
        }

        Text {
            x: 88px;
            y: 0px;
            width: max(0px, parent.width - 176px);
            height: 88px;
            text: item-title;
            color: #ffffffe6;
            font-size: 19px;
            font-weight: 500;
            horizontal-alignment: left;
            vertical-alignment: center;
            overflow: elide;
        }

        PlayerIconButton {
            x: parent.width - 72px;
            y: 16px;
            width: 56px;
            height: 56px;
            icon-size: 32px;
            icon-source: @image-url("../assets/images/icons/maximize.svg");
            tooltip: @tr("CTX_FULLSCREEN" => "Fullscreen") + " (F)";
            clicked => { toggle-fullscreen(); }
        }
    }

    // Match the web player's side drawer: season navigation stays fixed while
    // the selected season's rich episode rows scroll independently.
    if (controls-visible && show-playlist-drawer && is-series) : playlist-drawer := Rectangle {
        x: parent.width - playlist-drawer.width;
        y: 0px;
        width: min(560px, parent.width * 0.42);
        height: parent.height;
        background: Theme.modal-background;
        border-radius: 16px;
        border-width: 1px;
        border-color: Theme.card-border;
        z: 175;
        private property <int> reveal-index: root.active-episode-idx;
        private property <int> reveal-season: root.active-season;

        init => { episode-reveal-timer.restart(); }
        changed reveal-index => { episode-reveal-timer.restart(); }
        changed reveal-season => {
            episode-list.viewport-y = 0px;
            episode-reveal-timer.restart();
        }

        episode-reveal-timer := Timer {
            interval: 1ms;
            running: false;
            triggered => {
                self.stop();
                let row-height = 104px;
                let selected-y = playlist-drawer.reveal-index * row-height;
                let centered-y = max(0px, selected-y - (episode-list.visible-height - row-height) / 2);
                let max-y = max(0px, episode-list.viewport-height - episode-list.visible-height);
                episode-list.viewport-y = -min(centered-y, max-y);
            }
        }

        VerticalLayout {
            padding: 24px;
            spacing: 8px;

            HorizontalLayout {
                height: 64px;
                spacing: 12px;
                alignment: center;

                PlayerIconButton {
                    icon-source: @image-url("../assets/images/icons/chevron-forward.svg");
                    tooltip: @tr("Close episode list");
                    clicked => {
                        show-playlist-drawer = false;
                        season-menu-open = false;
                    }
                }

                Text {
                    horizontal-stretch: 1;
                    text: item-title;
                    color: #ffffff;
                    font-size: 20px;
                    font-weight: 600;
                    vertical-alignment: center;
                    overflow: elide;
                }
            }

            if (stream-name != "") : Text {
                height: 24px;
                text: stream-name;
                color: #ffffff80;
                font-size: 14px;
                vertical-alignment: center;
                overflow: elide;
            }

            if (available-seasons.length > 0) : season-bar := Rectangle {
                height: 64px;
                background: transparent;
                z: 10000;

                ChevronTextButton {
                    x: 0px;
                    y: 8px;
                    label: @tr("BUTTON_PREV" => "Prev");
                    icon-source: @image-url("../assets/images/icons/chevron-back.svg");
                    enabled: root.active-season != root.available-seasons[0];
                    clicked => { root.season-step(-1); }
                }

                SeasonSelectField {
                    x: (parent.width - self.width) / 2;
                    y: 8px;
                    field-width: min(176px, parent.width - 232px);
                    value: root.active-season;
                    options: root.available-seasons;
                    open: root.season-menu-open;
                    surface-color: transparent;
                    toggle => { root.season-menu-open = !root.season-menu-open; }
                    selected(season) => {
                        root.active-season = season;
                        root.season-menu-open = false;
                        root.season-changed(season);
                    }
                }

                ChevronTextButton {
                    x: parent.width - self.width;
                    y: 8px;
                    label: @tr("BUTTON_NEXT" => "Next");
                    trailing-icon: true;
                    icon-source: @image-url("../assets/images/icons/chevron-forward.svg");
                    enabled: root.active-season != root.available-seasons[root.available-seasons.length - 1];
                    clicked => { root.season-step(1); }
                }
            }

            Rectangle {
                height: 1px;
                background: #ffffff1f;
            }

            episode-list := ListView {
                vertical-stretch: 1;
                horizontal-scrollbar-policy: always-off;
                mouse-drag-pan-enabled: true;

                for episode[idx] in episodes : Video {
                    width: parent.width;
                    unit: 16px;
                    title: episode.title;
                    released: episode.released;
                    thumbnail: episode.thumbnail;
                    episode-number: episode.episode-num;
                    upcoming: episode.is-upcoming;
                    watched: episode.is-watched;
                    scheduled: episode.is-scheduled;
                    progress: episode.id == root.active-video-id
                        ? root.progress * 100.0
                        : episode.progress;
                    selected-row: episode.id == root.active-video-id;
                    selected => {
                        root.active-episode-idx = idx;
                        root.active-video-id = episode.id;
                        root.play-episode(idx, episode.id);
                    }
                    toggle-watched => { root.toggle-episode-watched(episode.id); }
                }
            }
        }
    }

    if (show-skip-button) : Rectangle {
        x: parent.width - self.width - 48px;
        y: parent.height - self.height - (controls-visible ? 230px : 120px);
        width: 170px;
        height: 48px;
        background: touch-area.has-hover ? #1b192be0 : #0f0d20cc;
        border-radius: self.height / 2;
        border-width: 1px;
        border-color: #ffffff14;
        z: 160;

        animate y { duration: 250ms; easing: ease-out; }
        animate background { duration: 150ms; }

        touch-area := TouchArea {
            clicked => { root.skip-segment(); }
        }

        HorizontalLayout {
            alignment: center;
            spacing: 8px;

            Image {
                source: @image-url("../assets/images/icons/chevron-forward.svg");
                width: 18px;
                height: 18px;
                colorize: #ffffff;
            }

            Text {
                text: root.skip-button-label;
                color: #ffffff;
                font-size: 14px;
                font-weight: 600;
                vertical-alignment: center;
            }
        }
    }

    // Official web control-bar geometry: a 10rem fade, a 2.5rem seek row and
    // a 4rem button row with 2rem page gutters. Explicit anchors keep the
    // timeline and right-side controls full-width on every Slint renderer.
    if (controls-visible) : Rectangle {
        y: parent.height - 160px;
        width: 100%;
        height: 160px;
        background: @linear-gradient(0deg, #00000059 0%, #0000002e 45%, #00000000 100%);
        z: 150;

        Text {
            x: 32px;
            y: 48px;
            width: 88px;
            height: 40px;
            text: elapsed-time-str;
            color: #ffffffe6;
            font-size: 17px;
            horizontal-alignment: center;
            vertical-alignment: center;
        }

        Slider {
            x: 120px;
            y: 48px;
            width: max(40px, parent.width - 240px);
            height: 40px;
            unit: 16px;
            minimum: 0;
            maximum: 1;
            step: 0.001;
            value: progress;
            buffered: buffered-percent / 100;
            track-inset: 10px;
            track-size: 6px;
            thumb-size: 19px;
            hover-thumb-size: 23px;
            track-color: #ffffff;
            track-opacity: 0.3;
            buffered-color: #ffffff80;
            progress-color: Theme.accent;
            thumb-color: Theme.accent;
            thumb-border-width: 4px;
            thumb-border-color: #a891ff;
            completed(value) => { root.seek(value); }
        }

        Text {
            x: parent.width - 120px;
            y: 48px;
            width: 88px;
            height: 40px;
            text: total-time-str;
            color: #ffffffe6;
            font-size: 17px;
            horizontal-alignment: center;
            vertical-alignment: center;
        }

        // Playback and volume controls are independently anchored to the left.
        HorizontalLayout {
            x: 32px;
            y: 88px;
            width: (is-series ? 200px : 132px) + (root.width > 900px ? 164px : 0px);
            height: 64px;
            spacing: 4px;
            alignment: start;

            PlayerIconButton {
                icon-source: paused
                    ? @image-url("../assets/images/icons/play.svg")
                    : @image-url("../assets/images/icons/pause.svg");
                tooltip: paused ? @tr("PLAYER_PLAY" => "Play") + " (Space)" : @tr("PLAYER_PAUSE" => "Pause") + " (Space)";
                clicked => { toggle-pause(); }
            }

            if (is-series) : PlayerIconButton {
                icon-source: @image-url("../assets/images/icons/next.svg");
                tooltip: @tr("PLAYER_NEXT_VIDEO" => "Next Video");
                disabled: !root.has-next-episode;
                clicked => { root.play-next-episode(); }
            }

            PlayerIconButton {
                icon-source: (muted || volume == 0.0)
                    ? @image-url("../assets/images/icons/volume-mute.svg")
                    : (volume < 0.3
                        ? @image-url("../assets/images/icons/volume-low.svg")
                        : (volume < 0.7
                            ? @image-url("../assets/images/icons/volume-medium.svg")
                            : @image-url("../assets/images/icons/volume-high.svg")));
                tooltip: muted ? @tr("PLAYER_UNMUTE" => "Unmute") + " (M)" : @tr("PLAYER_MUTE" => "Mute") + " (M)";
                clicked => { toggle-mute(); }
            }

            if (root.width > 900px) : Slider {
                width: 160px;
                height: 64px;
                unit: 16px;
                minimum: 0;
                maximum: 1;
                step: 0.01;
                value: muted ? 0.0 : volume;
                track-inset: 8px;
                track-size: 6px;
                thumb-size: 16px;
                track-color: #ffffff;
                track-opacity: 0.2;
                buffered-color: transparent;
                progress-color: #ffffff;
                thumb-color: #ffffff;
                changed(value) => { change-volume(value); }
            }
        }

        // Menus and display controls are independently anchored to the right.
        HorizontalLayout {
            width: is-series ? 472px : 404px;
            x: parent.width - self.width - 32px;
            y: 88px;
            height: 64px;
            spacing: 4px;
            alignment: end;

            PlayerIconButton {
                icon-source: @image-url("../assets/images/icons/network.svg");
                tooltip: @tr("Playback information");
                active: show-stats-menu;
                clicked => {
                    show-stats-menu = !show-stats-menu;
                    show-speed-menu = false;
                    show-subtitles-menu = false;
                    show-audio-menu = false;
                    show-playlist-drawer = false;
                    show-options-menu = false;
                }
            }

            PlayerIconButton {
                icon-source: @image-url("../assets/images/icons/speed.svg");
                tooltip: @tr("PLAYER_PLAYBACK_SPEED" => "Playback Speed");
                active: show-speed-menu;
                clicked => {
                    show-speed-menu = !show-speed-menu;
                    show-stats-menu = false;
                    show-subtitles-menu = false;
                    show-audio-menu = false;
                    show-playlist-drawer = false;
                    show-options-menu = false;
                }
            }

            PlayerIconButton {
                icon-source: @image-url("../assets/images/icons/subtitles.svg");
                tooltip: @tr("SUBTITLES" => "Subtitles");
                disabled: subtitles-tracks.length == 0;
                active: show-subtitles-menu;
                clicked => {
                    show-subtitles-menu = !show-subtitles-menu;
                    show-stats-menu = false;
                    show-speed-menu = false;
                    show-audio-menu = false;
                    show-playlist-drawer = false;
                    show-options-menu = false;
                }
            }

            PlayerIconButton {
                icon-source: @image-url("../assets/images/icons/audio-tracks.svg");
                tooltip: @tr("AUDIO_TRACKS" => "Audio Tracks");
                disabled: audio-tracks.length == 0;
                active: show-audio-menu;
                clicked => {
                    show-audio-menu = !show-audio-menu;
                    show-stats-menu = false;
                    show-speed-menu = false;
                    show-subtitles-menu = false;
                    show-playlist-drawer = false;
                    show-options-menu = false;
                }
            }

            if (is-series) : PlayerIconButton {
                icon-source: @image-url("../assets/images/icons/episodes.svg");
                tooltip: @tr("Episode list");
                active: show-playlist-drawer;
                clicked => {
                    show-playlist-drawer = !show-playlist-drawer;
                    show-stats-menu = false;
                    show-speed-menu = false;
                    show-subtitles-menu = false;
                    show-audio-menu = false;
                    show-options-menu = false;
                }
            }

            PlayerIconButton {
                icon-source: @image-url("../assets/images/icons/scale.svg");
                tooltip: video-scale-mode == 0 ? @tr("PLAYER_SCALE_FIT" => "Fit") : (video-scale-mode == 1 ? @tr("PLAYER_SCALE_CROP" => "Crop") : @tr("PLAYER_SCALE_STRETCH" => "Stretch"));
                clicked => {
                    video-scale-mode = Math.mod(video-scale-mode + 1, 3);
                    change-video-scale(video-scale-mode);
                    show-options-menu = false;
                }
            }

            PlayerIconButton {
                icon-source: @image-url("../assets/images/icons/more-horizontal.svg");
                tooltip: @tr("More playback options");
                active: show-options-menu;
                clicked => {
                    show-options-menu = !show-options-menu;
                    show-stats-menu = false;
                    show-speed-menu = false;
                    show-subtitles-menu = false;
                    show-audio-menu = false;
                    show-playlist-drawer = false;
                }
            }
        }
    }

    if (controls-visible && show-options-menu) : options-menu := PopupMenuSurface {
        x: parent.width - options-menu.width - 64px;
        y: parent.height - options-menu.height - 120px;
        width: 256px;
        height: 152px;
        background: Theme.card-background;
        border-radius: Theme.border-radius;
        border-width: 1px;
        border-color: Theme.divider;
        z: 180;

        VerticalLayout {
            padding: 16px;
            spacing: 8px;
            PlayerMenuOption {
                icon-source: @image-url("../assets/images/icons/link.svg");
                label: @tr("CTX_COPY_STREAM_LINK" => "Copy stream link");
                clicked => {
                    copy-stream-link();
                    show-options-menu = false;
                }
            }
            PlayerMenuOption {
                icon-source: @image-url("../assets/images/icons/download.svg");
                label: @tr("CTX_DOWNLOAD_VIDEO" => "Download this video");
                clicked => {
                    download-video();
                    show-options-menu = false;
                }
            }
        }
    }

    if (controls-visible && show-subtitles-menu) : subtitles-menu := PopupMenuSurface {
        x: parent.width - subtitles-menu.width - 64px;
        y: parent.height - subtitles-menu.height - 120px;
        width: min(784px, parent.width - 128px);
        height: min(400px, parent.height - 208px);
        background: Theme.card-background;
        border-radius: Theme.border-radius;
        border-width: 1px;
        border-color: Theme.divider;
        z: 180;

        HorizontalLayout {
            spacing: 0px;

            // Official Stremio menu: languages (16rem).
            VerticalLayout {
                width: 256px;
                spacing: 0px;

                HorizontalLayout {
                    height: 72px;
                    padding-left: 32px;
                    Text {
                        text: @tr("PLAYER_SUBTITLES_LANGUAGES" => "Subtitles Languages");
                        color: Theme.surface-light;
                        font-size: 16px;
                        font-weight: 700;
                        vertical-alignment: center;
                    }
                }

                ScrollView {
                    vertical-stretch: 1;
                    viewport-width: self.width;
                    horizontal-scrollbar-policy: always-off;
                    mouse-drag-pan-enabled: true;

                    VerticalLayout {
                        padding-left: 16px;
                        padding-right: 16px;
                        spacing: 8px;

                        TrackItem {
                            label: @tr("NAVIGATION_OFF" => "Off");
                            active: active-subtitle-idx == -1;
                            clicked => {
                                active-subtitle-idx = -1;
                                change-subtitle(-1);
                            }
                        }

                        for lang[idx] in subtitle-languages : TrackItem {
                            label: lang;
                            active: selected-subtitle-language == lang;
                            clicked => {
                                active-subtitle-idx = subtitle-language-track-indices[idx];
                                change-subtitle(active-subtitle-idx);
                            }
                        }
                    }
                }
            }

            Rectangle { width: 1px; background: Theme.overlay-color; }

            // Official Stremio menu: variants (16rem).
            VerticalLayout {
                width: 256px;
                spacing: 0px;

                HorizontalLayout {
                    height: 72px;
                    padding-left: 32px;
                    Text {
                        text: @tr("PLAYER_SUBTITLES_VARIANTS" => "Subtitles Variants");
                        color: Theme.surface-light;
                        font-size: 16px;
                        font-weight: 700;
                        vertical-alignment: center;
                    }
                }

                if (active-subtitle-idx < 0) : HorizontalLayout {
                    height: 72px;
                    padding-left: 16px;
                    padding-right: 16px;
                    Text {
                        text: @tr("PLAYER_SUBTITLES_DISABLED" => "Subtitles are disabled");
                        color: Theme.surface-light-90;
                        font-size: 15px;
                        font-weight: 500;
                        wrap: word-wrap;
                    }
                }

                if (active-subtitle-idx >= 0) : ScrollView {
                    vertical-stretch: 1;
                    viewport-width: self.width;
                    horizontal-scrollbar-policy: always-off;
                    mouse-drag-pan-enabled: true;

                    VerticalLayout {
                        padding-left: 16px;
                        padding-right: 16px;
                        spacing: 8px;

                        for sub-name[idx] in subtitles-tracks : Rectangle {
                            height: subtitle-track-languages[idx] == selected-subtitle-language ? 64px : 0px;
                            visible: subtitle-track-languages[idx] == selected-subtitle-language;

                            TrackItem {
                                width: 100%;
                                height: 64px;
                                label: sub-name;
                                secondary-label: subtitle-track-origins[idx];
                                active: active-subtitle-idx == idx;
                                clicked => {
                                    active-subtitle-idx = idx;
                                    change-subtitle(idx);
                                }
                            }
                        }
                    }
                }
            }

            Rectangle { width: 1px; background: Theme.overlay-color; }

            // Official Stremio menu: per-track settings (17rem).
            VerticalLayout {
                horizontal-stretch: 1;
                spacing: 0px;

                HorizontalLayout {
                    height: 72px;
                    padding-left: 32px;
                    Text {
                        text: @tr("SETTINGS" => "Settings");
                        color: Theme.surface-light;
                        font-size: 16px;
                        font-weight: 700;
                        vertical-alignment: center;
                    }
                }

                ScrollView {
                    vertical-stretch: 1;
                    viewport-width: self.width;
                    horizontal-scrollbar-policy: always-off;
                    mouse-drag-pan-enabled: true;

                    VerticalLayout {
                        SubtitleStepper {
                            label: @tr("DELAY" => "Delay");
                            unit: "s";
                            value: subtitle-delay-seconds;
                            step: 0.25;
                            minimum: -10.0;
                            maximum: 10.0;
                            disabled: active-subtitle-idx < 0;
                            changed(value) => {
                                subtitle-delay-seconds = value;
                                change-subtitle-delay(value);
                            }
                        }
                        SubtitleStepper {
                            label: @tr("SIZE" => "Size");
                            unit: "%";
                            value: subtitle-size-percent;
                            step: 25.0;
                            minimum: 50.0;
                            maximum: 200.0;
                            disabled: active-subtitle-idx < 0;
                            changed(value) => {
                                subtitle-size-percent = value;
                                change-subtitle-size(value);
                            }
                        }
                        SubtitleStepper {
                            label: @tr("PLAYER_SUBTITLES_VERTICAL_POSITION" => "Vertical Position");
                            unit: "%";
                            value: subtitle-offset-percent;
                            step: 1.0;
                            minimum: 0.0;
                            maximum: 100.0;
                            disabled: active-subtitle-idx < 0;
                            changed(value) => {
                                subtitle-offset-percent = value;
                                change-subtitle-offset(value);
                            }
                        }
                    }
                }
            }
        }
    }

    if (controls-visible && show-audio-menu) : audio-menu := PopupMenuSurface {
        x: parent.width - audio-menu.width - 64px;
        y: parent.height - audio-menu.height - 120px;
        width: 256px;
        height: min(400px, parent.height - 208px);
        background: #15121ff5;
        border-radius: 12px;
        border-width: 1px;
        border-color: #ffffff1f;
        z: 180;

        VerticalLayout {
            spacing: 0px;

            HorizontalLayout {
                height: 72px;
                padding-left: 32px;
                Text {
                    text: @tr("AUDIO_TRACKS" => "Audio Tracks");
                    color: #ffffff;
                    font-size: 16px;
                    font-weight: 700;
                    vertical-alignment: center;
                }
            }

            ScrollView {
                vertical-stretch: 1;
                viewport-width: self.width;
                horizontal-scrollbar-policy: always-off;
                mouse-drag-pan-enabled: true;

                VerticalLayout {
                    padding-left: 16px;
                    padding-right: 16px;
                    padding-bottom: 16px;
                    spacing: 8px;
                    for aud-name[idx] in audio-tracks : TrackItem {
                        label: audio-track-languages[idx];
                        secondary-label: audio-track-labels[idx];
                        active: active-audio-idx == idx;
                        clicked => {
                            active-audio-idx = idx;
                            change-audio(idx);
                            show-audio-menu = false;
                        }
                    }
                }
            }
        }
    }

    if (controls-visible && show-speed-menu) : speed-menu := PopupMenuSurface {
        x: parent.width - speed-menu.width - 32px;
        y: parent.height - speed-menu.height - 112px;
        width: 240px;
        height: min(540px, parent.height - 200px);
        background: #15121ff5;
        border-radius: 12px;
        border-width: 1px;
        border-color: #ffffff1f;
        z: 180;

        VerticalLayout {
            padding: 12px;
            spacing: 4px;

            Text {
                height: 52px;
                text: @tr("PLAYER_PLAYBACK_SPEED" => "Playback Speed");
                color: #ffffff;
                font-size: 20px;
                font-weight: 700;
                vertical-alignment: center;
            }

            ScrollView {
                vertical-stretch: 1;
                viewport-width: self.width;
                horizontal-scrollbar-policy: always-off;
                mouse-drag-pan-enabled: true;

                VerticalLayout {
                    width: parent.width;
                    spacing: 4px;

                    TrackItem { label: "0.25x"; active: playback-speed == 0.25; clicked => { playback-speed = 0.25; change-speed(0.25); show-speed-menu = false; } }
                    TrackItem { label: "0.5x"; active: playback-speed == 0.5; clicked => { playback-speed = 0.5; change-speed(0.5); show-speed-menu = false; } }
                    TrackItem { label: "0.75x"; active: playback-speed == 0.75; clicked => { playback-speed = 0.75; change-speed(0.75); show-speed-menu = false; } }
                    TrackItem { label: "1.0x (" + @tr("Normal") + ")"; active: playback-speed == 1.0; clicked => { playback-speed = 1.0; change-speed(1.0); show-speed-menu = false; } }
                    TrackItem { label: "1.25x"; active: playback-speed == 1.25; clicked => { playback-speed = 1.25; change-speed(1.25); show-speed-menu = false; } }
                    TrackItem { label: "1.5x"; active: playback-speed == 1.5; clicked => { playback-speed = 1.5; change-speed(1.5); show-speed-menu = false; } }
                    TrackItem { label: "2.0x"; active: playback-speed == 2.0; clicked => { playback-speed = 2.0; change-speed(2.0); show-speed-menu = false; } }
                    TrackItem { label: "3.0x"; active: playback-speed == 3.0; clicked => { playback-speed = 3.0; change-speed(3.0); show-speed-menu = false; } }
                    TrackItem { label: "4.0x"; active: playback-speed == 4.0; clicked => { playback-speed = 4.0; change-speed(4.0); show-speed-menu = false; } }
                }
            }
        }
    }

    if (controls-visible && show-stats-menu) : stats-menu := PopupMenuSurface {
        x: parent.width - stats-menu.width - 32px;
        y: parent.height - stats-menu.height - 112px;
        width: 480px;
        height: 175px;
        background: Theme.card-background;
        border-radius: Theme.border-radius;
        border-width: 1px;
        border-color: Theme.divider;
        z: 180;

        VerticalLayout {
            padding: 24px;
            spacing: 24px;
            alignment: start;

            // Title
            Text {
                text: @tr("PLAYER_STATISTICS" => "Statistics");
                color: Theme.surface-light;
                font-size: 16px;
                font-weight: 700;
            }

            // Stats row: Peers, Speed, Completed - inline label + value
            HorizontalLayout {
                spacing: 24px;
                alignment: start;

                HorizontalLayout {
                    spacing: 6px;
                    Text { text: @tr("PLAYER_PEERS" => "Peers"); color: Theme.text-secondary; font-size: 14px; font-weight: 500; vertical-alignment: center; }
                    Text { text: download-speed != "" ? peer-count : "0"; color: Theme.surface-light; font-size: 14px; font-weight: 500; vertical-alignment: center; }
                }

                HorizontalLayout {
                    spacing: 6px;
                    Text { text: @tr("PLAYER_SPEED" => "Speed"); color: Theme.text-secondary; font-size: 14px; font-weight: 500; vertical-alignment: center; }
                    Text { text: download-speed != "" ? download-speed : "0 KB/s"; color: Theme.surface-light; font-size: 14px; font-weight: 500; vertical-alignment: center; }
                }

                HorizontalLayout {
                    spacing: 6px;
                    Text { text: @tr("PLAYER_COMPLETED" => "Completed"); color: Theme.text-secondary; font-size: 14px; font-weight: 500; vertical-alignment: center; }
                    Text { text: download-speed != "" ? round(stream-progress) + " %" : "0 %"; color: Theme.surface-light; font-size: 14px; font-weight: 500; vertical-alignment: center; }
                }
            }

            // Info hash section
            VerticalLayout {
                spacing: 8px;
                alignment: start;
                Text { text: @tr("PLAYER_INFO_HASH" => "Info hash"); color: Theme.text-secondary; font-size: 14px; font-weight: 500; }
                Text {
                    text: info-hash != "" ? info-hash : "N/A";
                    color: Theme.surface-light;
                    font-size: 14px;
                    font-weight: 500;
                    overflow: elide;
                }
            }
        }
    }

    // Retained temporarily as an inert compatibility tree while the Rust-side
    // IconData bindings remain part of MainWindow's public interface.
    if (false && controls-visible) : Rectangle {
        y: parent.height - 100px;
        width: 100%;
        height: 100px;
        background: @linear-gradient(0deg, #000000cc 0%, #00000000 100%);
        z: 150;

        VerticalLayout {
            padding-left: 24px;
            padding-right: 24px;
            spacing: 8px;
            alignment: center;

            // 1. Timeline / Seek Slider Row
            HorizontalLayout {
                spacing: 12px;
                
                Text {
                    text: elapsed-time-str;
                    color: #ffffffcc;
                    font-size: 12px;
                    vertical-alignment: center;
                }

                // Interactive Seek Bar
                timeline-slider := Slider {
                    horizontal-stretch: 1;
                    minimum: 0;
                    maximum: 100;
                    value: progress * 100.0;
                    changed(val) => {
                        root.seek(val / 100.0);
                    }
                }

                Text {
                    text: total-time-str;
                    color: #ffffffcc;
                    font-size: 12px;
                    vertical-alignment: center;
                }
            }

            // 2. Playback Button Controls
            HorizontalLayout {
                spacing: 16px;
                alignment: start;

                // Play / Pause
                PlayerIconButton {
                    icon: paused ? icon-play : icon-pause;
                    tooltip: paused ? @tr("PLAYER_PLAY" => "Play") + " (Space)" : @tr("PLAYER_PAUSE" => "Pause") + " (Space)";
                    clicked => { toggle-pause(); }
                }

                // Next Episode
                if (is-series) : PlayerIconButton {
                    icon: icon-next;
                    tooltip: @tr("PLAYER_NEXT_VIDEO" => "Next Video");
                    disabled: !root.has-next-episode;
                    clicked => { root.play-next-episode(); }
                }

                // Volume and Slider
                HorizontalLayout {
                    spacing: 8px;
                    alignment: start;
                    
                    PlayerIconButton {
                        icon: (muted || volume == 0.0) ? icon-volume-mute : (volume < 0.5 ? icon-volume-low : icon-volume-high);
                        tooltip: muted ? @tr("PLAYER_UNMUTE" => "Unmute") + " (M)" : @tr("PLAYER_MUTE" => "Mute") + " (M)";
                        clicked => { toggle-mute(); }
                    }

                    Rectangle {
                        width: 80px;
                        height: 40px;
                        
                        Slider {
                            y: 10px;
                            width: 80px;
                            minimum: 0;
                            maximum: 100;
                            value: muted ? 0.0 : volume * 100.0;
                            changed(val) => {
                                change-volume(val / 100.0);
                            }
                        }
                    }
                }

                // Spacer
                Rectangle {
                    horizontal-stretch: 1;
                }

                PlayerIconButton {
                    icon: icon-fullscreen;
                    tooltip: @tr("CTX_FULLSCREEN" => "Fullscreen") + " (F)";
                    clicked => { toggle-fullscreen(); }
                }

                // Subtitles Popup Button
                Rectangle {
                    width: 40px;
                    height: 40px;
                    
                    PlayerIconButton {
                        icon: icon-subtitles;
                        tooltip: @tr("SUBTITLES" => "Subtitles");
                        active: show-subtitles-menu;
                        clicked => {
                            show-subtitles-menu = !show-subtitles-menu;
                            show-audio-menu = false;
                            show-speed-menu = false;
                            show-stats-menu = false;
                        }
                    }

                    if (show-subtitles-menu) : Rectangle {
                        x: -80px;
                        y: -220px;
                        width: 200px;
                        height: 200px;
                        background: #0f0d20f5;
                        border-radius: 8px;
                        border-width: 1px;
                        border-color: Theme.card-border;
                        z: 40;

                        ScrollView {
                            VerticalLayout {
                                padding: 8px;
                                spacing: 4px;
                                
                                TrackItem {
                                    label: @tr("None (Off)");
                                    active: active-subtitle-idx == -1;
                                    clicked => {
                                        active-subtitle-idx = -1;
                                        change-subtitle(-1);
                                        show-subtitles-menu = false;
                                    }
                                }

                                for sub-name[idx] in subtitles-tracks : TrackItem {
                                    label: sub-name;
                                    active: active-subtitle-idx == idx;
                                    clicked => {
                                        active-subtitle-idx = idx;
                                        change-subtitle(idx);
                                        show-subtitles-menu = false;
                                    }
                                }
                            }
                        }
                    }
                }

                // Audio Tracks Popup Button
                Rectangle {
                    width: 40px;
                    height: 40px;
                    
                    PlayerIconButton {
                        icon: icon-audio;
                        tooltip: @tr("AUDIO_TRACKS" => "Audio Tracks");
                        active: show-audio-menu;
                        clicked => {
                            show-audio-menu = !show-audio-menu;
                            show-subtitles-menu = false;
                            show-speed-menu = false;
                            show-stats-menu = false;
                        }
                    }

                    if (show-audio-menu) : Rectangle {
                        x: -80px;
                        y: -170px;
                        width: 200px;
                        height: 150px;
                        background: #0f0d20f5;
                        border-radius: 8px;
                        border-width: 1px;
                        border-color: Theme.card-border;
                        z: 40;

                        ScrollView {
                            VerticalLayout {
                                padding: 8px;
                                spacing: 4px;
                                
                                for aud-name[idx] in audio-tracks : TrackItem {
                                    label: aud-name;
                                    active: active-audio-idx == idx;
                                    clicked => {
                                        active-audio-idx = idx;
                                        change-audio(idx);
                                        show-audio-menu = false;
                                    }
                                }
                            }
                        }
                    }
                }

                // Speed Select Menu Button
                Rectangle {
                    width: 40px;
                    height: 40px;
                    
                    PlayerIconButton {
                        icon: icon-speed;
                        tooltip: @tr("PLAYER_PLAYBACK_SPEED" => "Playback Speed");
                        active: show-speed-menu;
                        clicked => {
                            show-speed-menu = !show-speed-menu;
                            show-subtitles-menu = false;
                            show-audio-menu = false;
                            show-stats-menu = false;
                        }
                    }

                    if (show-speed-menu) : Rectangle {
                        x: -80px;
                        y: -220px;
                        width: 160px;
                        height: 200px;
                        background: #0f0d20f5;
                        border-radius: 8px;
                        border-width: 1px;
                        border-color: Theme.card-border;
                        z: 40;

                        VerticalLayout {
                            padding: 8px;
                            spacing: 4px;
                            
                            TrackItem {
                                label: "0.5x (" + @tr("Slow") + ")";
                                active: playback-speed == 0.5;
                                clicked => {
                                    playback-speed = 0.5;
                                    change-speed(0.5);
                                    show-speed-menu = false;
                                }
                            }
                            TrackItem {
                                label: "1.0x (" + @tr("Normal") + ")";
                                active: playback-speed == 1.0;
                                clicked => {
                                    playback-speed = 1.0;
                                    change-speed(1.0);
                                    show-speed-menu = false;
                                }
                            }
                            TrackItem {
                                label: "1.25x";
                                active: playback-speed == 1.25;
                                clicked => {
                                    playback-speed = 1.25;
                                    change-speed(1.25);
                                    show-speed-menu = false;
                                }
                            }
                            TrackItem {
                                label: "1.5x";
                                active: playback-speed == 1.5;
                                clicked => {
                                    playback-speed = 1.5;
                                    change-speed(1.5);
                                    show-speed-menu = false;
                                }
                            }
                            TrackItem {
                                label: "2.0x (" + @tr("TORRENT_PROFILE_FAST" => "Fast") + ")";
                                active: playback-speed == 2.0;
                                clicked => {
                                    playback-speed = 2.0;
                                    change-speed(2.0);
                                    show-speed-menu = false;
                                }
                            }
                        }
                    }
                }

                // Stats Overlay Menu Button
                Rectangle {
                    width: 40px;
                    height: 40px;
                    
                    PlayerIconButton {
                        icon: icon-stats;
                        tooltip: @tr("Playback information");
                        active: show-stats-menu;
                        clicked => {
                            show-stats-menu = !show-stats-menu;
                            show-subtitles-menu = false;
                            show-audio-menu = false;
                            show-speed-menu = false;
                        }
                    }

                    if (show-stats-menu) : Rectangle {
                        x: -240px;
                        y: -225px;
                        width: 280px;
                        height: 205px;
                        background: #0f0d20f5;
                        border-radius: 8px;
                        border-width: 1px;
                        border-color: Theme.card-border;
                        z: 40;

                        VerticalLayout {
                            padding: 16px;
                            spacing: 8px;
                            alignment: start;

                            Text {
                                text: @tr("Video Statistics");
                                color: Theme.accent;
                                font-size: 13px;
                                font-weight: 700;
                            }
                            Text {
                                text: @tr("Container: {}", file-format == "" ? @tr("UNKNOWN_TRACK_LANG" => "Unknown") : file-format);
                                color: #ffffffcc;
                                font-size: 11px;
                            }
                            Text {
                                text: @tr("Video format: {}", video-format == "" ? @tr("UNKNOWN_TRACK_LANG" => "Unknown") : video-format);
                                color: #ffffffcc;
                                font-size: 11px;
                            }
                            Text {
                                text: @tr("Audio format: {}", audio-format == "" ? @tr("UNKNOWN_TRACK_LANG" => "Unknown") : audio-format);
                                color: #ffffffcc;
                                font-size: 11px;
                            }
                            Text {
                                text: @tr("Decoder: {}", (hardware-decoder == "" || hardware-decoder == "no") ? @tr("Software") : hardware-decoder);
                                color: #ffffffcc;
                                font-size: 11px;
                            }
                            Text {
                                text: @tr("Buffered: {}%", round(buffered-percent));
                                color: #ffffffcc;
                                font-size: 11px;
                            }
                            if (download-speed != "") : Text {
                                text: @tr("Torrent: {} down / {} up · {} peers", download-speed, upload-speed, peer-count);
                                color: #ffffffcc;
                                font-size: 11px;
                            }
                            if (download-speed != "") : Text {
                                text: @tr("Streamed: {}%", round(stream-progress));
                                color: #ffffffcc;
                                font-size: 11px;
                            }
                        }
                    }
                }

                // Side Playlist Drawer Trigger Button
                if (is-series) : PlayerIconButton {
                    icon: icon-menu;
                    tooltip: @tr("Episode list");
                    active: show-playlist-drawer;
                    clicked => {
                        show-playlist-drawer = !show-playlist-drawer;
                    }
                }
            }
        }
    }

    ContextMenuSurface {
        width: parent.width;
        height: parent.height;
        unit: 16px;
        open <=> root.show-context-menu;
        requested-x: root.context-menu-x;
        requested-y: root.context-menu-y;
        menu-width: 19 * self.unit;
        menu-height: 10.75 * self.unit;
        auto-close: true;
        close-requested => { root.show-context-menu = false; }

        VerticalLayout {
            padding-top: 0.5 * 16px;
            padding-bottom: 0.5 * 16px;
            spacing: 0px;

            ContextMenuOption {
                unit: 16px;
                label: @tr("CTX_COPY_STREAM_LINK" => "Copy stream link");
                show-icon: true;
                icon-source: @image-url("../assets/images/icons/link.svg");
                clicked => {
                    root.copy-stream-link();
                    root.show-context-menu = false;
                }
            }
            ContextMenuOption {
                unit: 16px;
                label: @tr("CTX_DOWNLOAD_VIDEO" => "Download this video");
                show-icon: true;
                icon-source: @image-url("../assets/images/icons/download.svg");
                clicked => {
                    root.download-video();
                    root.show-context-menu = false;
                }
            }
            ContextMenuOption {
                unit: 16px;
                label: @tr("Playback information");
                show-icon: true;
                icon-source: @image-url("../assets/images/icons/settings-outline.svg");
                clicked => {
                    root.show-stats-menu = true;
                    root.show-context-menu = false;
                }
            }
        }
    }
}
