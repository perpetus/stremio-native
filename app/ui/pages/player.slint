import { Button, Slider, ScrollView } from "std-widgets.slint";
import { Theme, IconData } from "../theme.slint";

component PlayerIconButton inherits Rectangle {
    // Kept for the legacy control tree below. The active player chrome uses
    // the exact SVG assets from stremio-icons through icon-source.
    in property <IconData> icon;
    in property <image> icon-source;
    in property <bool> active: false;
    in property <bool> disabled: false;
    in property <length> icon-size: 35px;
    in property <string> tooltip: "";
    callback clicked();

    width: 64px;
    height: 64px;
    border-radius: 12px;
    background: active ? #ffffff1f : transparent;
    accessible-role: button;
    accessible-label: tooltip;
    accessible-enabled: !disabled;
    accessible-action-default => { if (!disabled) { root.clicked(); } }

    states [
        disabled when disabled: {
            opacity: 0.3;
        }
        hover when mouse-area.has-hover: {
            background: #ffffff1f;
        }
    ]

    animate background { duration: 150ms; }

    Image {
        x: (parent.width - icon-size) / 2;
        y: (parent.height - icon-size) / 2;
        width: icon-size;
        height: icon-size;
        source: icon-source;
        image-fit: contain;
        colorize: active ? Theme.accent : #ffffffdf;
    }

    mouse-area := TouchArea {
        enabled: !disabled;
        clicked => { root.clicked(); }
    }
}

component TrackItem inherits Rectangle {
    in property <string> label;
    in property <string> secondary-label: "";
    in property <bool> active;
    in property <length> row-height: secondary-label == "" ? 56px : 64px;
    callback clicked();

    height: row-height;
    border-radius: 10px;
    background: active ? #7b5bf538 : transparent;
    accessible-role: button;
    accessible-label: label;
    accessible-action-default => { root.clicked(); }

    states [
        hover when mouse-area.has-hover: {
            background: active ? #7b5bf54d : #ffffff12;
        }
    ]

    animate background { duration: 150ms; }

    VerticalLayout {
        x: 24px;
        y: secondary-label == "" ? 0px : 10px;
        width: parent.width - 64px;
        height: secondary-label == "" ? parent.height : parent.height - 20px;
        spacing: 4px;
        alignment: center;

        Text {
            text: label;
            color: #ffffff;
            font-size: 17px;
            font-weight: active ? 600 : 400;
            vertical-alignment: center;
            overflow: elide;
        }

        if (secondary-label != "") : Text {
            text: secondary-label;
            color: #ffffff80;
            font-size: 14px;
            vertical-alignment: center;
            overflow: elide;
        }
    }

    if (active) : Rectangle {
        x: parent.width - 24px;
        y: (parent.height - 8px) / 2;
        width: 8px;
        height: 8px;
        border-radius: 4px;
        background: Theme.accent;
    }

    mouse-area := TouchArea {
        clicked => { root.clicked(); }
    }
}

component PlayerMenuOption inherits Rectangle {
    in property <image> icon-source;
    in property <string> label;
    callback clicked();

    height: 56px;
    border-radius: 10px;
    background: option-area.has-hover ? #ffffff1f : transparent;
    accessible-role: button;
    accessible-label: label;
    accessible-action-default => { clicked(); }

    HorizontalLayout {
        padding-left: 16px;
        padding-right: 16px;
        spacing: 16px;
        alignment: center;
        Image {
            width: 22px;
            height: 22px;
            source: icon-source;
            image-fit: contain;
            colorize: #ffffffdf;
        }
        Text {
            horizontal-stretch: 1;
            text: label;
            color: #ffffff;
            font-size: 16px;
            vertical-alignment: center;
            overflow: elide;
        }
    }

    option-area := TouchArea { clicked => { root.clicked(); } }
}

component SubtitleStepper inherits Rectangle {
    in property <string> label;
    in property <string> unit: "";
    in-out property <float> value;
    in property <float> step: 1.0;
    in property <float> minimum: -1000.0;
    in property <float> maximum: 1000.0;
    in property <bool> disabled: false;
    callback changed(float);

    height: 88px;
    background: transparent;
    opacity: disabled ? 0.42 : 1.0;

    VerticalLayout {
        padding-left: 24px;
        padding-right: 24px;
        padding-bottom: 16px;
        spacing: 8px;

        Text {
            height: 22px;
            text: label;
            color: #ffffff80;
            font-size: 14px;
            font-weight: 600;
            vertical-alignment: center;
            overflow: elide;
        }

        HorizontalLayout {
            height: 42px;
            spacing: 8px;
            alignment: center;

            Rectangle {
                width: 42px;
                height: 42px;
                border-radius: 8px;
                background: minus-area.has-hover ? #ffffff1f : #ffffff0d;
                Text { text: "−"; color: #ffffff; font-size: 24px; horizontal-alignment: center; vertical-alignment: center; }
                minus-area := TouchArea {
                    enabled: !disabled;
                    clicked => {
                        root.value = max(root.minimum, root.value - root.step);
                        root.changed(root.value);
                    }
                }
            }

            Text {
                horizontal-stretch: 1;
                text: round(value * 100.0) / 100.0 + unit;
                color: #ffffff;
                font-size: 16px;
                font-weight: 600;
                horizontal-alignment: center;
                vertical-alignment: center;
            }

            Rectangle {
                width: 42px;
                height: 42px;
                border-radius: 8px;
                background: plus-area.has-hover ? #ffffff1f : #ffffff0d;
                Text { text: "+"; color: #ffffff; font-size: 22px; horizontal-alignment: center; vertical-alignment: center; }
                plus-area := TouchArea {
                    enabled: !disabled;
                    clicked => {
                        root.value = min(root.maximum, root.value + root.step);
                        root.changed(root.value);
                    }
                }
            }
        }
    }
}

component PlayerSeekBar inherits Rectangle {
    in property <float> value: 0.0;
    in property <float> buffered: 0.0;
    callback seek(float);
    property <float> drag-value: value;
    property <bool> dragging: false;
    property <float> shown-value: dragging ? drag-value : value;
    property <length> track-inset: 10px;
    property <length> thumb-size: 19px;
    property <length> shown-thumb-size: seek-touch.has-hover || dragging ? 23px : thumb-size;

    height: 40px;
    background: transparent;

    base-seek-track := Rectangle {
        x: root.track-inset;
        y: (parent.height - 6px) / 2;
        width: max(1px, parent.width - 2 * root.track-inset);
        height: 6px;
        border-radius: 3px;
        background: #ffffff4d;
    }

    // Keep every layer in root coordinates. Nested percentage geometry was
    // being laid out as an isolated child on some renderers, which displayed
    // a detached purple segment around the middle of the timeline.
    Rectangle {
        x: root.track-inset;
        y: base-seek-track.y;
        width: base-seek-track.width * max(0.0, min(1.0, buffered / 100.0));
        height: base-seek-track.height;
        border-radius: base-seek-track.border-radius;
        background: #ffffff80;
    }

    Rectangle {
        x: root.track-inset;
        y: base-seek-track.y;
        width: base-seek-track.width * max(0.0, min(1.0, root.shown-value));
        height: base-seek-track.height;
        border-radius: base-seek-track.border-radius;
        background: Theme.accent;
    }

    Rectangle {
        x: root.track-inset - root.shown-thumb-size / 2
            + base-seek-track.width
                * max(0.0, min(1.0, shown-value));
        y: (parent.height - root.shown-thumb-size) / 2;
        width: root.shown-thumb-size;
        height: root.shown-thumb-size;
        border-radius: root.shown-thumb-size / 2;
        background: Theme.accent;
        border-width: 4px;
        border-color: #a891ff;
        opacity: 1.0;
        animate width { duration: 100ms; }
        animate height { duration: 100ms; }
        animate opacity { duration: 100ms; }
    }

    seek-touch := TouchArea {
        mouse-cursor: pointer;
        pointer-event(event) => {
            if (event.kind == PointerEventKind.down) {
                root.dragging = true;
                root.drag-value = max(0.0, min(1.0,
                    (seek-touch.mouse-x - root.track-inset)
                        / max(1px, root.width - 2 * root.track-inset)));
            } else if (event.kind == PointerEventKind.move && root.dragging) {
                root.drag-value = max(0.0, min(1.0,
                    (seek-touch.mouse-x - root.track-inset)
                        / max(1px, root.width - 2 * root.track-inset)));
            } else if (event.kind == PointerEventKind.up && root.dragging) {
                root.drag-value = max(0.0, min(1.0,
                    (seek-touch.mouse-x - root.track-inset)
                        / max(1px, root.width - 2 * root.track-inset)));
                root.seek(root.drag-value);
                root.dragging = false;
            }
        }
    }
}

component PlayerVolumeSlider inherits Rectangle {
    in property <float> value: 1.0;
    callback changed(float);
    property <float> drag-value: value;
    property <bool> dragging: false;
    property <float> shown-value: dragging ? drag-value : value;
    property <length> track-inset: 8px;
    property <length> thumb-size: 16px;

    width: 160px;
    height: 64px;
    background: transparent;

    base-volume-track := Rectangle {
        x: root.track-inset;
        y: (parent.height - 6px) / 2;
        width: max(1px, parent.width - 2 * root.track-inset);
        height: 6px;
        border-radius: 3px;
        background: #ffffff33;
    }

    Rectangle {
        x: root.track-inset;
        y: base-volume-track.y;
        width: base-volume-track.width * max(0.0, min(1.0, root.shown-value));
        height: base-volume-track.height;
        border-radius: base-volume-track.border-radius;
        background: #ffffff;
    }

    Rectangle {
        x: root.track-inset - root.thumb-size / 2
            + base-volume-track.width
                * max(0.0, min(1.0, shown-value));
        y: (parent.height - root.thumb-size) / 2;
        width: root.thumb-size;
        height: root.thumb-size;
        border-radius: root.thumb-size / 2;
        background: #ffffff;
    }

    volume-touch := TouchArea {
        mouse-cursor: pointer;
        pointer-event(event) => {
            if (event.kind == PointerEventKind.down) {
                root.dragging = true;
                root.drag-value = max(0.0, min(1.0,
                    (volume-touch.mouse-x - root.track-inset)
                        / max(1px, root.width - 2 * root.track-inset)));
                root.changed(root.drag-value);
            } else if (event.kind == PointerEventKind.move && root.dragging) {
                root.drag-value = max(0.0, min(1.0,
                    (volume-touch.mouse-x - root.track-inset)
                        / max(1px, root.width - 2 * root.track-inset)));
                root.changed(root.drag-value);
            } else if (event.kind == PointerEventKind.up && root.dragging) {
                root.drag-value = max(0.0, min(1.0,
                    (volume-touch.mouse-x - root.track-inset)
                        / max(1px, root.width - 2 * root.track-inset)));
                root.changed(root.drag-value);
                root.dragging = false;
            }
        }
    }
}

export component PlayerPage inherits Rectangle {
    in property <string> item-title: "";
    in property <string> stream-name: "";
    in property <image> poster-image;
    in property <image> video-frame;
    in property <bool> has-video-frame: false;
    in property <bool> loading: false;
    in property <bool> buffering: false;
    in property <float> buffering-percent: 0.0;
    in property <string> error-message: "";
    in property <string> video-format: "";
    in property <string> audio-format: "";
    in property <string> file-format: "";
    in property <string> hardware-decoder: "";
    in property <float> buffered-percent: 0.0;
    in property <string> download-speed: "";
    in property <string> upload-speed: "";
    in property <int> peer-count: 0;
    in property <float> stream-progress: 0.0;

    // Playback state bindings
    in property <bool> paused: true;
    in-out property <float> volume: 1.0;
    in property <bool> muted: false;
    in-out property <float> progress: 0.0; // 0.0 to 1.0 representation
    in property <string> elapsed-time-str: "00:00";
    in property <string> total-time-str: "00:00";
    in property <float> seek-step-seconds: 10.0;

    // Track data lists
    in property <[string]> subtitles-tracks: [];
    in property <[string]> subtitle-track-languages: [];
    in property <[string]> subtitle-track-origins: [];
    in property <[string]> subtitle-languages: [];
    in property <[int]> subtitle-language-track-indices: [];
    in property <[string]> audio-tracks: [];
    in property <[string]> audio-track-languages: [];
    in property <[string]> audio-track-labels: [];
    in-out property <int> active-subtitle-idx: -1;
    in-out property <int> active-audio-idx: 0;
    in-out property <float> subtitle-delay-seconds: 0.0;
    in-out property <float> subtitle-size-percent: 100.0;
    in-out property <float> subtitle-offset-percent: 100.0;
    
    // Episode playlist
    in property <bool> is-series: false;
    in property <[string]> episode-names: [];
    in-out property <int> active-episode-idx: 0;

    // Speed options
    in-out property <float> playback-speed: 1.0;
    in-out property <int> video-scale-mode: 0;

    // Icons
    in property <IconData> icon-play;
    in property <IconData> icon-pause;
    in property <IconData> icon-next;
    in property <IconData> icon-volume-high;
    in property <IconData> icon-volume-low;
    in property <IconData> icon-volume-mute;
    in property <IconData> icon-fullscreen;
    in property <IconData> icon-subtitles;
    in property <IconData> icon-audio;
    in property <IconData> icon-speed;
    in property <IconData> icon-stats;
    in property <IconData> icon-options;
    in property <IconData> icon-menu;
    in property <IconData> icon-back;

    // Callbacks to Rust
    callback toggle-pause();
    callback seek(float);
    callback seek-relative(float);
    callback change-volume(float);
    callback toggle-mute();
    callback change-subtitle(int);
    callback change-audio(int);
    callback change-subtitle-delay(float);
    callback change-subtitle-size(float);
    callback change-subtitle-offset(float);
    callback change-speed(float);
    callback change-video-scale(int);
    callback copy-stream-link();
    callback download-video();
    callback play-episode(int);
    callback toggle-fullscreen();
    callback close();

    // Internal state
    property <bool> show-subtitles-menu: false;
    property <bool> show-audio-menu: false;
    property <bool> show-speed-menu: false;
    property <bool> show-stats-menu: false;
    property <bool> show-options-menu: false;
    property <bool> show-playlist-drawer: false;
    property <bool> controls-visible: true;
    property <bool> buffer-pulse: false;
    property <length> buffer-logo-size: min(240px, min(root.width / 3, root.height / 3));
    property <float> buffer-visual-progress: stream-progress > 0.0
        ? stream-progress
        : buffering-percent;
    property <string> selected-subtitle-language: active-subtitle-idx >= 0 && active-subtitle-idx < subtitle-track-languages.length
        ? subtitle-track-languages[active-subtitle-idx]
        : "";

    hide-controls-timer := Timer {
        interval: 5s;
        // Pointer motion is not reliable on every shared libmpv/OpenGL backend.
        // Keep playback controls available until the backend can guarantee it.
        running: false;
        triggered => { controls-visible = true; }
    }

    buffering-pulse-timer := Timer {
        interval: 1s;
        running: loading || buffering || !has-video-frame;
        triggered => { buffer-pulse = !buffer-pulse; }
    }

    keyboard := FocusScope {
        focus-on-click: true;
        key-pressed(event) => {
            controls-visible = true;
            hide-controls-timer.restart();
            if (event.text == Key.Space || event.text == "k" || event.text == "K") {
                toggle-pause();
                return accept;
            } else if (event.text == Key.LeftArrow) {
                seek-relative(-seek-step-seconds);
                return accept;
            } else if (event.text == Key.RightArrow) {
                seek-relative(seek-step-seconds);
                return accept;
            } else if (event.text == Key.UpArrow) {
                change-volume(min(1.0, volume + 0.05));
                return accept;
            } else if (event.text == Key.DownArrow) {
                change-volume(max(0.0, volume - 0.05));
                return accept;
            } else if (event.text == "m" || event.text == "M") {
                toggle-mute();
                return accept;
            } else if (event.text == "f" || event.text == "F") {
                toggle-fullscreen();
                return accept;
            } else if (event.text == Key.Escape) {
                close();
                return accept;
            }
            reject
        }
    }

    background: #000000;

    // MPV renders into a same-context RGBA texture. Keeping the frame in the
    // Slint scene lets the renderer composite every control above the video.
    Image {
        source: video-frame;
        width: 100%;
        height: 100%;
        // The render target normally matches the content area, while a resize
        // can briefly expose the previous texture. `contain` prevents that
        // transitional frame from being stretched into a square or a stale
        // window aspect; libmpv still owns the video letterboxing inside it.
        image-fit: contain;
        z: 0;
    }

    // Retain the artwork only until libmpv publishes an actual decoded frame.
    // Cache state may remain active after that point and must not mask video.
    if (!has-video-frame && error-message == "") : Rectangle {
        width: 100%;
        height: 100%;
        background: #000000;
        z: 2;
        Image {
            source: poster-image;
            width: 100%;
            height: 100%;
            image-fit: cover;
            opacity: 0.35;
        }
    }

    if (error-message != "") : Rectangle {
        width: 100%;
        height: 100%;
        background: #09070ed9;
        z: 250;

        VerticalLayout {
            alignment: center;
            spacing: 14px;
            padding-left: 48px;
            padding-right: 48px;

            Text {
                text: "Playback unavailable";
                color: #ffffff;
                font-size: 22px;
                font-weight: 700;
                horizontal-alignment: center;
            }
            Text {
                text: error-message;
                color: #ffffffb8;
                font-size: 14px;
                horizontal-alignment: center;
                wrap: word-wrap;
            }
            Button {
                text: "Back to streams";
                clicked => { close(); }
            }
        }
    }

    // Interactive Screen Area (to toggle controls visibility)
    screen-touch := TouchArea {
        width: 100%;
        height: 100%;
        clicked => {
            keyboard.focus();
            if (!show-subtitles-menu && !show-audio-menu && !show-speed-menu &&
                !show-stats-menu && !show-options-menu && !show-playlist-drawer) {
                toggle-pause();
            }
            show-subtitles-menu = false;
            show-audio-menu = false;
            show-speed-menu = false;
            show-stats-menu = false;
            show-options-menu = false;
            
            controls-visible = true;
        }
        pointer-event(event) => {
            if (event.kind == PointerEventKind.move) {
                controls-visible = true;
                hide-controls-timer.restart();
            }
        }
    }

    // Big play indicator in center if paused
    if (paused && !loading) : Rectangle {
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        width: 96px;
        height: 96px;
        border-radius: 48px;
        background: #0f0d20aa;
        border-width: 1px;
        border-color: #ffffff22;
        z: 40;
        
        Image {
            x: (parent.width - 42px) / 2 + 3px;
            y: (parent.height - 42px) / 2;
            width: 42px;
            height: 42px;
            source: @image-url("../assets/images/icons/play.svg");
            image-fit: contain;
            colorize: #ffffff;
        }

        TouchArea {
            clicked => { toggle-pause(); }
        }
    }

    // Match the web player: buffering is a transparent, pulsing Stremio mark.
    // The foreground fill follows torrent/cache progress while the faded mark
    // remains visible behind it. Video is never covered by an opaque scrim.
    if (loading || buffering || !has-video-frame) : Rectangle {
        width: 100%;
        height: 100%;
        background: transparent;
        z: 20;

        buffer-mark := Rectangle {
            width: buffer-pulse ? buffer-logo-size * 1.05 : buffer-logo-size;
            height: buffer-pulse ? buffer-logo-size * 1.05 : buffer-logo-size;
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            background: transparent;
            opacity: buffer-pulse ? 1.0 : 0.4;

            animate width { duration: 1s; easing: ease-in-out; }
            animate height { duration: 1s; easing: ease-in-out; }
            animate opacity { duration: 1s; easing: ease-in-out; }

            Image {
                width: 100%;
                height: 100%;
                source: @image-url("../assets/images/stremio_symbol.png");
                image-fit: contain;
                opacity: 0.2;
            }

            Rectangle {
                width: parent.width * max(0.0, min(100.0, buffer-visual-progress)) / 100.0;
                height: parent.height;
                clip: true;
                background: transparent;

                Image {
                    width: buffer-mark.width;
                    height: buffer-mark.height;
                    source: @image-url("../assets/images/stremio_symbol.png");
                    image-fit: contain;
                }
            }
        }
    }

    // Official Stremio player navigation. These items are positioned
    // explicitly instead of being put in a nested layout so their anchors do
    // not collapse when the video texture changes size.
    if (controls-visible) : Rectangle {
        y: 0px;
        width: 100%;
        height: 128px;
        background: @linear-gradient(180deg, #00000059 0%, #00000000 100%);
        z: 150;

        PlayerIconButton {
            x: 16px;
            y: 16px;
            width: 56px;
            height: 56px;
            icon-size: 32px;
            icon-source: @image-url("../assets/images/icons/chevron-back.svg");
            tooltip: "Back (Escape)";
            clicked => { close(); }
        }

        Text {
            x: 88px;
            y: 0px;
            width: max(0px, parent.width - 176px);
            height: 88px;
            text: item-title;
            color: #ffffffe6;
            font-size: 19px;
            font-weight: 500;
            horizontal-alignment: left;
            vertical-alignment: center;
            overflow: elide;
        }

        PlayerIconButton {
            x: parent.width - 72px;
            y: 16px;
            width: 56px;
            height: 56px;
            icon-size: 32px;
            icon-source: @image-url("../assets/images/icons/maximize.svg");
            tooltip: "Fullscreen (F)";
            clicked => { toggle-fullscreen(); }
        }
    }

    // Right Side Drawer (Series Playlist/Episodes)
    if (controls-visible && show-playlist-drawer && is-series) : playlist-drawer := Rectangle {
        x: parent.width - playlist-drawer.width;
        y: 0px;
        width: min(560px, parent.width * 0.42);
        height: parent.height;
        background: #0f0d20f0;
        border-radius: 16px;
        border-width: 1px;
        border-color: Theme.card-border;
        z: 175;

        VerticalLayout {
            padding: 24px;
            spacing: 16px;

            HorizontalLayout {
                height: 64px;
                spacing: 12px;
                alignment: center;

                PlayerIconButton {
                    icon-source: @image-url("../assets/images/icons/chevron-forward.svg");
                    tooltip: "Close episode list";
                    clicked => { show-playlist-drawer = false; }
                }

                Text {
                    text: "Episodes";
                    color: #ffffff;
                    font-size: 24px;
                    font-weight: 700;
                    vertical-alignment: center;
                }
            }

            Rectangle {
                height: 1px;
                background: #ffffff1f;
            }

            ScrollView {
                vertical-stretch: 1;
                viewport-width: self.width;
                horizontal-scrollbar-policy: always-off;
                mouse-drag-pan-enabled: true;

                VerticalLayout {
                    spacing: 8px;
                    for ep-name[idx] in episode-names : Rectangle {
                        height: 64px;
                        border-radius: 10px;
                        background: active-episode-idx == idx ? #7b5bf540 : #ffffff08;
                        
                        HorizontalLayout {
                            padding-left: 12px;
                            padding-right: 12px;
                            spacing: 8px;
                            
                            Text {
                                text: (idx + 1) + ".";
                                color: #ffffff99;
                                font-size: 14px;
                                vertical-alignment: center;
                            }
                            Text {
                                text: ep-name;
                                color: #ffffff;
                                font-size: 15px;
                                font-weight: active-episode-idx == idx ? 600 : 400;
                                vertical-alignment: center;
                                overflow: elide;
                            }
                        }

                        TouchArea {
                            clicked => {
                                play-episode(idx);
                                active-episode-idx = idx;
                            }
                        }
                    }
                }
            }
        }
    }

    // Official web control-bar geometry: a 10rem fade, a 2.5rem seek row and
    // a 4rem button row with 2rem page gutters. Explicit anchors keep the
    // timeline and right-side controls full-width on every Slint renderer.
    if (controls-visible) : Rectangle {
        y: parent.height - 160px;
        width: 100%;
        height: 160px;
        background: @linear-gradient(0deg, #00000059 0%, #0000002e 45%, #00000000 100%);
        z: 150;

        Text {
            x: 32px;
            y: 48px;
            width: 88px;
            height: 40px;
            text: elapsed-time-str;
            color: #ffffffe6;
            font-size: 17px;
            horizontal-alignment: center;
            vertical-alignment: center;
        }

        PlayerSeekBar {
            x: 120px;
            y: 48px;
            width: max(40px, parent.width - 240px);
            height: 40px;
            value: progress;
            buffered: buffered-percent;
            seek(value) => { root.seek(value); }
        }

        Text {
            x: parent.width - 120px;
            y: 48px;
            width: 88px;
            height: 40px;
            text: total-time-str;
            color: #ffffffe6;
            font-size: 17px;
            horizontal-alignment: center;
            vertical-alignment: center;
        }

        // Playback and volume controls are independently anchored to the left.
        HorizontalLayout {
            x: 32px;
            y: 88px;
            width: (is-series ? 200px : 132px) + (root.width > 900px ? 164px : 0px);
            height: 64px;
            spacing: 4px;
            alignment: start;

            PlayerIconButton {
                icon-source: paused
                    ? @image-url("../assets/images/icons/play.svg")
                    : @image-url("../assets/images/icons/pause.svg");
                tooltip: paused ? "Play (Space)" : "Pause (Space)";
                clicked => { toggle-pause(); }
            }

            if (is-series) : PlayerIconButton {
                icon-source: @image-url("../assets/images/icons/next.svg");
                tooltip: "Next episode";
                clicked => {
                    if (active-episode-idx + 1 < episode-names.length) {
                        play-episode(active-episode-idx + 1);
                        active-episode-idx = active-episode-idx + 1;
                    }
                }
            }

            PlayerIconButton {
                icon-source: (muted || volume == 0.0)
                    ? @image-url("../assets/images/icons/volume-mute.svg")
                    : (volume < 0.3
                        ? @image-url("../assets/images/icons/volume-low.svg")
                        : (volume < 0.7
                            ? @image-url("../assets/images/icons/volume-medium.svg")
                            : @image-url("../assets/images/icons/volume-high.svg")));
                tooltip: muted ? "Unmute (M)" : "Mute (M)";
                clicked => { toggle-mute(); }
            }

            if (root.width > 900px) : PlayerVolumeSlider {
                value: muted ? 0.0 : volume;
                changed(value) => { change-volume(value); }
            }
        }

        // Menus and display controls are independently anchored to the right.
        HorizontalLayout {
            width: is-series ? 472px : 404px;
            x: parent.width - self.width - 32px;
            y: 88px;
            height: 64px;
            spacing: 4px;
            alignment: end;

            PlayerIconButton {
                icon-source: @image-url("../assets/images/icons/network.svg");
                tooltip: "Playback information";
                active: show-stats-menu;
                clicked => {
                    show-stats-menu = !show-stats-menu;
                    show-speed-menu = false;
                    show-subtitles-menu = false;
                    show-audio-menu = false;
                    show-playlist-drawer = false;
                    show-options-menu = false;
                }
            }

            PlayerIconButton {
                icon-source: @image-url("../assets/images/icons/speed.svg");
                tooltip: "Playback speed";
                active: show-speed-menu;
                clicked => {
                    show-speed-menu = !show-speed-menu;
                    show-stats-menu = false;
                    show-subtitles-menu = false;
                    show-audio-menu = false;
                    show-playlist-drawer = false;
                    show-options-menu = false;
                }
            }

            PlayerIconButton {
                icon-source: @image-url("../assets/images/icons/subtitles.svg");
                tooltip: "Subtitles";
                disabled: subtitles-tracks.length == 0;
                active: show-subtitles-menu;
                clicked => {
                    show-subtitles-menu = !show-subtitles-menu;
                    show-stats-menu = false;
                    show-speed-menu = false;
                    show-audio-menu = false;
                    show-playlist-drawer = false;
                    show-options-menu = false;
                }
            }

            PlayerIconButton {
                icon-source: @image-url("../assets/images/icons/audio-tracks.svg");
                tooltip: "Audio tracks";
                disabled: audio-tracks.length == 0;
                active: show-audio-menu;
                clicked => {
                    show-audio-menu = !show-audio-menu;
                    show-stats-menu = false;
                    show-speed-menu = false;
                    show-subtitles-menu = false;
                    show-playlist-drawer = false;
                    show-options-menu = false;
                }
            }

            if (is-series) : PlayerIconButton {
                icon-source: @image-url("../assets/images/icons/episodes.svg");
                tooltip: "Episode list";
                active: show-playlist-drawer;
                clicked => {
                    show-playlist-drawer = !show-playlist-drawer;
                    show-stats-menu = false;
                    show-speed-menu = false;
                    show-subtitles-menu = false;
                    show-audio-menu = false;
                    show-options-menu = false;
                }
            }

            PlayerIconButton {
                icon-source: @image-url("../assets/images/icons/scale.svg");
                tooltip: video-scale-mode == 0 ? "Fit video" : (video-scale-mode == 1 ? "Crop video" : "Stretch video");
                clicked => {
                    video-scale-mode = Math.mod(video-scale-mode + 1, 3);
                    change-video-scale(video-scale-mode);
                    show-options-menu = false;
                }
            }

            PlayerIconButton {
                icon-source: @image-url("../assets/images/icons/more-horizontal.svg");
                tooltip: "More playback options";
                active: show-options-menu;
                clicked => {
                    show-options-menu = !show-options-menu;
                    show-stats-menu = false;
                    show-speed-menu = false;
                    show-subtitles-menu = false;
                    show-audio-menu = false;
                    show-playlist-drawer = false;
                }
            }
        }
    }

    if (controls-visible && show-options-menu) : options-menu := Rectangle {
        x: parent.width - options-menu.width - 64px;
        y: parent.height - options-menu.height - 120px;
        width: 256px;
        height: 152px;
        background: #15121ff5;
        border-radius: 12px;
        border-width: 1px;
        border-color: #ffffff1f;
        z: 180;

        VerticalLayout {
            padding: 16px;
            spacing: 8px;
            PlayerMenuOption {
                icon-source: @image-url("../assets/images/icons/link.svg");
                label: "Copy stream link";
                clicked => {
                    copy-stream-link();
                    show-options-menu = false;
                }
            }
            PlayerMenuOption {
                icon-source: @image-url("../assets/images/icons/download.svg");
                label: "Download video";
                clicked => {
                    download-video();
                    show-options-menu = false;
                }
            }
        }
    }

    if (controls-visible && show-subtitles-menu) : subtitles-menu := Rectangle {
        x: parent.width - subtitles-menu.width - 64px;
        y: parent.height - subtitles-menu.height - 120px;
        width: min(784px, parent.width - 128px);
        height: min(400px, parent.height - 208px);
        background: #15121ff5;
        border-radius: 12px;
        border-width: 1px;
        border-color: #ffffff1f;
        z: 180;

        HorizontalLayout {
            spacing: 0px;

            // Official Stremio menu: languages (16rem).
            VerticalLayout {
                width: 256px;
                spacing: 0px;

                HorizontalLayout {
                    height: 72px;
                    padding-left: 32px;
                    Text {
                        text: "Languages";
                        color: #ffffff;
                        font-size: 16px;
                        font-weight: 700;
                        vertical-alignment: center;
                    }
                }

                ScrollView {
                    vertical-stretch: 1;
                    viewport-width: self.width;
                    horizontal-scrollbar-policy: always-off;
                    mouse-drag-pan-enabled: true;

                    VerticalLayout {
                        padding-left: 16px;
                        padding-right: 16px;
                        spacing: 8px;

                        TrackItem {
                            label: "Off";
                            active: active-subtitle-idx == -1;
                            clicked => {
                                active-subtitle-idx = -1;
                                change-subtitle(-1);
                            }
                        }

                        for lang[idx] in subtitle-languages : TrackItem {
                            label: lang;
                            active: selected-subtitle-language == lang;
                            clicked => {
                                active-subtitle-idx = subtitle-language-track-indices[idx];
                                change-subtitle(active-subtitle-idx);
                            }
                        }
                    }
                }
            }

            Rectangle { width: 1px; background: #ffffff12; }

            // Official Stremio menu: variants (16rem).
            VerticalLayout {
                width: 256px;
                spacing: 0px;

                HorizontalLayout {
                    height: 72px;
                    padding-left: 32px;
                    Text {
                        text: "Variants";
                        color: #ffffff;
                        font-size: 16px;
                        font-weight: 700;
                        vertical-alignment: center;
                    }
                }

                if (active-subtitle-idx < 0) : HorizontalLayout {
                    height: 72px;
                    padding-left: 16px;
                    padding-right: 16px;
                    Text {
                        text: "Subtitles disabled";
                        color: #ffffffb8;
                        font-size: 15px;
                        font-weight: 500;
                        wrap: word-wrap;
                    }
                }

                if (active-subtitle-idx >= 0) : ScrollView {
                    vertical-stretch: 1;
                    viewport-width: self.width;
                    horizontal-scrollbar-policy: always-off;
                    mouse-drag-pan-enabled: true;

                    VerticalLayout {
                        padding-left: 16px;
                        padding-right: 16px;
                        spacing: 8px;

                        for sub-name[idx] in subtitles-tracks : Rectangle {
                            height: subtitle-track-languages[idx] == selected-subtitle-language ? 64px : 0px;
                            visible: subtitle-track-languages[idx] == selected-subtitle-language;

                            TrackItem {
                                width: 100%;
                                height: 64px;
                                label: sub-name;
                                secondary-label: subtitle-track-origins[idx];
                                active: active-subtitle-idx == idx;
                                clicked => {
                                    active-subtitle-idx = idx;
                                    change-subtitle(idx);
                                }
                            }
                        }
                    }
                }
            }

            Rectangle { width: 1px; background: #ffffff12; }

            // Official Stremio menu: per-track settings (17rem).
            VerticalLayout {
                horizontal-stretch: 1;
                spacing: 0px;

                HorizontalLayout {
                    height: 72px;
                    padding-left: 32px;
                    Text {
                        text: "Settings";
                        color: #ffffff;
                        font-size: 16px;
                        font-weight: 700;
                        vertical-alignment: center;
                    }
                }

                ScrollView {
                    vertical-stretch: 1;
                    viewport-width: self.width;
                    horizontal-scrollbar-policy: always-off;
                    mouse-drag-pan-enabled: true;

                    VerticalLayout {
                        SubtitleStepper {
                            label: "Delay";
                            unit: "s";
                            value: subtitle-delay-seconds;
                            step: 0.25;
                            minimum: -10.0;
                            maximum: 10.0;
                            disabled: active-subtitle-idx < 0;
                            changed(value) => {
                                subtitle-delay-seconds = value;
                                change-subtitle-delay(value);
                            }
                        }
                        SubtitleStepper {
                            label: "Size";
                            unit: "%";
                            value: subtitle-size-percent;
                            step: 25.0;
                            minimum: 50.0;
                            maximum: 200.0;
                            disabled: active-subtitle-idx < 0;
                            changed(value) => {
                                subtitle-size-percent = value;
                                change-subtitle-size(value);
                            }
                        }
                        SubtitleStepper {
                            label: "Vertical position";
                            unit: "%";
                            value: subtitle-offset-percent;
                            step: 1.0;
                            minimum: 0.0;
                            maximum: 100.0;
                            disabled: active-subtitle-idx < 0;
                            changed(value) => {
                                subtitle-offset-percent = value;
                                change-subtitle-offset(value);
                            }
                        }
                    }
                }
            }
        }
    }

    if (controls-visible && show-audio-menu) : audio-menu := Rectangle {
        x: parent.width - audio-menu.width - 64px;
        y: parent.height - audio-menu.height - 120px;
        width: 256px;
        height: min(400px, parent.height - 208px);
        background: #15121ff5;
        border-radius: 12px;
        border-width: 1px;
        border-color: #ffffff1f;
        z: 180;

        VerticalLayout {
            spacing: 0px;

            HorizontalLayout {
                height: 72px;
                padding-left: 32px;
                Text {
                    text: "Audio tracks";
                    color: #ffffff;
                    font-size: 16px;
                    font-weight: 700;
                    vertical-alignment: center;
                }
            }

            ScrollView {
                vertical-stretch: 1;
                viewport-width: self.width;
                horizontal-scrollbar-policy: always-off;
                mouse-drag-pan-enabled: true;

                VerticalLayout {
                    padding-left: 16px;
                    padding-right: 16px;
                    padding-bottom: 16px;
                    spacing: 8px;
                    for aud-name[idx] in audio-tracks : TrackItem {
                        label: audio-track-languages[idx];
                        secondary-label: audio-track-labels[idx];
                        active: active-audio-idx == idx;
                        clicked => {
                            active-audio-idx = idx;
                            change-audio(idx);
                            show-audio-menu = false;
                        }
                    }
                }
            }
        }
    }

    if (controls-visible && show-speed-menu) : speed-menu := Rectangle {
        x: parent.width - speed-menu.width - 32px;
        y: parent.height - speed-menu.height - 112px;
        width: 240px;
        height: min(540px, parent.height - 200px);
        background: #15121ff5;
        border-radius: 12px;
        border-width: 1px;
        border-color: #ffffff1f;
        z: 180;

        VerticalLayout {
            padding: 12px;
            spacing: 4px;

            Text {
                height: 52px;
                text: "Playback speed";
                color: #ffffff;
                font-size: 20px;
                font-weight: 700;
                vertical-alignment: center;
            }

            ScrollView {
                vertical-stretch: 1;
                viewport-width: self.width;
                horizontal-scrollbar-policy: always-off;
                mouse-drag-pan-enabled: true;

                VerticalLayout {
                    width: parent.width;
                    spacing: 4px;

                    TrackItem { label: "0.25x"; active: playback-speed == 0.25; clicked => { playback-speed = 0.25; change-speed(0.25); show-speed-menu = false; } }
                    TrackItem { label: "0.5x"; active: playback-speed == 0.5; clicked => { playback-speed = 0.5; change-speed(0.5); show-speed-menu = false; } }
                    TrackItem { label: "0.75x"; active: playback-speed == 0.75; clicked => { playback-speed = 0.75; change-speed(0.75); show-speed-menu = false; } }
                    TrackItem { label: "1.0x (Normal)"; active: playback-speed == 1.0; clicked => { playback-speed = 1.0; change-speed(1.0); show-speed-menu = false; } }
                    TrackItem { label: "1.25x"; active: playback-speed == 1.25; clicked => { playback-speed = 1.25; change-speed(1.25); show-speed-menu = false; } }
                    TrackItem { label: "1.5x"; active: playback-speed == 1.5; clicked => { playback-speed = 1.5; change-speed(1.5); show-speed-menu = false; } }
                    TrackItem { label: "2.0x"; active: playback-speed == 2.0; clicked => { playback-speed = 2.0; change-speed(2.0); show-speed-menu = false; } }
                    TrackItem { label: "3.0x"; active: playback-speed == 3.0; clicked => { playback-speed = 3.0; change-speed(3.0); show-speed-menu = false; } }
                    TrackItem { label: "4.0x"; active: playback-speed == 4.0; clicked => { playback-speed = 4.0; change-speed(4.0); show-speed-menu = false; } }
                }
            }
        }
    }

    if (controls-visible && show-stats-menu) : stats-menu := Rectangle {
        x: parent.width - stats-menu.width - 32px;
        y: parent.height - stats-menu.height - 112px;
        width: min(480px, parent.width - 64px);
        height: 360px;
        background: #15121ff5;
        border-radius: 12px;
        border-width: 1px;
        border-color: #ffffff1f;
        z: 180;

        VerticalLayout {
            padding: 24px;
            spacing: 12px;
            alignment: start;

            Text { text: "Playback information"; color: #ffffff; font-size: 22px; font-weight: 700; }
            Rectangle { height: 1px; background: #ffffff1f; }
            Text { text: "Container"; color: #ffffff80; font-size: 13px; }
            Text { text: file-format == "" ? "Unknown" : file-format; color: #ffffff; font-size: 16px; overflow: elide; }
            Text { text: "Video · " + (video-format == "" ? "Unknown" : video-format) + " · " + ((hardware-decoder == "" || hardware-decoder == "no") ? "Software decoding" : hardware-decoder); color: #ffffffcc; font-size: 15px; overflow: elide; }
            Text { text: "Audio · " + (audio-format == "" ? "Unknown" : audio-format); color: #ffffffcc; font-size: 15px; overflow: elide; }
            Text { text: "Buffered · " + round(buffered-percent) + "%"; color: #ffffffcc; font-size: 15px; }
            if (download-speed != "") : Text { text: download-speed + " down · " + upload-speed + " up · " + peer-count + " peers"; color: #ffffffcc; font-size: 15px; overflow: elide; }
            if (download-speed != "") : Text { text: "Streamed · " + round(stream-progress) + "%"; color: #ffffffcc; font-size: 15px; }
        }
    }

    // Retained temporarily as an inert compatibility tree while the Rust-side
    // IconData bindings remain part of MainWindow's public interface.
    if (false && controls-visible) : Rectangle {
        y: parent.height - 100px;
        width: 100%;
        height: 100px;
        background: @linear-gradient(0deg, #000000cc 0%, #00000000 100%);
        z: 150;

        VerticalLayout {
            padding-left: 24px;
            padding-right: 24px;
            spacing: 8px;
            alignment: center;

            // 1. Timeline / Seek Slider Row
            HorizontalLayout {
                spacing: 12px;
                
                Text {
                    text: elapsed-time-str;
                    color: #ffffffcc;
                    font-size: 12px;
                    vertical-alignment: center;
                }

                // Interactive Seek Bar
                timeline-slider := Slider {
                    horizontal-stretch: 1;
                    minimum: 0;
                    maximum: 100;
                    value: progress * 100.0;
                    changed(val) => {
                        root.seek(val / 100.0);
                    }
                }

                Text {
                    text: total-time-str;
                    color: #ffffffcc;
                    font-size: 12px;
                    vertical-alignment: center;
                }
            }

            // 2. Playback Button Controls
            HorizontalLayout {
                spacing: 16px;
                alignment: start;

                // Play / Pause
                PlayerIconButton {
                    icon: paused ? icon-play : icon-pause;
                    tooltip: paused ? "Play (Space)" : "Pause (Space)";
                    clicked => { toggle-pause(); }
                }

                // Next Episode
                if (is-series) : PlayerIconButton {
                    icon: icon-next;
                    tooltip: "Next episode";
                    clicked => {
                        if (active-episode-idx + 1 < episode-names.length) {
                            play-episode(active-episode-idx + 1);
                            active-episode-idx = active-episode-idx + 1;
                        }
                    }
                }

                // Volume and Slider
                HorizontalLayout {
                    spacing: 8px;
                    alignment: start;
                    
                    PlayerIconButton {
                        icon: (muted || volume == 0.0) ? icon-volume-mute : (volume < 0.5 ? icon-volume-low : icon-volume-high);
                        tooltip: muted ? "Unmute (M)" : "Mute (M)";
                        clicked => { toggle-mute(); }
                    }

                    Rectangle {
                        width: 80px;
                        height: 40px;
                        
                        Slider {
                            y: 10px;
                            width: 80px;
                            minimum: 0;
                            maximum: 100;
                            value: muted ? 0.0 : volume * 100.0;
                            changed(val) => {
                                change-volume(val / 100.0);
                            }
                        }
                    }
                }

                // Spacer
                Rectangle {
                    horizontal-stretch: 1;
                }

                PlayerIconButton {
                    icon: icon-fullscreen;
                    tooltip: "Fullscreen (F)";
                    clicked => { toggle-fullscreen(); }
                }

                // Subtitles Popup Button
                Rectangle {
                    width: 40px;
                    height: 40px;
                    
                    PlayerIconButton {
                        icon: icon-subtitles;
                        tooltip: "Subtitles";
                        active: show-subtitles-menu;
                        clicked => {
                            show-subtitles-menu = !show-subtitles-menu;
                            show-audio-menu = false;
                            show-speed-menu = false;
                            show-stats-menu = false;
                        }
                    }

                    if (show-subtitles-menu) : Rectangle {
                        x: -80px;
                        y: -220px;
                        width: 200px;
                        height: 200px;
                        background: #0f0d20f5;
                        border-radius: 8px;
                        border-width: 1px;
                        border-color: Theme.card-border;
                        z: 40;

                        ScrollView {
                            VerticalLayout {
                                padding: 8px;
                                spacing: 4px;
                                
                                TrackItem {
                                    label: "None (Off)";
                                    active: active-subtitle-idx == -1;
                                    clicked => {
                                        active-subtitle-idx = -1;
                                        change-subtitle(-1);
                                        show-subtitles-menu = false;
                                    }
                                }

                                for sub-name[idx] in subtitles-tracks : TrackItem {
                                    label: sub-name;
                                    active: active-subtitle-idx == idx;
                                    clicked => {
                                        active-subtitle-idx = idx;
                                        change-subtitle(idx);
                                        show-subtitles-menu = false;
                                    }
                                }
                            }
                        }
                    }
                }

                // Audio Tracks Popup Button
                Rectangle {
                    width: 40px;
                    height: 40px;
                    
                    PlayerIconButton {
                        icon: icon-audio;
                        tooltip: "Audio tracks";
                        active: show-audio-menu;
                        clicked => {
                            show-audio-menu = !show-audio-menu;
                            show-subtitles-menu = false;
                            show-speed-menu = false;
                            show-stats-menu = false;
                        }
                    }

                    if (show-audio-menu) : Rectangle {
                        x: -80px;
                        y: -170px;
                        width: 200px;
                        height: 150px;
                        background: #0f0d20f5;
                        border-radius: 8px;
                        border-width: 1px;
                        border-color: Theme.card-border;
                        z: 40;

                        ScrollView {
                            VerticalLayout {
                                padding: 8px;
                                spacing: 4px;
                                
                                for aud-name[idx] in audio-tracks : TrackItem {
                                    label: aud-name;
                                    active: active-audio-idx == idx;
                                    clicked => {
                                        active-audio-idx = idx;
                                        change-audio(idx);
                                        show-audio-menu = false;
                                    }
                                }
                            }
                        }
                    }
                }

                // Speed Select Menu Button
                Rectangle {
                    width: 40px;
                    height: 40px;
                    
                    PlayerIconButton {
                        icon: icon-speed;
                        tooltip: "Playback speed";
                        active: show-speed-menu;
                        clicked => {
                            show-speed-menu = !show-speed-menu;
                            show-subtitles-menu = false;
                            show-audio-menu = false;
                            show-stats-menu = false;
                        }
                    }

                    if (show-speed-menu) : Rectangle {
                        x: -80px;
                        y: -220px;
                        width: 160px;
                        height: 200px;
                        background: #0f0d20f5;
                        border-radius: 8px;
                        border-width: 1px;
                        border-color: Theme.card-border;
                        z: 40;

                        VerticalLayout {
                            padding: 8px;
                            spacing: 4px;
                            
                            TrackItem {
                                label: "0.5x (Slow)";
                                active: playback-speed == 0.5;
                                clicked => {
                                    playback-speed = 0.5;
                                    change-speed(0.5);
                                    show-speed-menu = false;
                                }
                            }
                            TrackItem {
                                label: "1.0x (Normal)";
                                active: playback-speed == 1.0;
                                clicked => {
                                    playback-speed = 1.0;
                                    change-speed(1.0);
                                    show-speed-menu = false;
                                }
                            }
                            TrackItem {
                                label: "1.25x";
                                active: playback-speed == 1.25;
                                clicked => {
                                    playback-speed = 1.25;
                                    change-speed(1.25);
                                    show-speed-menu = false;
                                }
                            }
                            TrackItem {
                                label: "1.5x";
                                active: playback-speed == 1.5;
                                clicked => {
                                    playback-speed = 1.5;
                                    change-speed(1.5);
                                    show-speed-menu = false;
                                }
                            }
                            TrackItem {
                                label: "2.0x (Fast)";
                                active: playback-speed == 2.0;
                                clicked => {
                                    playback-speed = 2.0;
                                    change-speed(2.0);
                                    show-speed-menu = false;
                                }
                            }
                        }
                    }
                }

                // Stats Overlay Menu Button
                Rectangle {
                    width: 40px;
                    height: 40px;
                    
                    PlayerIconButton {
                        icon: icon-stats;
                        tooltip: "Playback information";
                        active: show-stats-menu;
                        clicked => {
                            show-stats-menu = !show-stats-menu;
                            show-subtitles-menu = false;
                            show-audio-menu = false;
                            show-speed-menu = false;
                        }
                    }

                    if (show-stats-menu) : Rectangle {
                        x: -240px;
                        y: -225px;
                        width: 280px;
                        height: 205px;
                        background: #0f0d20f5;
                        border-radius: 8px;
                        border-width: 1px;
                        border-color: Theme.card-border;
                        z: 40;

                        VerticalLayout {
                            padding: 16px;
                            spacing: 8px;
                            alignment: start;

                            Text {
                                text: "Video Statistics";
                                color: Theme.accent;
                                font-size: 13px;
                                font-weight: 700;
                            }
                            Text {
                                text: "Container: " + (file-format == "" ? "Unknown" : file-format);
                                color: #ffffffcc;
                                font-size: 11px;
                            }
                            Text {
                                text: "Video format: " + (video-format == "" ? "Unknown" : video-format);
                                color: #ffffffcc;
                                font-size: 11px;
                            }
                            Text {
                                text: "Audio format: " + (audio-format == "" ? "Unknown" : audio-format);
                                color: #ffffffcc;
                                font-size: 11px;
                            }
                            Text {
                                text: "Decoder: " + ((hardware-decoder == "" || hardware-decoder == "no") ? "Software" : hardware-decoder);
                                color: #ffffffcc;
                                font-size: 11px;
                            }
                            Text {
                                text: "Buffered: " + round(buffered-percent) + "%";
                                color: #ffffffcc;
                                font-size: 11px;
                            }
                            if (download-speed != "") : Text {
                                text: "Torrent: " + download-speed + " down / " + upload-speed + " up · " + peer-count + " peers";
                                color: #ffffffcc;
                                font-size: 11px;
                            }
                            if (download-speed != "") : Text {
                                text: "Streamed: " + round(stream-progress) + "%";
                                color: #ffffffcc;
                                font-size: 11px;
                            }
                        }
                    }
                }

                // Side Playlist Drawer Trigger Button
                if (is-series) : PlayerIconButton {
                    icon: icon-menu;
                    tooltip: "Episode list";
                    active: show-playlist-drawer;
                    clicked => {
                        show-playlist-drawer = !show-playlist-drawer;
                    }
                }
            }
        }
    }
}
