import { ListView } from "std-widgets.slint";
import { Theme } from "../theme.slint";
import { MediaCard, MediaCardItem } from "../components/media_card.slint";
import { SelectField } from "../components/form_controls.slint";

export struct LibraryRow {
    cols: [MediaCardItem],
}

export component LibraryPage inherits Rectangle {
    in property <[LibraryRow]> rows: [];
    in property <int> column-count: 6;
    in property <bool> loading: false;
    in-out property <string> active-type: "All";
    in-out property <string> active-sort: "Last Watched";

    callback type-changed(string);
    callback sort-changed(string);
    callback item-selected(string);
    callback poster-requested(string);
    in-out property <length> scroll-y: 0px;

    property <length> unit: root.width > 2700px ? 18px :
        (root.width > 2100px ? 16px : (root.width > 1500px ? 15px : 14px));
    property <bool> type-open: false;
    property <bool> sort-open: false;
    property <length> grid-width: root.width - 3 * root.unit;
    property <length> card-width: root.column-count > 0
        ? (root.grid-width - (root.column-count - 1) * 0.5 * root.unit) / root.column-count
        : root.grid-width;
    property <length> card-height: (root.card-width - 2 * root.unit) * 1.464 + 6 * root.unit;

    background: transparent;

    VerticalLayout {
        spacing: 0px;

        Rectangle {
            height: 5.75 * root.unit;
            z: 50;

            HorizontalLayout {
                padding: 1.5 * root.unit;
                spacing: 1.5 * root.unit;
                alignment: start;

                SelectField {
                    unit: root.unit;
                    field-width: 15 * root.unit;
                    value: root.active-type;
                    options: ["All", "Movies", "Series", "Others"];
                    open: root.type-open;
                    toggle => {
                        root.type-open = !root.type-open;
                        root.sort-open = false;
                    }
                    selected(value) => {
                        root.type-open = false;
                        root.active-type = value;
                        root.type-changed(value);
                    }
                }

                SelectField {
                    unit: root.unit;
                    field-width: 15 * root.unit;
                    value: root.active-sort;
                    options: ["Last Watched", "A–Z", "Z–A", "Most Watched", "Watched", "Not Watched"];
                    open: root.sort-open;
                    toggle => {
                        root.sort-open = !root.sort-open;
                        root.type-open = false;
                    }
                    selected(value) => {
                        root.sort-open = false;
                        root.active-sort = value;
                        root.sort-changed(value);
                    }
                }
            }
        }

        if (root.loading) : Rectangle {
            vertical-stretch: 1;
            Text {
                text: "Loading library…";
                color: Theme.text-primary;
                opacity: 0.6;
                font-size: 1.2 * root.unit;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
        }

        if (!root.loading && root.rows.length == 0) : Rectangle {
            vertical-stretch: 1;
            VerticalLayout {
                alignment: center;
                spacing: root.unit;
                Rectangle {
                    width: parent.width;
                    height: 12 * root.unit;

                    Image {
                        x: (parent.width - self.width) / 2;
                        width: 12 * root.unit;
                        height: 12 * root.unit;
                        source: @image-url("../assets/images/icons/library.svg");
                        colorize: Theme.text-primary;
                        opacity: 0.2;
                        image-fit: contain;
                    }
                }
                Text {
                    text: "Your library is empty";
                    color: Theme.text-primary;
                    font-size: 2 * root.unit;
                    font-weight: 400;
                    horizontal-alignment: center;
                }
                Text {
                    text: "Add movies and series to find them here.";
                    color: Theme.text-primary;
                    opacity: 0.5;
                    font-size: root.unit;
                    horizontal-alignment: center;
                }
            }
        }

        if (!root.loading && root.rows.length > 0) : library-scroll := ListView {
            vertical-stretch: 1;
            viewport-width: root.width;
            viewport-y <=> root.scroll-y;
            mouse-drag-pan-enabled: true;
            horizontal-scrollbar-policy: ScrollBarPolicy.always-off;

            for row in root.rows : Rectangle {
                width: root.width;
                height: root.card-height + 0.5 * root.unit;

                HorizontalLayout {
                    x: 1.5 * root.unit;
                    width: root.grid-width;
                    height: root.card-height;
                    spacing: 0.5 * root.unit;
                    alignment: start;

                    for card-item in row.cols : MediaCard {
                        width: root.card-width;
                        unit: root.unit;
                        item: card-item;
                        clicked => { root.item-selected(card-item.id); }
                        poster-requested(url) => { root.poster-requested(url); }
                    }
                }
            }
        }
    }
}
