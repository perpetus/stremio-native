import { ScrollView, ListView } from "std-widgets.slint";
import { Theme, IconData } from "../theme.slint";
import { ButtonSurface, ChevronTextButton, IconAction } from "../components/button.slint";
import { EmptyState, SkeletonBlock } from "../components/feedback.slint";
import { StreamRow, Video, VideoPlaceholder } from "../components/media_rows.slint";
import { MetaPreview, MetaPreviewPlaceholder } from "../components/meta_preview.slint";
import { SelectField, SeasonSelectField } from "../components/select.slint";
import { SearchBar } from "../components/text_input.slint";
import { ToggleSwitch } from "../components/toggle.slint";
import { ContextMenuSurface, ContextMenuOption } from "../components/overlays.slint";

export struct StreamLink {
    id: string,
    name: string,
    description: string,
    provider: string,
}

export struct EpisodeItem {
    id: string,
    title: string,
    released: string,
    thumbnail-url: string,
    thumbnail: image,
    season: int,
    episode-num: int,
    is-upcoming: bool,
    is-watched: bool,
}

export component DetailsPage inherits Rectangle {
    width: 1280px;
    height: 720px;
    in property <string> item-title: "";
    in property <string> description: "";
    in property <image> poster;
    in property <image> background-image;
    in property <string> release-year: "";
    in property <string> runtime: "";
    in property <string> rating: "";
    in property <[string]> genres: [];
    in property <[string]> cast: [];
    in property <[string]> directors: [];
    in property <[StreamLink]> streams: [];
    in property <[string]> stream-providers: ["All"];
    in property <int> stream-loading-count: 0;
    in-out property <string> active-stream-provider: "All";
    in property <bool> loading: false;
    in property <bool> is-in-library: false;
    in property <bool> is-watched: false;
    in property <bool> has-trailer: false;
    in property <string> trailer-selection-id: "";
    callback toggle-library;
    callback toggle-watched;
    callback play-trailer(string);
    in property <bool> is-series: false;
    in property <[int]> available-seasons: [];
    in-out property <int> active-season: 1;
    in-out property <bool> season-menu-open: false;
    in-out property <bool> notifications-enabled: true;
    in property <[string]> episode-names: [];
    in-out property <int> active-episode-idx: 0;
    in property <[EpisodeItem]> episodes: [];
    in-out property <bool> in-stream-view: false;
    in-out property <string> episode-search-query: "";
    in property <string> username: "";
    in property <image> avatar-image;
    in property <bool> has-avatar-image: false;
    in property <image> default-avatar-icon;
    in property <image> anonymous-icon;
    callback toggle-fullscreen;
    callback season-changed(int);
    callback notifications-changed(bool);
    callback episode-changed(int);
    callback toggle-episode-watched(string);
    callback episode-search-changed(string);
    callback copy-stream-link(string);
    callback copy-magnet-link(string);
    callback copy-download-link(string);
    callback toggle-season-watched(int);
    in property <IconData> icon-play;
    in property <IconData> icon-link;
    in property <IconData> icon-magnet;
    in property <IconData> icon-download;
    in property <IconData> icon-eye;
    in property <IconData> icon-eye-off;
    in property <IconData> icon-clapperboard;
    callback play-stream(string);
    callback close;

    in property <length> unit: Theme.root-font-size;
    property <length> drawer-width: 30 * root.unit;
    in-out property <bool> stream-filter-open: false;
    private property <int> first-season: root.available-seasons.length > 0
        ? root.available-seasons[0] : root.active-season;
    private property <int> last-season: root.available-seasons.length > 0
        ? root.available-seasons[root.available-seasons.length - 1] : root.active-season;
    private property <length> season-button-width: 10 * root.unit;
    private property <length> season-button-x: root.width - root.drawer-width
        + 1.5 * root.unit
        + (root.drawer-width - 3 * root.unit - root.season-button-width) / 2;
    private property <length> season-button-y: 11.8 * root.unit;

    background: Theme.modal-background;
    clip: true;

    if (root.background-image.width > 0) : Image {
        width: parent.width;
        height: parent.height;
        source: root.background-image;
        image-fit: cover;
        horizontal-alignment: right;
        opacity: 0.3;
    }

    Rectangle {
        width: parent.width;
        height: parent.height;
        background: Theme.background.with-alpha(0.18);
    }

    // Navigation must remain available while metadata or streams are loading.
    IconAction {
        x: root.unit;
        y: root.unit;
        width: 3.5 * root.unit;
        height: 3.5 * root.unit;
        unit: root.unit;
        icon-source: @image-url("../assets/images/icons/chevron-back.svg");
        accessible-name: @tr("BACK" => "Back");
        surface-color: transparent;
        z: 10;
        clicked => { root.close(); }
    }

    if (root.loading) : Rectangle {
        MetaPreviewPlaceholder {
            x: 4 * root.unit;
            y: 8 * root.unit;
            width: parent.width - root.drawer-width - 8 * root.unit;
            height: parent.height - 10 * root.unit;
            unit: root.unit;
        }

        Rectangle {
            x: parent.width - root.drawer-width;
            y: 6 * root.unit;
            width: root.drawer-width;
            height: parent.height - 6 * root.unit;
            border-radius: Theme.border-radius;
            background: Theme.drawer-background;

            VerticalLayout {
                padding: 1.5 * root.unit;
                spacing: root.unit;

                SkeletonBlock {
                    height: 3.5 * root.unit;
                    radius: self.height / 2;
                }

                for _video in [0, 1, 2, 3, 4] : VideoPlaceholder {
                    horizontal-stretch: 1;
                    unit: root.unit;
                    has-thumbnail: false;
                }
            }
        }
    }

    if (!root.loading) : Rectangle {
        x: 0px;
        width: parent.width - root.drawer-width;
        height: parent.height;
        background: transparent;
        clip: true;

        MetaPreview {
            x: 4 * root.unit;
            y: 5.5 * root.unit;
            width: parent.width - 8 * root.unit;
            height: parent.height - 7.5 * root.unit;
            unit: root.unit;
            name: root.item-title;
            runtime: root.runtime;
            release-info: root.release-year;
            imdb-label: root.rating;
            description: root.description;
            genres: root.genres;
            cast: root.cast;
            directors: root.directors;
            show-trailer: root.has-trailer && root.trailer-selection-id != "";
            show-library-actions: true;
            in-library: root.is-in-library;
            watched: root.is-watched;
            show-ratings: true;
            show-share: true;
            trailer-requested => { root.play-trailer(root.trailer-selection-id); }
            library-requested(_in-library) => { root.toggle-library(); }
            watched-requested(_watched) => { root.toggle-watched(); }
        }
    }

    if (!root.loading) : Rectangle {
        x: parent.width - root.drawer-width;
        y: 6 * root.unit;
        width: root.drawer-width;
        height: parent.height - 6 * root.unit;
        border-radius: Theme.border-radius;
        background: Theme.drawer-background;
        clip: true;

        VerticalLayout {
            padding-top: 1.5 * root.unit;
            padding-left: 1.5 * root.unit;
            padding-right: 1.5 * root.unit;
            padding-bottom: root.unit;
            spacing: root.unit;

            if (!root.is-series) : Rectangle {
                height: 2.75 * root.unit;
                z: 10000;

                SelectField {
                    unit: root.unit;
                    field-width: parent.width;
                    value: root.active-stream-provider;
                    options: root.stream-providers;
                    open: root.stream-filter-open;
                    toggle => { root.stream-filter-open = !root.stream-filter-open; }
                    selected(provider) => {
                        root.active-stream-provider = provider;
                        root.stream-filter-open = false;
                    }
                }
            }

            if (root.is-series && !root.in-stream-view && root.is-in-library) : Rectangle {
                height: 2.8 * root.unit;
                background: transparent;

                ToggleSwitch {
                    x: 0px;
                    y: (parent.height - self.height) / 2;
                    unit: root.unit;
                    checked <=> root.notifications-enabled;
                    toggled => { root.notifications-changed(root.notifications-enabled); }
                }

                Text {
                    x: 4.2 * root.unit;
                    y: 0px;
                    width: parent.width - self.x;
                    height: parent.height;
                    text: @tr("DETAIL_RECEIVE_NOTIF_SERIES" => "Receive notifications for new episodes");
                    color: Theme.surface-light-90;
                    font-size: root.unit;
                    vertical-alignment: center;
                    overflow: elide;
                }
            }

            if (root.is-series && !root.in-stream-view && root.available-seasons.length > 0) : Rectangle {
                height: 4 * root.unit;
                background: transparent;
                z: 10000;

                ChevronTextButton {
                    x: 0px;
                    y: 0.5 * root.unit;
                    unit: root.unit;
                    label: @tr("Prev");
                    icon-source: @image-url("../assets/images/icons/chevron-back.svg");
                    enabled: root.active-season > root.first-season;
                    clicked => {
                        root.active-season = max(root.first-season, root.active-season - 1);
                        root.season-changed(root.active-season);
                    }
                }

                SeasonSelectField {
                    x: (parent.width - self.width) / 2;
                    y: 0.5 * root.unit;
                    unit: root.unit;
                    field-width: root.season-button-width;
                    value: root.active-season;
                    options: root.available-seasons;
                    open: root.season-menu-open;
                    toggle => { root.season-menu-open = !root.season-menu-open; }
                    selected(season) => {
                        root.active-season = season;
                        root.season-menu-open = false;
                        root.season-changed(season);
                    }
                }

                ChevronTextButton {
                    x: parent.width - self.width;
                    y: 0.5 * root.unit;
                    unit: root.unit;
                    label: @tr("Next");
                    trailing-icon: true;
                    icon-source: @image-url("../assets/images/icons/chevron-forward.svg");
                    enabled: root.active-season < root.last-season;
                    clicked => {
                        root.active-season = min(root.last-season, root.active-season + 1);
                        root.season-changed(root.active-season);
                    }
                }
            }

            if (root.is-series && !root.in-stream-view) : SearchBar {
                horizontal-stretch: 1;
                height: 3 * root.unit;
                unit: root.unit;
                text <=> root.episode-search-query;
                title: @tr("SEARCH_VIDEOS" => "search videos");
                edited => { root.episode-search-changed(root.episode-search-query); }
            }

            if (root.is-series && root.in-stream-view) : HorizontalLayout {
                height: 3.5 * root.unit;
                spacing: root.unit;

                IconAction {
                    width: 2.5 * root.unit;
                    height: 3.5 * root.unit;
                    unit: root.unit;
                    icon-size: 1.25 * root.unit;
                    icon-source: @image-url("../assets/images/icons/chevron-back.svg");
                    label: @tr("Back to episodes");
                    surface-color: transparent;
                    clicked => { root.in-stream-view = false; }
                }

                Text {
                    horizontal-stretch: 1;
                    text: root.episode-names.length > root.active-episode-idx
                        ? root.episode-names[root.active-episode-idx]
                        : @tr("Episode streams");
                    color: Theme.text-primary;
                    font-size: 1.05 * root.unit;
                    font-weight: 500;
                    vertical-alignment: center;
                    overflow: elide;
                }
                Text {
                    width: 4 * root.unit;
                    text: @tr("ALL" => "All") + "  ▾";
                    color: Theme.text-primary;
                    opacity: 0.8;
                    font-size: root.unit;
                    vertical-alignment: center;
                }
            }

            if (root.is-series && !root.in-stream-view) : ListView {
                vertical-stretch: 1;
                for episode[index] in root.episodes : Video {
                    width: parent.width;
                    unit: root.unit;
                    title: episode.title;
                    released: episode.released;
                    thumbnail: episode.thumbnail;
                    episode-number: episode.episode-num;
                    upcoming: episode.is-upcoming;
                    watched: episode.is-watched;
                    selected => {
                        root.active-episode-idx = index;
                        root.episode-changed(index);
                        root.in-stream-view = true;
                    }
                    toggle-watched => { root.toggle-episode-watched(episode.id); }
                }
            }

            if ((!root.is-series || root.in-stream-view) && root.streams.length == 0) : EmptyState {
                height: 8 * root.unit;
                unit: root.unit;
                icon-source: @image-url("../assets/images/icons/addons-outline.svg");
                title: @tr("NO_STREAM" => "No streams were found");
                message: @tr("INSTALL_MORE_ADDONS" => "For more streams, please install more addons");
            }

            if ((!root.is-series || root.in-stream-view) && root.streams.length > 0) : ListView {
                vertical-stretch: 1;
                horizontal-scrollbar-policy: ScrollBarPolicy.always-off;
                mouse-drag-pan-enabled: true;

                for stream in root.streams : stream-delegate := Rectangle {
                    private property <bool> matches-provider:
                        root.active-stream-provider == "All"
                            || stream.provider == root.active-stream-provider;
                    width: parent.width;
                    // The additional 0.1rem preserves the web row gap while
                    // allowing ListView to virtualize off-screen streams.
                    height: self.matches-provider ? 5.5 * root.unit : 0px;
                    clip: true;
                    background: transparent;

                    StreamRow {
                        visible: stream-delegate.matches-provider;
                        x: 0px;
                        y: 0px;
                        width: parent.width;
                        height: 5.4 * root.unit;
                        unit: root.unit;
                        name: stream.name;
                        description: stream.description;
                        play => { root.play-stream(stream.id); }
                    }
                }
            }

            if ((!root.is-series || root.in-stream-view) && root.stream-loading-count > 0) : VerticalLayout {
                height: 4 * root.unit;
                spacing: 0.75 * root.unit;
                Text {
                    text: @tr("STREMIO_TV_STREAMS_STILL_LOADING" => "{} addon is still loading...", root.stream-loading-count);
                    color: Theme.text-primary;
                    font-size: root.unit;
                    horizontal-alignment: center;
                }
                Rectangle {
                    height: 0.3 * root.unit;
                    border-radius: self.height / 2;
                    background: Theme.accent;
                }
            }
        }
    }

    if (!root.loading) : HorizontalLayout {
        x: parent.width - 11 * root.unit;
        y: root.unit;
        height: 3.5 * root.unit;
        spacing: 0.5 * root.unit;
        alignment: start;
        z: 50;

        IconAction {
            width: 3.5 * root.unit;
            height: 3.5 * root.unit;
            unit: root.unit;
            border-radius: 0.75 * root.unit;
            icon-size: 2 * root.unit;
            icon-source: @image-url("../assets/images/icons/maximize.svg");
            label: @tr("SETTINGS_SHORTCUT_FULLSCREEN" => "Toggle Fullscreen");
            surface-color: transparent;
            clicked => { root.toggle-fullscreen(); }
        }

        Rectangle {
            width: 3.5 * root.unit;
            border-radius: 0.75 * root.unit;
            background: transparent;
            Rectangle {
                x: 0.55 * root.unit;
                y: 0.55 * root.unit;
                width: 2.4 * root.unit;
                height: 2.4 * root.unit;
                background: Theme.accent;
                border-radius: self.width / 2;
                border-width: 0.15 * root.unit;
                border-color: Theme.accent;
                clip: true;

                if (root.username == "" || root.username == "Guest") : Image {
                    width: parent.width;
                    height: parent.height;
                    source: root.anonymous-icon;
                    image-fit: cover;
                }
                if (root.username != "" && root.username != "Guest" && root.has-avatar-image) : Image {
                    width: parent.width;
                    height: parent.height;
                    source: root.avatar-image;
                    image-fit: cover;
                }
                if (root.username != "" && root.username != "Guest" && !root.has-avatar-image) : Image {
                    width: parent.width;
                    height: parent.height;
                    source: root.default-avatar-icon;
                    image-fit: cover;
                }
            }
        }
    }

}
