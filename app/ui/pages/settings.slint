import { ScrollView } from "std-widgets.slint";
import { Theme, IconData } from "../theme.slint";
import { ButtonSurface, MenuButton, PillButton } from "../components/button.slint";
import { NativeTextField } from "../components/text_input.slint";
import { ToggleSwitch } from "../components/toggle.slint";
import { Slider } from "../components/slider.slint";
import { UiStyle } from "../cinematic/types.slint";

component SettingsSection inherits VerticalLayout {
    in property <length> unit: 16px;
    in property <string> title;

    width: 35 * root.unit;
    padding-top: 3 * root.unit;
    padding-bottom: 3 * root.unit;
    spacing: 0px;
    alignment: start;

    Text {
        height: 5.4 * root.unit;
        text: root.title;
        color: Theme.text-primary;
        font-size: 1.8 * root.unit;
        font-weight: 400;
        vertical-alignment: top;
    }

    @children

    Rectangle {
        height: 1px;
        background: Theme.overlay;
    }
}

component SettingsLink inherits Rectangle {
    in property <length> unit: 16px;
    in property <string> label;
    callback clicked;

    height: 3.5 * root.unit;
    background: transparent;

    HorizontalLayout {
        alignment: start;
        Text {
            text: root.label;
            color: touch.has-hover ? Theme.accent.brighter(15%) : Theme.accent;
            font-size: root.unit;
            font-weight: 500;
            vertical-alignment: center;
        }
    }

    touch := TouchArea {
        clicked => { root.clicked(); }
    }
}

component SettingsOption inherits Rectangle {
    in property <length> unit: 16px;
    in property <string> label;
    in property <string> description: "";

    height: root.description == "" ? 5 * root.unit : 6 * root.unit;
    background: transparent;

    HorizontalLayout {
        spacing: 2 * root.unit;

        VerticalLayout {
            horizontal-stretch: 1;
            alignment: center;
            spacing: 0.35 * root.unit;
            Text {
                text: root.label;
                color: Theme.text-primary;
                font-size: root.unit;
                font-weight: 500;
                wrap: word-wrap;
            }
            if (root.description != "") : Text {
                text: root.description;
                color: Theme.text-primary;
                opacity: 0.45;
                font-size: 0.85 * root.unit;
                wrap: word-wrap;
                overflow: elide;
            }
        }

        VerticalLayout {
            width: 16 * root.unit;
            alignment: center;
            HorizontalLayout {
                alignment: end;
                @children
            }
        }
    }
}

component InterfaceStyleChoice inherits ButtonSurface {
    in property <length> unit: 16px;
    in property <string> title;
    in property <string> description;
    in property <bool> selected: false;

    height: 6.5 * root.unit;
    border-radius: Theme.compact-radius;
    border-width: root.has-focus ? 2px : 1px;
    border-color: root.has-focus ? Theme.focus
        : (root.selected ? Theme.accent : Theme.divider);
    background: root.pressed ? Theme.overlay-pressed
        : (root.has-hover ? Theme.overlay-hover : Theme.control-background);
    accessible-name: root.title + ". " + root.description;

    VerticalLayout {
        padding: root.unit;
        spacing: 0.35 * root.unit;
        Text {
            text: root.title;
            color: Theme.text-primary;
            font-size: root.unit;
            font-weight: root.selected ? 700 : 500;
        }
        Text {
            text: root.description;
            color: Theme.text-secondary;
            font-size: 0.78 * root.unit;
            wrap: word-wrap;
            overflow: elide;
        }
    }

    if (root.selected) : Rectangle {
        x: parent.width - 1.65 * root.unit;
        y: 0.65 * root.unit;
        width: root.unit;
        height: root.unit;
        border-radius: self.width / 2;
        background: Theme.accent;
        Text {
            text: "✓";
            color: Theme.text-primary;
            font-size: 0.7 * root.unit;
            font-weight: 800;
            horizontal-alignment: center;
            vertical-alignment: center;
        }
    }
}

component InterfaceStyleSelector inherits Rectangle {
    in property <length> unit: 16px;
    in property <UiStyle> value: UiStyle.classic;
    callback changed(UiStyle);

    height: 10 * root.unit;
    background: transparent;

    restore-focus := Timer {
        interval: 1ms;
        running: true;
        triggered => {
            self.stop();
            if (root.value == UiStyle.classic) {
                classic-choice.focus();
            } else {
                cinematic-choice.focus();
            }
        }
    }

    VerticalLayout {
        spacing: 0.75 * root.unit;
        Text {
            height: 1.5 * root.unit;
            text: "Interface style";
            color: Theme.text-primary;
            font-size: root.unit;
            font-weight: 500;
        }
        HorizontalLayout {
            spacing: root.unit;
            classic-choice := InterfaceStyleChoice {
                horizontal-stretch: 1;
                unit: root.unit;
                title: "Classic";
                description: "The original Stremio desktop interface.";
                selected: root.value == UiStyle.classic;
                clicked => { root.changed(UiStyle.classic); }
            }
            cinematic-choice := InterfaceStyleChoice {
                horizontal-stretch: 1;
                unit: root.unit;
                title: "Cinematic";
                description: "Artwork-led browsing with a compact top navigation.";
                selected: root.value == UiStyle.cinematic;
                clicked => { root.changed(UiStyle.cinematic); }
            }
        }
    }
}

export component SettingsPage inherits Rectangle {
    width: 1280px;
    height: 720px;
    in-out property <string> torrent-cache-size: "2.0 GB";
    in property <string> server-url: "";
    in-out property <string> interface-language: "English";
    in-out property <string> subtitles-language: "English";
    in-out property <string> torrent-profile: "Default";
    in-out property <bool> hardware-acceleration: true;
    in-out property <bool> binge-watching: true;
    in-out property <bool> discord-rpc-enabled: false;
    in-out property <string> tidb-api-key: "";
    in-out property <bool> tidb-show-intro: true;
    in-out property <bool> tidb-show-recap: true;
    in-out property <bool> tidb-show-credits: true;
    in-out property <bool> tidb-show-preview: true;
    in-out property <bool> hide-spoilers: false;
    in-out property <bool> gamepad-support: false;
    in-out property <bool> play-in-background: true;
    in-out property <bool> subtitles-auto-select: true;
    in-out property <string> subtitles-font: "Roboto";
    in-out property <string> subtitles-size: "100";
    in-out property <bool> subtitles-bold: false;
    in-out property <string> subtitles-offset: "5";
    in-out property <string> seek-duration: "10";
    in-out property <bool> pause-on-minimize: false;
    in-out property <bool> quit-on-close: true;
    in property <bool> export-loading: false;
    in property <string> export-status: "";
    in-out property <bool> streaming-seeding: false;
    in-out property <bool> streaming-dht: true;
    in-out property <bool> streaming-pex: true;
    in-out property <bool> streaming-lsd: true;
    in-out property <string> streaming-remote-url: "";
    in-out property <string> streaming-logs-text: "No logs loaded. Click Refresh.";
    in property <IconData> refresh-icon;
    in property <IconData> folder-icon;
    in-out property <bool> esc-exit-fullscreen: true;

    callback open-external-url(string);
    callback apply-cache-settings(float);
    callback change-interface-language(string);
    callback change-subtitles-language(string);
    callback change-torrent-profile(string);
    callback change-hardware-acceleration(bool);
    callback clear-search-history;
    callback shutdown-server;
    callback change-seeding-enabled(bool);
    callback change-dht-enabled(bool);
    callback change-pex-enabled(bool);
    callback change-lsd-enabled(bool);
    callback refresh-logs;
    callback open-logs-folder;
    callback export-data;
    callback change-binge-watching(bool);
    callback change-discord-rpc-enabled(bool);
    callback change-tidb-api-key(string);
    callback change-tidb-show-intro(bool);
    callback change-tidb-show-recap(bool);
    callback change-tidb-show-credits(bool);
    callback change-tidb-show-preview(bool);
    callback change-hide-spoilers(bool);
    callback change-gamepad-support(bool);
    callback change-play-in-background(bool);
    callback change-subtitles-auto-select(bool);
    callback change-subtitles-font(string);
    callback change-subtitles-size(string);
    callback change-subtitles-bold(bool);
    callback change-subtitles-offset(string);
    callback change-seek-duration(string);
    callback change-pause-on-minimize(bool);
    callback change-quit-on-close(bool);

    in property <length> unit: Theme.root-font-size;
    in property <UiStyle> ui-style: UiStyle.classic;
    callback change-ui-style(UiStyle);
    in-out property <int> active-category: 0;
    background: transparent;

    function update-active-category(offset: length) {
        root.active-category = (offset < 30 * root.unit) ? 0 :
            ((offset < 75 * root.unit) ? 1 :
            ((offset < 165 * root.unit) ? 2 :
            ((offset < 215 * root.unit) ? 3 : 4)));
    }

    HorizontalLayout {
        spacing: 0px;

        VerticalLayout {
            width: 18 * root.unit;
            padding-top: 3 * root.unit;
            padding-bottom: 3 * root.unit;
            padding-left: 1.5 * root.unit;
            padding-right: 1.5 * root.unit;
            spacing: 0.5 * root.unit;

            MenuButton { unit: root.unit; label: "General"; selected: root.active-category == 0; clicked => { scroll.viewport-y = 0px; root.active-category = 0; } }
            MenuButton { unit: root.unit; label: "Interface"; selected: root.active-category == 1; clicked => { scroll.viewport-y = -35 * root.unit; root.active-category = 1; } }
            MenuButton { unit: root.unit; label: "Player"; selected: root.active-category == 2; clicked => { scroll.viewport-y = -80 * root.unit; root.active-category = 2; } }
            MenuButton { unit: root.unit; label: "Streaming"; selected: root.active-category == 3; clicked => { scroll.viewport-y = -175 * root.unit; root.active-category = 3; } }
            MenuButton { unit: root.unit; label: "Shortcuts"; selected: root.active-category == 4; clicked => { scroll.viewport-y = -225 * root.unit; root.active-category = 4; } }
            Rectangle { vertical-stretch: 1; }
            Text {
                height: 2 * root.unit;
                text: "Stremio Native";
                color: Theme.text-primary;
                opacity: 0.3;
                font-size: 0.9 * root.unit;
                vertical-alignment: center;
            }
        }

        scroll := ScrollView {
            horizontal-stretch: 1;
            scrolled => {
                root.update-active-category(-self.viewport-y);
            }

            VerticalLayout {
                padding-left: 3 * root.unit;
                padding-right: 3 * root.unit;
                spacing: 0px;
                alignment: start;

                general-sec := SettingsSection {
                    unit: root.unit;
                    title: "General";

                    SettingsOption {
                        unit: root.unit;
                        label: "Discord Rich Presence";
                        description: "Show what you are watching in your Discord profile.";
                        ToggleSwitch {
                            unit: root.unit;
                            checked: root.discord-rpc-enabled;
                            toggled => { root.change-discord-rpc-enabled(self.checked); }
                        }
                    }

                    SettingsOption {
                        unit: root.unit;
                        label: "Export user data";
                        description: root.export-status == ""
                            ? "Download a backup of your library and settings."
                            : root.export-status;
                        PillButton {
                            width: 16 * root.unit;
                            unit: root.unit;
                            label: root.export-loading ? "Preparing…" : "Export";
                            outlined: true;
                            enabled: !root.export-loading;
                            clicked => { root.export-data(); }
                        }
                    }
                    SettingsOption {
                        unit: root.unit;
                        label: "Clear search history";
                        description: "Delete all recent search queries stored locally.";
                        PillButton {
                            width: 16 * root.unit;
                            unit: root.unit;
                            label: "Clear history";
                            outlined: true;
                            clicked => { root.clear-search-history(); }
                        }
                    }

                    SettingsLink {
                        unit: root.unit;
                        label: "Data export";
                        clicked => { root.export-data(); }
                    }
                    SettingsLink {
                        unit: root.unit;
                        label: "Support";
                        clicked => { root.open-external-url("https://stremio.zendesk.com/hc/en-us"); }
                    }
                    SettingsLink {
                        unit: root.unit;
                        label: "Source code";
                        clicked => { root.open-external-url("https://github.com/stremio/stremio-native"); }
                    }
                    SettingsLink {
                        unit: root.unit;
                        label: "Terms of Service";
                        clicked => { root.open-external-url("https://www.stremio.com/tos"); }
                    }
                    SettingsLink {
                        unit: root.unit;
                        label: "Privacy Policy";
                        clicked => { root.open-external-url("https://www.stremio.com/privacy"); }
                    }
                    SettingsLink {
                        unit: root.unit;
                        label: "Delete account";
                        clicked => { root.open-external-url("https://stremio.zendesk.com/hc/en-us/articles/360021428911-How-to-delete-my-account"); }
                    }
                }

                interface-sec := SettingsSection {
                    unit: root.unit;
                    title: "Interface";
                    InterfaceStyleSelector {
                        unit: root.unit;
                        value: root.ui-style;
                        changed(style) => { root.change-ui-style(style); }
                    }
                    SettingsOption {
                        unit: root.unit;
                        label: "Interface language";
                        NativeTextField {
                            width: 16 * root.unit;
                            unit: root.unit;
                            text: root.interface-language;
                            placeholder-text: "English";
                            accepted => { root.change-interface-language(self.text); }
                        }
                    }
                    SettingsOption {
                        unit: root.unit;
                        label: "Gamepad support";
                        ToggleSwitch { unit: root.unit; checked: root.gamepad-support; toggled => { root.change-gamepad-support(self.checked); } }
                    }
                    SettingsOption {
                        unit: root.unit;
                        label: "Hide spoilers";
                        ToggleSwitch { unit: root.unit; checked: root.hide-spoilers; toggled => { root.change-hide-spoilers(self.checked); } }
                    }
                    SettingsOption {
                        unit: root.unit;
                        label: "Quit when closing the window";
                        ToggleSwitch { unit: root.unit; checked: root.quit-on-close; toggled => { root.change-quit-on-close(self.checked); } }
                    }
                    SettingsOption {
                        unit: root.unit;
                        label: "Esc exits fullscreen";
                        ToggleSwitch { unit: root.unit; checked: root.esc-exit-fullscreen; toggled => { root.esc-exit-fullscreen = self.checked; } }
                    }
                }

                player-sec := SettingsSection {
                    unit: root.unit;
                    title: "Player";

                    // Subtitles Settings
                    SettingsOption {
                        unit: root.unit;
                        label: "Default subtitles language";
                        NativeTextField {
                            width: 16 * root.unit;
                            unit: root.unit;
                            text: root.subtitles-language;
                            placeholder-text: "English";
                            accepted => { root.change-subtitles-language(self.text); }
                        }
                    }
                    SettingsOption {
                        unit: root.unit;
                        label: "Automatically select subtitles";
                        ToggleSwitch { unit: root.unit; checked: root.subtitles-auto-select; toggled => { root.change-subtitles-auto-select(self.checked); } }
                    }
                    SettingsOption {
                        unit: root.unit;
                        label: "Subtitle font";
                        NativeTextField {
                            width: 16 * root.unit;
                            unit: root.unit;
                            text: root.subtitles-font;
                            placeholder-text: "Roboto";
                            accepted => { root.change-subtitles-font(self.text); }
                        }
                    }
                    SettingsOption {
                        unit: root.unit;
                        label: "Subtitle size";
                        description: "Percentage from 50 to 200.";
                        NativeTextField {
                            width: 16 * root.unit;
                            unit: root.unit;
                            text: root.subtitles-size;
                            placeholder-text: "100";
                            accepted => { root.change-subtitles-size(self.text); }
                        }
                    }
                    SettingsOption {
                        unit: root.unit;
                        label: "Bold subtitles";
                        ToggleSwitch { unit: root.unit; checked: root.subtitles-bold; toggled => { root.change-subtitles-bold(self.checked); } }
                    }
                    SettingsOption {
                        unit: root.unit;
                        label: "Subtitle vertical offset";
                        description: "Percentage from the bottom edge.";
                        NativeTextField {
                            width: 16 * root.unit;
                            unit: root.unit;
                            text: root.subtitles-offset;
                            placeholder-text: "5";
                            accepted => { root.change-subtitles-offset(self.text); }
                        }
                    }

                    // Advanced Settings
                    SettingsOption {
                        unit: root.unit;
                        label: "Play next episode automatically";
                        ToggleSwitch { unit: root.unit; checked: root.binge-watching; toggled => { root.change-binge-watching(self.checked); } }
                    }
                    SettingsOption {
                        unit: root.unit;
                        label: "Continue playback in the background";
                        ToggleSwitch { unit: root.unit; checked: root.play-in-background; toggled => { root.change-play-in-background(self.checked); } }
                    }
                    SettingsOption {
                        unit: root.unit;
                        label: "Seek duration";
                        description: "Seconds skipped by the forward and back shortcuts.";
                        NativeTextField {
                            width: 16 * root.unit;
                            unit: root.unit;
                            text <=> root.seek-duration;
                            placeholder-text: "10";
                            accepted => { root.change-seek-duration(self.text); }
                        }
                    }
                    SettingsOption {
                        unit: root.unit;
                        label: "Pause when minimized";
                        ToggleSwitch { unit: root.unit; checked: root.pause-on-minimize; toggled => { root.change-pause-on-minimize(self.checked); } }
                    }
                    SettingsOption {
                        unit: root.unit;
                        label: "Hardware-accelerated decoding";
                        description: "Use the GPU for video decoding. A restart may be required.";
                        ToggleSwitch {
                            unit: root.unit;
                            checked: root.hardware-acceleration;
                            toggled => { root.change-hardware-acceleration(self.checked); }
                        }
                    }
                    SettingsOption {
                        unit: root.unit;
                        label: "TheIntroDB API Key";
                        description: "Optional API Key for TheIntroDB Premium.";
                        NativeTextField {
                            width: 16 * root.unit;
                            unit: root.unit;
                            text: root.tidb-api-key;
                            placeholder-text: "Leave empty for free tier";
                            accepted => { root.change-tidb-api-key(self.text); }
                        }
                    }
                    SettingsOption {
                        unit: root.unit;
                        label: "Show Skip Intro Button";
                        ToggleSwitch { unit: root.unit; checked: root.tidb-show-intro; toggled => { root.change-tidb-show-intro(self.checked); } }
                    }
                    SettingsOption {
                        unit: root.unit;
                        label: "Show Skip Recap Button";
                        ToggleSwitch { unit: root.unit; checked: root.tidb-show-recap; toggled => { root.change-tidb-show-recap(self.checked); } }
                    }
                    SettingsOption {
                        unit: root.unit;
                        label: "Show Skip Credits Button";
                        ToggleSwitch { unit: root.unit; checked: root.tidb-show-credits; toggled => { root.change-tidb-show-credits(self.checked); } }
                    }
                    SettingsOption {
                        unit: root.unit;
                        label: "Show Skip Preview Button";
                        ToggleSwitch { unit: root.unit; checked: root.tidb-show-preview; toggled => { root.change-tidb-show-preview(self.checked); } }
                    }
                }

                streaming-sec := SettingsSection {
                    unit: root.unit;
                    title: "Streaming";
                    SettingsOption {
                        unit: root.unit;
                        label: "Streaming server endpoint";
                        description: root.server-url == "" ? "The streaming server is offline." : root.server-url;
                        Text {
                            width: 16 * root.unit;
                            text: root.server-url == "" ? "Offline" : "Online";
                            color: root.server-url == "" ? Theme.text-secondary : Theme.success;
                            font-size: root.unit;
                            font-weight: 600;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                            overflow: elide;
                        }
                    }
                    if (root.streaming-remote-url != "") : SettingsOption {
                        unit: root.unit;
                        label: "Remote access URL";
                        description: root.streaming-remote-url;
                    }
                    SettingsOption {
                        unit: root.unit;
                        label: "Torrent cache size";
                        description: "Limit the disk space available for torrent buffering.";
                        VerticalLayout {
                            width: 16 * root.unit;
                            spacing: 0.35 * root.unit;
                            Text {
                                text: root.torrent-cache-size;
                                color: Theme.accent;
                                font-size: 0.9 * root.unit;
                                font-weight: 600;
                                horizontal-alignment: center;
                            }
                            Slider {
                                minimum: 0;
                                maximum: 50;
                                value: 2;
                                changed(value) => { root.apply-cache-settings(value); }
                            }
                        }
                    }
                    SettingsOption {
                        unit: root.unit;
                        label: "Torrent connection profile";
                        HorizontalLayout {
                            width: 16 * root.unit;
                            spacing: 0.5 * root.unit;
                            for profile in ["Default", "Fast", "Ultra Fast"] : PillButton {
                                horizontal-stretch: 1;
                                height: 3.5 * root.unit;
                                unit: root.unit;
                                label: profile;
                                label-font-size: 0.8 * root.unit;
                                label-font-weight: 600;
                                primary: root.torrent-profile == profile;
                                accent-color: Theme.accent;
                                surface-color: Theme.overlay;
                                clicked => {
                                    root.torrent-profile = profile;
                                    root.change-torrent-profile(
                                        profile == "Ultra Fast" ? "ultrafast" :
                                        (profile == "Fast" ? "fast" : "default")
                                    );
                                }
                            }
                        }
                    }
                    SettingsOption { unit: root.unit; label: "Enable DHT"; ToggleSwitch { unit: root.unit; checked: root.streaming-dht; toggled => { root.change-dht-enabled(self.checked); } } }
                    SettingsOption { unit: root.unit; label: "Enable peer exchange"; ToggleSwitch { unit: root.unit; checked: root.streaming-pex; toggled => { root.change-pex-enabled(self.checked); } } }
                    SettingsOption { unit: root.unit; label: "Enable local peer discovery"; ToggleSwitch { unit: root.unit; checked: root.streaming-lsd; toggled => { root.change-lsd-enabled(self.checked); } } }
                    SettingsOption {
                        unit: root.unit;
                        label: "Enable torrent seeding";
                        description: "Upload downloaded pieces while streaming.";
                        ToggleSwitch { unit: root.unit; checked: root.streaming-seeding; toggled => { root.change-seeding-enabled(self.checked); } }
                    }
                    PillButton {
                        width: 18 * root.unit;
                        unit: root.unit;
                        label: "Shutdown streaming server";
                        outlined: true;
                        clicked => { root.shutdown-server(); }
                    }
                }

                shortcuts-sec := SettingsSection {
                    unit: root.unit;
                    title: "Shortcuts";
                    SettingsOption { unit: root.unit; label: "Play / Pause"; Text { text: "Space"; color: Theme.text-primary; opacity: 0.5; font-size: root.unit; horizontal-alignment: center; } }
                    SettingsOption { unit: root.unit; label: "Fullscreen"; Text { text: "F"; color: Theme.text-primary; opacity: 0.5; font-size: root.unit; horizontal-alignment: center; } }
                    SettingsOption { unit: root.unit; label: "Volume"; Text { text: "Up / Down"; color: Theme.text-primary; opacity: 0.5; font-size: root.unit; horizontal-alignment: center; } }
                    SettingsOption { unit: root.unit; label: "Seek"; Text { text: "Left / Right"; color: Theme.text-primary; opacity: 0.5; font-size: root.unit; horizontal-alignment: center; } }
                }
            }
        }
    }
}
