import { ListView } from "std-widgets.slint";
import { Theme } from "../theme.slint";
import { MediaCardItem } from "../components/media_card.slint";
import { MediaCatalogRow } from "../components/media_carousel.slint";
import { MetaRowPlaceholder } from "../components/meta_row.slint";
import { EmptyState } from "../components/feedback.slint";

export struct BoardSection {
    title: string,
    r-type: string,
    catalog-id: string,
    addon-base: string,
    catalog-index: int,
    loading: bool,
    error-message: string,
    items: [MediaCardItem],
    is-continue-watching: bool,
}

export component BoardPage inherits Rectangle {
    width: 1280px;
    height: 720px;
    in property <[MediaCardItem]> continue-watching: [];
    in property <[BoardSection]> sections: [];
    in property <bool> loading: false;

    callback item-selected(string, string, string);
    callback remove-continue-watching(string);
    callback see-all-continue-watching;
    callback see-all-clicked(int);
    callback catalog-visible(int);
    callback poster-requested(string);

    in property <length> unit: Theme.root-font-size;
    property <int> visible-count: root.width > 2100px ? 9 :
        (root.width > 1500px ? 8 : (root.width > 1200px ? 7 : (root.width > 900px ? 6 : 4)));
    property <length> card-width: (root.width - 2 * root.unit) / root.visible-count;
    property <length> card-height: (root.card-width - 2 * root.unit) * 1.464 + 6 * root.unit;

    background: transparent;

    if (root.loading && root.sections.length == 0) : ListView {
        x: root.unit;
        width: max(0px, root.width - 2 * root.unit);
        mouse-drag-pan-enabled: true;
        horizontal-scrollbar-policy: ScrollBarPolicy.always-off;

        for _catalog in [0, 1, 2] : MetaRowPlaceholder {
            width: parent.width;
            unit: root.unit;
            item-width: max(9 * root.unit, root.card-width - 2 * root.unit);
        }
    }

    if (!root.loading && root.sections.length == 0) : EmptyState {
        x: root.unit;
        width: max(0px, root.width - 2 * root.unit);
        height: 20 * root.unit;
        unit: root.unit;
        icon-source: @image-url("../assets/images/icons/home-outline.svg");
        title: @tr("Nothing to watch yet");
        message: @tr("Your recommendations and continue-watching items will appear here.");
    }

    // Board rows are virtualized vertically. This prevents every poster in
    // every off-screen catalogue from becoming part of the active image set.
    if (root.sections.length > 0) : ListView {
        x: root.unit;
        width: max(0px, root.width - 2 * root.unit);
        mouse-drag-pan-enabled: true;
        horizontal-scrollbar-policy: ScrollBarPolicy.always-off;

        for section in root.sections : Rectangle {
                width: parent.width;
                height: 3 * root.unit + root.card-height;
                background: transparent;
                property <int> visible-catalog-index: section.catalog-index;

                init => {
                    if (self.visible-catalog-index >= 0) {
                        root.catalog-visible(self.visible-catalog-index);
                    }
                }
                changed visible-catalog-index => {
                    if (self.visible-catalog-index >= 0) {
                        root.catalog-visible(self.visible-catalog-index);
                    }
                }

                if (section.loading) : MetaRowPlaceholder {
                    width: parent.width;
                    height: parent.height;
                    unit: root.unit;
                    title: section.title;
                    show-see-all: true;
                    item-width: max(9 * root.unit, root.card-width - 2 * root.unit);
                }

                if (!section.loading) : MediaCatalogRow {
                    width: parent.width;
                    height: parent.height;
                    unit: root.unit;
                    title: section.is-continue-watching
                        ? @tr("BOARD_CONTINUE_WATCHING" => "Continue watching")
                        : section.title;
                    message: section.error-message;
                    show-see-all: true;
                    card-width: root.card-width;
                    card-height: root.card-height;
                    items: section.items;
                    show-close-button: section.is-continue-watching;
                    see-all-requested => {
                        if (section.is-continue-watching) {
                            root.see-all-continue-watching();
                        } else {
                            root.see-all-clicked(section.catalog-index);
                        }
                    }
                    item-selected(id, media-type, video-id) => {
                        root.item-selected(id, media-type, video-id);
                    }
                    remove-clicked(id) => {
                        if (section.is-continue-watching) {
                            root.remove-continue-watching(id);
                        }
                    }
                    poster-requested(url) => { root.poster-requested(url); }
                }
        }
    }
}
