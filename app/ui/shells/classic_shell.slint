import { AppState, AppActions } from "../app_contract.slint";
import { Theme } from "../theme.slint";
import { Sidebar } from "../components/sidebar.slint";
import { SearchBox } from "../components/search.slint";
import { MenuButton } from "../components/button.slint";
import { BoardPage } from "../pages/board.slint";
import { DiscoverPage } from "../pages/discover.slint";
import { LibraryPage } from "../pages/library.slint";
import { AddonsPage } from "../pages/addons.slint";
import { SettingsPage } from "../pages/settings.slint";
import { CalendarPage } from "../pages/calendar.slint";
import { SearchPage } from "../pages/search.slint";
import { UiStyle } from "../cinematic/types.slint";

export component ClassicShell inherits VerticalLayout {
    in property <int> route-index: 0;
    in property <bool> show-details-layer: false;
    in-out property <int> settings-active-category: 0;
    private property <length> ui-unit: root.width >= 2800px ? 18px
        : (root.width >= 2200px ? 16px : (root.width >= 1600px ? 15px : 14px));
            width: 100%;
            height: 100%;
            visible: !root.show-details-layer;
            spacing: 0;
            padding: 0;

            // Official horizontal navigation bar.
            if (AppState.ui-style == UiStyle.classic && !root.show-details-layer) : Rectangle {
                height: 5.5 * root.ui-unit;
                background: transparent;
                z: 100;

                HorizontalLayout {
                    padding-right: root.ui-unit;
                    alignment: space-between;

                    // Left Block: Logo symbol
                    Rectangle {
                        width: 6 * root.ui-unit;
                        height: 5.5 * root.ui-unit;
                        
                        Image {
                            source: @image-url("../assets/images/stremio-logo.svg");
                            width: 2.5 * root.ui-unit;
                            height: 2.5 * root.ui-unit;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                            opacity: 0.9;
                        }
                    }

                    // Center Search pill (starts next to logo, left-ish aligned)
                    VerticalLayout {
                        alignment: center;
                        
                        search-input := SearchBox {
                            width: 30 * root.ui-unit;
                            height: 3.25 * root.ui-unit;
                            unit: root.ui-unit;
                            text <=> AppState.search-query;
                            suggestions: AppState.search-suggestions;
                            edited(value) => {
                                AppActions.global-search-edited(value);
                                if (root.route-index == 1) {
                                    AppActions.discover-search-changed(value);
                                } else if (root.route-index == 2) {
                                    AppActions.library-search-changed(value);
                                }
                            }
                            accepted(value) => {
                                if (value != "") {
                                    AppActions.global-search-submitted(value);
                                }
                            }
                            cleared => { AppActions.global-search-edited(""); }
                            suggestion-selected(id, media-type, title) => {
                                AppState.search-query = title;
                                AppActions.global-search-suggestion-selected(id, media-type);
                            }
                        }
                    }

                    HorizontalLayout {
                        spacing: 0.5 * root.ui-unit;
                        alignment: center;
                        padding-top: 0.5 * root.ui-unit;

                        Rectangle {
                            width: 3.5 * root.ui-unit;
                            height: 3.5 * root.ui-unit;
                            border-radius: 0.75 * root.ui-unit;
                            background: top-fullscreen.has-hover ? Theme.overlay : transparent;
                            top-fullscreen := TouchArea {
                                clicked => { AppActions.player-toggle-fullscreen(); }
                            }
                             Image {
                                source: @image-url("../assets/images/icons/maximize.svg");
                                width: 2 * root.ui-unit;
                                height: 2 * root.ui-unit;
                                x: (parent.width - self.width) / 2;
                                y: (parent.height - self.height) / 2;
                                opacity: 0.6;
                                image-fit: contain;
                            }
                        }

                        Rectangle {
                            width: 5.5 * root.ui-unit;
                            height: 3.5 * root.ui-unit;
                            border-radius: 0.75 * root.ui-unit;
                            background: profile-area.has-hover ? Theme.overlay : transparent;

                            profile-area := TouchArea {
                                clicked => { AppState.profile-menu-open = !AppState.profile-menu-open; }
                            }

                            Rectangle {
                                x: 0.55 * root.ui-unit;
                                y: 0.55 * root.ui-unit;
                                width: 2.4 * root.ui-unit;
                                height: 2.4 * root.ui-unit;
                                background: Theme.accent;
                                border-radius: self.width / 2;
                                border-width: 0.15 * root.ui-unit;
                                border-color: Theme.accent;
                                clip: true;
                            
                                if (AppState.username == "" || AppState.username == "Guest") : Image {
                                    source: AppState.anonymous-icon;
                                    width: parent.width;
                                    height: parent.height;
                                    image-fit: cover;
                                }
                            
                                if (AppState.username != "" && AppState.username != "Guest" && AppState.has-avatar-image) : Image {
                                    source: AppState.avatar-image;
                                    width: parent.width;
                                    height: parent.height;
                                    image-fit: cover;
                                }
                            
                                if (AppState.username != "" && AppState.username != "Guest" && !AppState.has-avatar-image) : Image {
                                    source: AppState.default-avatar-icon;
                                    width: parent.width;
                                    height: parent.height;
                                    image-fit: cover;
                                }
                            }

                            Image {
                                x: parent.width - self.width - 0.55 * root.ui-unit;
                                y: (parent.height - self.height) / 2;
                                width: root.ui-unit;
                                height: root.ui-unit;
                                source: @image-url("../assets/images/icons/caret-down.svg");
                                colorize: Theme.text-primary;
                                opacity: 0.6;
                                image-fit: contain;
                            }
                        }
                    }
                }

                if (AppState.profile-menu-open) : Rectangle {
                    x: 0px;
                    y: 0px;
                    width: root.width;
                    height: root.height;
                    background: transparent;
                    z: 190;

                    TouchArea {
                        clicked => { AppState.profile-menu-open = false; }
                    }
                }

                if (AppState.profile-menu-open) : Rectangle {
                    x: parent.width - 23 * root.ui-unit;
                    y: 6.5 * root.ui-unit;
                    width: 22 * root.ui-unit;
                    height: layout.preferred-height;
                    border-radius: 0.75 * root.ui-unit;
                    background: Theme.modal-background;
                    clip: true;
                    z: 200;

                    layout := VerticalLayout {
                        spacing: 0px;

                        HorizontalLayout {
                            height: 7 * root.ui-unit;
                            padding-left: root.ui-unit;
                            padding-right: root.ui-unit;
                            spacing: root.ui-unit;
                            alignment: start;

                            Rectangle {
                                width: 4 * root.ui-unit;
                                height: 4 * root.ui-unit;
                                border-radius: self.width / 2;
                                background: Theme.text-primary;
                                clip: true;
                                y: (parent.height - self.height) / 2;

                                if (AppState.username == "" || AppState.username == "Guest") : Image {
                                    source: AppState.anonymous-icon;
                                    width: parent.width;
                                    height: parent.height;
                                    image-fit: cover;
                                }
                                if (AppState.username != "" && AppState.username != "Guest" && AppState.has-avatar-image) : Image {
                                    source: AppState.avatar-image;
                                    width: parent.width;
                                    height: parent.height;
                                    image-fit: cover;
                                }
                                if (AppState.username != "" && AppState.username != "Guest" && !AppState.has-avatar-image) : Image {
                                    source: AppState.default-avatar-icon;
                                    width: parent.width;
                                    height: parent.height;
                                    image-fit: cover;
                                }
                            }

                            VerticalLayout {
                                alignment: center;
                                spacing: 0.5 * root.ui-unit;
                                Text {
                                    text: AppState.username == "" || AppState.username == "Guest" ? "Anonymous user" : AppState.username;
                                    color: Theme.text-primary;
                                    font-size: root.ui-unit;
                                    overflow: elide;
                                }
                                Text {
                                    text: AppState.username == "" || AppState.username == "Guest" ? "Log in / Sign up" : "Log out";
                                    color: Theme.accent;
                                    font-size: 0.9 * root.ui-unit;
                                    font-weight: 600;
                                    TouchArea {
                                        mouse-cursor: pointer;
                                        clicked => {
                                            AppState.profile-menu-open = false;
                                            if (AppState.username == "" || AppState.username == "Guest") {
                                                AppState.username = "";
                                            } else {
                                                AppActions.logout();
                                            }
                                        }
                                    }
                                }
                            }
                        }

                        Rectangle { height: 1px; background: Theme.overlay; }

                        MenuButton {
                            unit: root.ui-unit;
                            label: AppState.is-fullscreen ? "Exit Fullscreen" : "Enter Fullscreen";
                            show-icon: true;
                            icon-source: AppState.is-fullscreen ? @image-url("../assets/images/icons/minimize.svg") : @image-url("../assets/images/icons/maximize.svg");
                            clicked => {
                                AppState.profile-menu-open = false;
                                AppActions.toggle-fullscreen();
                            }
                        }

                        Rectangle { height: 1px; background: Theme.overlay; }

                        MenuButton {
                            unit: root.ui-unit;
                            label: "Settings";
                            show-icon: true;
                            icon-source: @image-url("../assets/images/icons/settings.svg");
                            clicked => {
                                AppState.profile-menu-open = false;
                                AppActions.tab-changed(4);
                            }
                        }
                        MenuButton {
                            unit: root.ui-unit;
                            label: "Addons";
                            show-icon: true;
                            icon-source: @image-url("../assets/images/icons/addons.svg");
                            clicked => {
                                AppState.profile-menu-open = false;
                                AppActions.tab-changed(3);
                            }
                        }
                        MenuButton {
                            unit: root.ui-unit;
                            label: "Play URL or magnet link";
                            show-icon: true;
                            icon-source: @image-url("../assets/images/icons/magnet-link.svg");
                            clicked => {
                                AppState.profile-menu-open = false;
                                search-input.focus-input();
                            }
                        }
                        MenuButton {
                            unit: root.ui-unit;
                            label: "Help & Feedback";
                            show-icon: true;
                            icon-source: @image-url("../assets/images/icons/help.svg");
                            clicked => {
                                AppState.profile-menu-open = false;
                                AppActions.open-external-url("https://stremio.zendesk.com/");
                            }
                        }

                        Rectangle { height: 1px; background: Theme.overlay; }

                        MenuButton {
                            unit: root.ui-unit;
                            label: "Terms of Service";
                            show-icon: false;
                            clicked => {
                                AppState.profile-menu-open = false;
                                AppActions.open-external-url("https://www.stremio.com/tos");
                            }
                        }
                        MenuButton {
                            unit: root.ui-unit;
                            label: "Privacy Policy";
                            show-icon: false;
                            clicked => {
                                AppState.profile-menu-open = false;
                                AppActions.open-external-url("https://www.stremio.com/privacy");
                            }
                        }
                        if (AppState.username != "" && AppState.username != "Guest") : MenuButton {
                            unit: root.ui-unit;
                            label: "User Panel";
                            show-icon: false;
                            clicked => {
                                AppState.profile-menu-open = false;
                                AppActions.open-external-url("https://www.stremio.com/acc-settings");
                            }
                        }
                    }
                }
            }

            // Lower Content Area (Sidebar on left, main content page on right)
            HorizontalLayout {
                spacing: 0;
                padding: 0;
                vertical-stretch: 1;

                Sidebar {
                    unit: root.ui-unit;
                    visible: !root.show-details-layer && AppState.ui-style == UiStyle.classic;
                    width: AppState.ui-style == UiStyle.classic ? Theme.vertical-nav-bar-size : 0px;
                    active-tab: root.route-index;
                    server-status: AppState.server-status;
                    username: AppState.username;
                    avatar-letter: AppState.avatar-letter;
                    
                    board-icon: AppState.board-icon;
                    discover-icon: AppState.discover-icon;
                    library-icon: AppState.library-icon;
                    calendar-icon: AppState.calendar-icon;
                    addons-icon: AppState.addons-icon;
                    settings-icon: AppState.settings-icon;
                    logout-icon: AppState.logout-icon;

                    change-tab(tab) => {
                        AppActions.tab-changed(tab);
                    }
                    logout => { AppActions.logout(); }
                }

                // Inner content area
                Rectangle {
                    min-width: 0px;
                    horizontal-stretch: 1;
                    vertical-stretch: 1;
                    background: transparent;
                    clip: true;

                    page-host := Rectangle {
                    y: 0px;
                    width: parent.width;
                    height: parent.height - self.y;
                    background: transparent;
                    
                    if (root.route-index == 0) : BoardPage {
                        width: parent.width;
                        height: parent.height;
                        unit: root.ui-unit;
                        continue-watching: AppState.debug-preview-enabled && AppState.debug-preview-page == 0
                            && (AppState.debug-preview-state == "empty"
                                || AppState.debug-preview-state == "loading"
                                || AppState.debug-preview-state == "catalogs-only")
                            ? [] : AppState.board-continue-watching;
                        sections: AppState.debug-preview-enabled && AppState.debug-preview-page == 0
                            && (AppState.debug-preview-state == "empty"
                                || AppState.debug-preview-state == "loading"
                                || AppState.debug-preview-state == "continue-only")
                            ? [] : AppState.board-sections;
                        loading: AppState.debug-preview-enabled && AppState.debug-preview-page == 0
                            ? AppState.debug-preview-state == "loading"
                            : AppState.loading;
                        item-selected(id, media-type, video-id) => {
                            AppActions.board-item-selected(id, media-type, video-id);
                        }
                        remove-continue-watching(id) => { AppActions.remove-continue-watching(id); }
                        see-all-continue-watching() => { AppActions.board-see-all-continue-watching(); }
                        see-all-clicked(t, id, base) => { AppActions.board-see-all-clicked(t, id, base); }
                        poster-requested(url) => { AppActions.request-poster(url); }
                    }

                    if (root.route-index == 1) : DiscoverPage {
                        width: parent.width;
                        height: parent.height;
                        unit: root.ui-unit;
                        rows: AppState.debug-preview-enabled && AppState.debug-preview-page == 1
                            && (AppState.debug-preview-state == "empty" || AppState.debug-preview-state == "loading")
                            ? [] : AppState.discover-rows;
                        column-count: AppState.discover-column-count;
                        loading: AppState.debug-preview-enabled && AppState.debug-preview-page == 1
                            ? AppState.debug-preview-state == "loading"
                            : AppState.loading;

                        available-types: AppState.discover-types;
                        active-type: AppState.discover-active-type;
                        available-catalogs: AppState.discover-catalogs;
                        active-catalog: AppState.discover-active-catalog;
                        available-genres: AppState.discover-genres;
                        active-genre: AppState.discover-active-genre;

                        has-preview: AppState.debug-preview-enabled && AppState.debug-preview-page == 1
                            ? (AppState.debug-preview-state == "movie-selected"
                                || AppState.debug-preview-state == "series-selected")
                            : AppState.discover-has-preview;
                        preview-title: AppState.debug-preview-enabled && AppState.debug-preview-page == 1
                            && AppState.debug-preview-state == "movie-selected"
                            ? "Dune: Part Two" : AppState.discover-preview-title;
                        preview-description: AppState.debug-preview-enabled && AppState.debug-preview-page == 1
                            && AppState.debug-preview-state == "movie-selected"
                            ? "Paul Atreides unites with Chani and the Fremen while seeking revenge against the conspirators who destroyed his family."
                            : AppState.discover-preview-description;
                        preview-rating: AppState.debug-preview-enabled && AppState.debug-preview-page == 1
                            && AppState.debug-preview-state == "movie-selected" ? "8.5" : AppState.discover-preview-rating;
                        preview-year: AppState.debug-preview-enabled && AppState.debug-preview-page == 1
                            && AppState.debug-preview-state == "movie-selected" ? "2024" : AppState.discover-preview-year;
                        preview-runtime: AppState.debug-preview-enabled && AppState.debug-preview-page == 1
                            && AppState.debug-preview-state == "movie-selected" ? "166 min" : AppState.discover-preview-runtime;
                        preview-genres: AppState.debug-preview-enabled && AppState.debug-preview-page == 1
                            && AppState.debug-preview-state == "movie-selected"
                            ? ["Science Fiction", "Adventure", "Drama"] : AppState.discover-preview-genres;
                        preview-cast: AppState.debug-preview-enabled && AppState.debug-preview-page == 1
                            && AppState.debug-preview-state == "movie-selected"
                            ? ["Timothée Chalamet", "Zendaya", "Rebecca Ferguson"] : AppState.discover-preview-cast;
                        preview-directors: AppState.debug-preview-enabled && AppState.debug-preview-page == 1
                            && AppState.debug-preview-state == "movie-selected"
                            ? ["Denis Villeneuve"] : AppState.discover-preview-directors;
                        preview-is-in-library: AppState.discover-preview-is-in-library;
                        preview-is-watched: AppState.discover-preview-is-watched;
                        preview-has-trailer: AppState.discover-preview-has-trailer;
                        preview-trailer-selection-id: AppState.detail-trailer-selection-id;
                        preview-poster: AppState.discover-preview-poster;
                        type-open: AppState.debug-preview-enabled && AppState.debug-preview-page == 1
                            && AppState.debug-preview-state == "type-dropdown";
                        catalog-open: AppState.debug-preview-enabled && AppState.debug-preview-page == 1
                            && AppState.debug-preview-state == "catalog-dropdown";
                        genre-open: AppState.debug-preview-enabled && AppState.debug-preview-page == 1
                            && AppState.debug-preview-state == "genre-dropdown";

                        type-changed(t) => { AppActions.discover-type-changed(t); }
                        catalog-changed(c) => { AppActions.discover-catalog-changed(c); }
                        genre-changed(g) => { AppActions.discover-genre-changed(g); }
                        item-selected(id) => { AppActions.discover-item-selected(id); }
                        poster-requested(url) => { AppActions.request-poster(url); }
                        play-preview => { AppActions.play-preview(); }
                        toggle-library-preview => { AppActions.toggle-library-preview(); }
                        toggle-watched-preview => { AppActions.details-toggle-watched(); }
                        play-trailer-preview(selection-id) => { AppActions.play-stream(selection-id); }
                        scroll-y: AppState.discover-scroll-y;
                    }

                    if (root.route-index == 2) : LibraryPage {
                        width: parent.width;
                        height: parent.height;
                        unit: root.ui-unit;
                        rows: AppState.debug-preview-enabled && AppState.debug-preview-page == 2
                            && (AppState.debug-preview-state == "empty" || AppState.debug-preview-state == "loading")
                            ? [] : AppState.library-rows;
                        column-count: AppState.library-column-count;
                        loading: AppState.debug-preview-enabled && AppState.debug-preview-page == 2
                            ? AppState.debug-preview-state == "loading"
                            : AppState.loading;
                        active-type: AppState.library-active-type;
                        active-sort: AppState.library-active-sort;
                        type-open: AppState.debug-preview-enabled && AppState.debug-preview-page == 2
                            && AppState.debug-preview-state == "type-dropdown";
                        sort-open: AppState.debug-preview-enabled && AppState.debug-preview-page == 2
                            && AppState.debug-preview-state == "sort-dropdown";

                        type-changed(t) => { AppActions.library-type-changed(t); }
                        sort-changed(s) => { AppActions.library-sort-changed(s); }
                        item-selected(id, media-type) => { AppActions.library-item-selected(id, media-type); }
                        poster-requested(url) => { AppActions.request-poster(url); }
                        scroll-y: AppState.library-scroll-y;
                    }

                    if (root.route-index == 3) : AddonsPage {
                        width: parent.width;
                        height: parent.height;
                        unit: root.ui-unit;
                        addons: AppState.debug-preview-enabled && AppState.debug-preview-page == 3
                            && (AppState.debug-preview-state == "empty" || AppState.debug-preview-state == "loading")
                            ? [] : AppState.addons-list;
                        search-query: AppState.addons-search-query;
                        active-filter <=> AppState.addons-active-filter;
                        active-type <=> AppState.addons-active-type;
                        loading: AppState.debug-preview-enabled && AppState.debug-preview-page == 3
                            ? AppState.debug-preview-state == "loading"
                            : AppState.loading;
                        details-open: AppState.debug-preview-enabled && AppState.debug-preview-page == 3
                            ? (AppState.debug-preview-state == "addon-details"
                                || AppState.debug-preview-state == "addon-details-loading"
                                || AppState.debug-preview-state == "addon-details-error")
                            : AppState.addon-details-open;
                        details-addon: AppState.addon-details-addon;
                        details-loading: AppState.debug-preview-enabled && AppState.debug-preview-page == 3
                            ? AppState.debug-preview-state == "addon-details-loading"
                            : AppState.addon-details-loading;
                        details-error: AppState.debug-preview-enabled && AppState.debug-preview-page == 3
                            ? (AppState.debug-preview-state == "addon-details-error" ? "Unable to load the addon manifest." : "")
                            : AppState.addon-details-error;
                        details-configurable: AppState.addon-details-configurable;
                        details-configuration-required: AppState.addon-details-configuration-required;
                        filter-open: AppState.debug-preview-enabled && AppState.debug-preview-page == 3
                            && AppState.debug-preview-state == "filter-dropdown";
                        type-open: AppState.debug-preview-enabled && AppState.debug-preview-page == 3
                            && AppState.debug-preview-state == "type-dropdown";
                        add-modal-open: AppState.debug-preview-enabled && AppState.debug-preview-page == 3
                            && AppState.debug-preview-state == "add-addon";
                        install-addon(url) => { AppActions.install-addon(url); }
                        uninstall-addon(url) => { AppActions.uninstall-addon(url); }
                        open-addon-details(url) => { AppActions.open-addon-details(url); }
                        close-addon-details => { AppActions.close-addon-details(); }
                        configure-addon(url) => { AppActions.configure-addon(url); }
                        share-addon(url) => { AppActions.share-addon(url); }
                        search-changed(query) => { AppActions.addons-search-changed(query); }
                    }

                    if (root.route-index == 4) : SettingsPage {
                        width: parent.width;
                        height: parent.height;
                        unit: root.ui-unit;
                        ui-style: AppState.ui-style;
                        active-category: AppState.debug-preview-enabled && AppState.debug-preview-page == 4
                            ? (AppState.debug-preview-state == "interface" ? 1
                                : (AppState.debug-preview-state == "player-settings" ? 2
                                : (AppState.debug-preview-state == "streaming" ? 3
                                : (AppState.debug-preview-state == "shortcuts" ? 4
                                : (AppState.debug-preview-state == "diagnostics" ? 5 : 0)))))
                            : root.settings-active-category;
                        changed active-category => {
                            if (!AppState.debug-preview-enabled) {
                                root.settings-active-category = self.active-category;
                            }
                        }
                        torrent-cache-size: AppState.torrent-cache-size;
                        server-url: AppState.server-url;
                        interface-language: AppState.settings-interface-language;
                        subtitles-language: AppState.settings-subtitles-language;
                        torrent-profile: AppState.settings-torrent-profile;
                        hardware-acceleration: AppState.settings-hardware-acceleration;
                        binge-watching: AppState.settings-binge-watching;
                        discord-rpc-enabled: AppState.settings-discord-rpc-enabled;
                        tidb-api-key: AppState.settings-tidb-api-key;
                        tidb-show-intro: AppState.settings-tidb-show-intro;
                        tidb-show-recap: AppState.settings-tidb-show-recap;
                        tidb-show-credits: AppState.settings-tidb-show-credits;
                        tidb-show-preview: AppState.settings-tidb-show-preview;
                        hide-spoilers: AppState.settings-hide-spoilers;
                        gamepad-support: AppState.settings-gamepad-support;
                        play-in-background: AppState.settings-play-in-background;
                        subtitles-auto-select: AppState.settings-subtitles-auto-select;
                        subtitles-font: AppState.settings-subtitles-font;
                        subtitles-size: AppState.settings-subtitles-size;
                        subtitles-bold: AppState.settings-subtitles-bold;
                        subtitles-offset: AppState.settings-subtitles-offset;
                        seek-duration: AppState.settings-seek-duration;
                        pause-on-minimize: AppState.settings-pause-on-minimize;
                        quit-on-close: AppState.settings-quit-on-close;
                        export-loading: AppState.debug-preview-enabled && AppState.debug-preview-page == 4
                            ? AppState.debug-preview-state == "exporting"
                            : AppState.settings-export-loading;
                        export-status: AppState.debug-preview-enabled && AppState.debug-preview-page == 4
                            && AppState.debug-preview-state == "exporting"
                            ? "Exporting profile data…"
                            : AppState.settings-export-status;

                        streaming-seeding: AppState.settings-streaming-seeding;
                        streaming-dht: AppState.settings-streaming-dht;
                        streaming-pex: AppState.settings-streaming-pex;
                        streaming-lsd: AppState.settings-streaming-lsd;
                        streaming-remote-url: AppState.settings-streaming-remote-url;
                        streaming-logs-text: AppState.settings-streaming-logs-text;
                        refresh-icon: AppState.refresh-icon;
                        folder-icon: AppState.folder-icon;

                        apply-cache-settings(val) => { AppActions.apply-cache-settings(val); }
                        change-interface-language(lang) => { AppActions.settings-change-interface-language(lang); }
                        change-ui-style(style) => { AppState.ui-style = style; AppActions.settings-change-ui-style(style); }
                        change-subtitles-language(lang) => { AppActions.settings-change-subtitles-language(lang); }
                        change-torrent-profile(prof) => { AppActions.settings-change-torrent-profile(prof); }
                        change-hardware-acceleration(val) => { AppActions.settings-change-hardware-acceleration(val); }
                        clear-search-history => { AppActions.settings-clear-search-history(); }
                        shutdown-server => { AppActions.shutdown-server(); }

                        change-seeding-enabled(val) => { AppActions.settings-change-seeding-enabled(val); }
                        change-dht-enabled(val) => { AppActions.settings-change-dht-enabled(val); }
                        change-pex-enabled(val) => { AppActions.settings-change-pex-enabled(val); }
                        change-lsd-enabled(val) => { AppActions.settings-change-lsd-enabled(val); }
                        refresh-logs => { AppActions.settings-refresh-logs(); }
                        open-logs-folder => { AppActions.settings-open-logs-folder(); }
                        export-data => { AppActions.settings-export-data(); }
                        change-binge-watching(val) => { AppActions.settings-change-binge-watching(val); }
                        change-discord-rpc-enabled(val) => { AppActions.settings-change-discord-rpc-enabled(val); }
                        change-tidb-api-key(val) => { AppActions.settings-change-tidb-api-key(val); }
                        change-tidb-show-intro(val) => { AppActions.settings-change-tidb-show-intro(val); }
                        change-tidb-show-recap(val) => { AppActions.settings-change-tidb-show-recap(val); }
                        change-tidb-show-credits(val) => { AppActions.settings-change-tidb-show-credits(val); }
                        change-tidb-show-preview(val) => { AppActions.settings-change-tidb-show-preview(val); }
                        change-hide-spoilers(val) => { AppActions.settings-change-hide-spoilers(val); }
                        change-gamepad-support(val) => { AppActions.settings-change-gamepad-support(val); }
                        change-play-in-background(val) => { AppActions.settings-change-play-in-background(val); }
                        change-subtitles-auto-select(val) => { AppActions.settings-change-subtitles-auto-select(val); }
                        change-subtitles-font(val) => { AppActions.settings-change-subtitles-font(val); }
                        change-subtitles-size(val) => { AppActions.settings-change-subtitles-size(val); }
                        change-subtitles-bold(val) => { AppActions.settings-change-subtitles-bold(val); }
                        change-subtitles-offset(val) => { AppActions.settings-change-subtitles-offset(val); }
                        change-seek-duration(val) => { AppActions.settings-change-seek-duration(val); }
                        change-pause-on-minimize(val) => { AppActions.settings-change-pause-on-minimize(val); }
                        change-quit-on-close(val) => { AppActions.settings-change-quit-on-close(val); }
                        open-external-url(url) => { AppActions.open-external-url(url); }
                    }

                    if (root.route-index == 5) : CalendarPage {
                        width: parent.width;
                        height: parent.height;
                        unit: root.ui-unit;
                        authenticated: AppState.debug-preview-enabled && AppState.debug-preview-page == 5
                            ? AppState.debug-preview-state != "signed-out"
                            : AppState.username != "" && AppState.username != "Guest";
                        loading: AppState.debug-preview-enabled && AppState.debug-preview-page == 5
                            ? AppState.debug-preview-state == "loading"
                            : AppState.calendar-loading;
                        selected-year: AppState.calendar-selected-year;
                        selected-month: AppState.calendar-selected-month;
                        previous-month: AppState.calendar-previous-month;
                        next-month: AppState.calendar-next-month;
                        rows: AppState.debug-preview-enabled && AppState.debug-preview-page == 5
                            && AppState.debug-preview-state == "empty" ? [] : AppState.calendar-rows;
                        previous => { AppActions.calendar-previous(); }
                        next => { AppActions.calendar-next(); }
                        item-selected(id, media-type) => { AppActions.calendar-item-selected(id, media-type); }
                    }

                    if (root.route-index == 6) : SearchPage {
                        width: parent.width;
                        height: parent.height;
                        unit: root.ui-unit;
                        query: AppState.debug-preview-enabled && AppState.debug-preview-page == 6
                            && AppState.debug-preview-state == "idle" ? "" : AppState.search-query;
                        sections: AppState.debug-preview-enabled && AppState.debug-preview-page == 6
                            && (AppState.debug-preview-state == "empty"
                                || AppState.debug-preview-state == "loading"
                                || AppState.debug-preview-state == "idle")
                            ? [] : AppState.search-sections;
                        loading: AppState.debug-preview-enabled && AppState.debug-preview-page == 6
                            ? AppState.debug-preview-state == "loading"
                            : AppState.search-loading;
                        catalog-count: AppState.debug-preview-enabled && AppState.debug-preview-page == 6
                            && (AppState.debug-preview-state == "empty" || AppState.debug-preview-state == "idle")
                            ? 0 : AppState.search-catalog-count;
                        item-selected(id, media-type, video-id) => {
                            AppActions.search-item-selected(id, media-type, video-id);
                        }
                        poster-requested(url) => { AppActions.request-poster(url); }
                    }
                    }
                }
            }
}
